{
    "name": "arsip-surat-digital-enterprise",
    "version": "3.0.0",
    "description": "Sistem Manajemen Arsip Surat Digital Enterprise - Full Stack Application",
    "main": "index.html",
    "scripts": {
        "dev": "live-server --port=3000 --host=localhost",
        "build": "npm run minify:css && npm run minify:js && npm run copy:files",
        "minify:css": "cleancss -o dist/css/enterprise.min.css src/public/css/enterprise.css",
        "minify:js": "terser src/public/js/*.js -o dist/js/enterprise.min.js -c -m",
        "copy:files": "cpy '*.html' 'src/manifest.json' 'service-worker.js' 'robots.txt' 'sitemap.xml' '.htaccess' dist/",
        "test": "jest --coverage",
        "test:unit": "jest tests/unit/",
        "test:integration": "jest tests/integration/",
        "test:e2e": "cypress run",
        "lint": "eslint src/public/js/ --fix",
        "lint:css": "stylelint src/public/css/ --fix",
        "format": "prettier --write '**/*.{js,json,css,html,md}'",
        "type-check": "tsc --noEmit",
        "deploy": "npm run build && npm run deploy:server",
        "deploy:server": "rsync -avz --delete dist/ user@server:/var/www/html/",
        "docker:build": "docker build -t arsip-surat-enterprise .",
        "docker:run": "docker-compose up -d",
        "docker:stop": "docker-compose down",
        "clean": "rimraf dist/ coverage/"
    },
    "keywords": [
        "arsip",
        "surat",
        "digital",
        "enterprise",
        "management",
        "document",
        "e-office",
        "pwa",
        "spa"
    ],
    "author": "Enterprise Development Team",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/warso-id/arsip-surat-digital-enterprise.git"
    },
    "bugs": {
        "url": "https://github.com/warso-id/arsip-surat-digital-enterprise/issues"
    },
    "homepage": "https://warso-id.github.io/arsip-surat-digital-enterprise",
    "devDependencies": {
        "clean-css-cli": "^5.6.3",
        "cpy-cli": "^5.0.0",
        "cypress": "^13.6.0",
        "eslint": "^8.56.0",
        "jest": "^29.7.0",
        "live-server": "^1.2.2",
        "prettier": "^3.2.0",
        "rimraf": "^5.0.5",
        "stylelint": "^16.1.0",
        "terser": "^5.26.0",
        "typescript": "^5.3.3"
    },
    "jest": {
        "testEnvironment": "jsdom",
        "collectCoverageFrom": [
            "src/public/js/**/*.js"
        ],
        "coverageThreshold": {
            "global": {
                "branches": 60,
                "functions": 70,
                "lines": 70,
                "statements": 70
            }
        }
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    }
}
