{
  "name": "arsip-surat-digital-enterprise",
  "version": "2.1.0",
  "description": "Sistem Manajemen Arsip Surat Digital Enterprise",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "jest --config jest.config.js --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/ --ext .js",
    "lint:fix": "eslint src/ --ext .js --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\"",
    "migrate": "node src/database/migrations/001_create_all_tables.js up",
    "migrate:rollback": "node src/database/migrations/001_create_all_tables.js down",
    "seed": "node src/database/seeders/AdminSeeder.js",
    "db:reset": "npm run migrate:rollback && npm run migrate && npm run seed",
    "db:backup": "node tools/backup.js backup",
    "db:restore": "node tools/backup.js restore",
    "generate-env": "node scripts/generate-env.js",
    "decode-gas": "node scripts/decode-gcs.js decode",
    "encode-gas": "node scripts/decode-gcs.js encode",
    "verify-gas": "node scripts/decode-gcs.js verify",
    "health-check": "node scripts/health-check.js",
    "docker:dev": "docker-compose up -d",
    "docker:prod": "docker-compose -f docker-compose.yml -f docker-compose.production.yml up -d",
    "docker:down": "docker-compose down",
    "docker:build": "docker-compose build",
    "docker:logs": "docker-compose logs -f",
    "deploy:staging": "bash tools/deploy.sh staging",
    "deploy:production": "bash tools/deploy.sh production",
    "security:audit": "npm audit",
    "setup": "bash tools/setup.sh"
  },
  "keywords": ["arsip", "surat", "digital", "enterprise", "pwa", "dms"],
  "author": "Arsip Surat Digital Enterprise Team",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "better-sqlite3": "^9.4.3",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "multer": "^1.4.5-lts.1",
    "ejs": "^3.1.9",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "dotenv": "^16.3.1",
    "express-validator": "^7.0.1",
    "cookie-parser": "^1.4.6",
    "pdfkit": "^0.13.0",
    "sharp": "^0.33.2",
    "qrcode": "^1.5.3",
    "nodemailer": "^6.9.8",
    "uuid": "^9.0.0",
    "dayjs": "^1.11.10",
    "winston": "^3.11.0",
    "archiver": "^6.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.4",
    "supertest": "^6.3.3"
  }
}
