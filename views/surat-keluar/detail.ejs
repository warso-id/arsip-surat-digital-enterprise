<div class="row mb-4">
    <div class="col-12">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                <li class="breadcrumb-item"><a href="/surat-keluar">Surat Keluar</a></li>
                <li class="breadcrumb-item active">Detail Surat Keluar</li>
            </ol>
        </nav>
        <div class="d-flex justify-content-between align-items-center">
            <h4><i class="bi bi-eye me-2"></i>Detail Surat Keluar</h4>
            <div>
                <button class="btn btn-outline-secondary me-2" onclick="window.print()">
                    <i class="bi bi-printer"></i> Cetak
                </button>
                <button class="btn btn-outline-success me-2" onclick="downloadSurat()">
                    <i class="bi bi-download"></i> Download PDF
                </button>
                <a href="/surat-keluar/<%= id %>/edit" class="btn btn-warning me-2">
                    <i class="bi bi-pencil"></i> Edit
                </a>
                <button class="btn btn-danger" onclick="deleteSurat()">
                    <i class="bi bi-trash"></i> Hapus
                </button>
            </div>
        </div>
        <hr>
    </div>
</div>

<div class="row">
    <!-- Main Content -->
    <div class="col-lg-8">
        <div class="card shadow-sm mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Informasi Surat</h5>
                <span class="badge bg-info" id="suratStatus">Loading...</span>
            </div>
            <div class="card-body" id="suratDetail">
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-2">Memuat data surat...</p>
                </div>
            </div>
        </div>
        
        <!-- File Preview -->
        <div class="card shadow-sm mb-4" id="fileCard" style="display: none;">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-file-earmark"></i> File Surat</h5>
            </div>
            <div class="card-body text-center" id="filePreview">
                <div class="embed-responsive" style="min-height: 500px;">
                    <iframe id="fileFrame" style="width: 100%; height: 500px; border: none;"></iframe>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Sidebar -->
    <div class="col-lg-4">
        <!-- Status & Actions -->
        <div class="card shadow-sm mb-4">
            <div class="card-header"><h5 class="mb-0">Status & Aksi</h5></div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Ubah Status</label>
                    <select class="form-select" id="changeStatus" onchange="updateStatus(this.value)">
                        <option value="draft">Draft</option>
                        <option value="dikirim">Dikirim</option>
                        <option value="selesai">Selesai</option>
                        <option value="arsip">Arsip</option>
                    </select>
                </div>
                <div class="d-grid gap-2">
                    <button class="btn btn-primary" onclick="downloadSurat()">
                        <i class="bi bi-download"></i> Download Surat
                    </button>
                    <button class="btn btn-outline-secondary" onclick="window.print()">
                        <i class="bi bi-printer"></i> Cetak Surat
                    </button>
                </div>
            </div>
        </div>
        
        <!-- Informasi Tambahan -->
        <div class="card shadow-sm mb-4">
            <div class="card-header"><h5 class="mb-0">Informasi Tambahan</h5></div>
            <div class="card-body" id="additionalInfo">
                <div class="text-center py-3">Memuat...</div>
            </div>
        </div>
        
        <!-- QR Code -->
        <div class="card shadow-sm">
            <div class="card-header"><h5 class="mb-0">QR Code Surat</h5></div>
            <div class="card-body text-center">
                <div id="qrcode"></div>
                <small class="text-muted">Scan untuk verifikasi surat</small>
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Konfirmasi Hapus</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Apakah Anda yakin ingin menghapus surat keluar ini?</p>
                <p class="text-danger"><small>Tindakan ini tidak dapat dibatalkan.</small></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Hapus</button>
            </div>
        </div>
    </div>
</div>

<script>
    const suratId = '<%= id %>';
    let suratData = null;
    
    document.addEventListener('DOMContentLoaded', async function() {
        await loadSuratDetail();
    });
    
    async function loadSuratDetail() {
        try {
            showLoading();
            
            const response = await axios.get(`/api/surat-keluar/${suratId}`);
            suratData = response.data.data;
            
            renderSuratDetail(suratData);
            renderAdditionalInfo(suratData);
            
            // Update status dropdown
            document.getElementById('changeStatus').value = suratData.status;
            document.getElementById('suratStatus').textContent = suratData.status.toUpperCase();
            document.getElementById('suratStatus').className = `badge bg-${getStatusColor(suratData.status)}`;
            
            // Show file preview if PDF
            if (suratData.file_path && suratData.file_path.endsWith('.pdf')) {
                document.getElementById('fileCard').style.display = 'block';
                document.getElementById('fileFrame').src = `/${suratData.file_path}`;
            } else if (suratData.file_path) {
                document.getElementById('fileCard').style.display = 'block';
                document.getElementById('filePreview').innerHTML = `
                    <div class="py-5">
                        <i class="bi bi-file-earmark fs-1 text-muted"></i>
                        <p class="mt-2">${suratData.file_name || 'File Surat'}</p>
                        <a href="/${suratData.file_path}" target="_blank" class="btn btn-primary">
                            <i class="bi bi-download"></i> Download File
                        </a>
                    </div>
                `;
            }
            
            // Generate QR Code
            generateQRCode();
            
            hideLoading();
        } catch (error) {
            hideLoading();
            document.getElementById('suratDetail').innerHTML = `
                <div class="alert alert-danger">
                    <i class="bi bi-exclamation-triangle"></i> Gagal memuat data surat
                </div>
            `;
        }
    }
    
    function renderSuratDetail(surat) {
        document.getElementById('suratDetail').innerHTML = `
            <table class="table table-bordered">
                <tr>
                    <td class="fw-bold bg-light" width="200">Nomor Surat</td>
                    <td><strong>${surat.nomor_surat}</strong></td>
                </tr>
                <tr>
                    <td class="fw-bold bg-light">Tanggal Surat</td>
                    <td>${formatDate(surat.tanggal_surat)}</td>
                </tr>
                <tr>
                    <td class="fw-bold bg-light">Tujuan</td>
                    <td>${surat.tujuan}</td>
                </tr>
                <tr>
                    <td class="fw-bold bg-light">Instansi</td>
                    <td>${surat.instansi?.nama_instansi || '-'}</td>
                </tr>
                <tr>
                    <td class="fw-bold bg-light">Perihal</td>
                    <td>${surat.perihal}</td>
                </tr>
                <tr>
                    <td class="fw-bold bg-light">Kategori</td>
                    <td>${surat.kategori?.nama_kategori || '-'}</td>
                </tr>
                <tr>
                    <td class="fw-bold bg-light">Sifat</td>
                    <td><span class="badge bg-${getSifatColor(surat.sifat)}">${surat.sifat.toUpperCase()}</span></td>
                </tr>
                <tr>
                    <td class="fw-bold bg-light">Status</td>
                    <td><span class="badge bg-${getStatusColor(surat.status)}">${surat.status.toUpperCase()}</span></td>
                </tr>
                <tr>
                    <td class="fw-bold bg-light">Penandatangan</td>
                    <td>${surat.penandatangan || '-'}</td>
                </tr>
                ${surat.isi_ringkas ? `
                <tr>
                    <td class="fw-bold bg-light">Isi Ringkas</td>
                    <td style="white-space: pre-wrap;">${surat.isi_ringkas}</td>
                </tr>` : ''}
                ${surat.file_path && !surat.file_path.endsWith('.pdf') ? `
                <tr>
                    <td class="fw-bold bg-light">File</td>
                    <td>
                        <a href="/${surat.file_path}" target="_blank" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-download"></i> Download (${formatFileSize(surat.file_size)})
                        </a>
                    </td>
                </tr>` : ''}
            </table>
        `;
    }
    
    function renderAdditionalInfo(surat) {
        document.getElementById('additionalInfo').innerHTML = `
            <ul class="list-unstyled mb-0">
                <li class="mb-2">
                    <i class="bi bi-person text-primary"></i>
                    <small>Dibuat oleh: ${surat.creator?.nama_lengkap || '-'}</small>
                </li>
                <li class="mb-2">
                    <i class="bi bi-clock text-primary"></i>
                    <small>Dibuat: ${formatDateTime(surat.created_at)}</small>
                </li>
                ${surat.updated_by ? `
                <li class="mb-2">
                    <i class="bi bi-pencil text-primary"></i>
                    <small>Diupdate oleh: ${surat.updater?.nama_lengkap || '-'}</small>
                </li>
                <li class="mb-2">
                    <i class="bi bi-clock-history text-primary"></i>
                    <small>Diupdate: ${formatDateTime(surat.updated_at)}</small>
                </li>` : ''}
            </ul>
        `;
    }
    
    function generateQRCode() {
        const qrContainer = document.getElementById('qrcode');
        if (!qrContainer) return;
        
        // Generate QR code with surat info
        const qrData = JSON.stringify({
            id: suratData.id,
            nomor_surat: suratData.nomor_surat,
            tanggal: suratData.tanggal_surat,
            perihal: suratData.perihal
        });
        
        // Use QR code library if available
        if (typeof QRCode !== 'undefined') {
            new QRCode(qrContainer, {
                text: qrData,
                width: 150,
                height: 150
            });
        } else {
            // Fallback: show text
            qrContainer.innerHTML = `
                <div class="border p-3 d-inline-block">
                    <small class="text-muted">QR Code tidak tersedia</small><br>
                    <small>ID: ${suratData.id}</small>
                </div>
            `;
        }
    }
    
    async function updateStatus(status) {
        try {
            await axios.put(`/api/surat-keluar/${suratId}`, { status });
            alert('Status berhasil diupdate');
            await loadSuratDetail();
        } catch (error) {
            alert('Gagal mengupdate status');
            document.getElementById('changeStatus').value = suratData.status;
        }
    }
    
    async function downloadSurat() {
        try {
            const response = await axios.get(`/api/surat-keluar/${suratId}/export-pdf`, {
                responseType: 'blob'
            });
            
            const url = window.URL.createObjectURL(new Blob([response.data]));
            const link = document.createElement('a');
            link.href = url;
            link.setAttribute('download', `surat-keluar-${suratData.nomor_surat.replace(/[/\\]/g, '-')}.pdf`);
            document.body.appendChild(link);
            link.click();
            link.remove();
            window.URL.revokeObjectURL(url);
        } catch (error) {
            alert('Gagal mendownload surat');
        }
    }
    
    async function deleteSurat() {
        const modal = new bootstrap.Modal(document.getElementById('deleteModal'));
        
        document.getElementById('confirmDeleteBtn').onclick = async function() {
            try {
                await axios.delete(`/api/surat-keluar/${suratId}`);
                modal.hide();
                alert('Surat berhasil dihapus');
                window.location.href = '/surat-keluar';
            } catch (error) {
                modal.hide();
                alert('Gagal menghapus surat');
            }
        };
        
        modal.show();
    }
    
    function formatDate(date) {
        return new Date(date).toLocaleDateString('id-ID', {
            year: 'numeric', month: 'long', day: 'numeric'
        });
    }
    
    function formatDateTime(date) {
        return new Date(date).toLocaleString('id-ID', {
            year: 'numeric', month: 'long', day: 'numeric',
            hour: '2-digit', minute: '2-digit'
        });
    }
    
    function formatFileSize(bytes) {
        if (!bytes) return '0 B';
        const k = 1024;
        const sizes = ['B', 'KB', 'MB', 'GB'];
        const i = Math.floor(Math.log(bytes) / Math.log(k));
        return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
    }
    
    function getStatusColor(status) {
        const colors = {
            'draft': 'secondary',
            'dikirim': 'primary',
            'selesai': 'success',
            'arsip': 'dark'
        };
        return colors[status] || 'secondary';
    }
    
    function getSifatColor(sifat) {
        const colors = {
            'biasa': 'secondary',
            'segera': 'warning',
            'penting': 'danger',
            'rahasia': 'dark'
        };
        return colors[sifat] || 'secondary';
    }
    
    function showLoading() {
        const overlay = document.createElement('div');
        overlay.id = 'loadingOverlay';
        overlay.style.cssText = `
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.5); z-index: 9999;
            display: flex; align-items: center; justify-content: center;
        `;
        overlay.innerHTML = `
            <div class="text-center text-white">
                <div class="spinner-border mb-3" role="status"></div>
                <p>Memuat...</p>
            </div>
        `;
        document.body.appendChild(overlay);
    }
    
    function hideLoading() {
        const overlay = document.getElementById('loadingOverlay');
        if (overlay) overlay.remove();
    }
</script>

<!-- Print Styles -->
<style>
@media print {
    .navbar, .sidebar, .footer, .btn, .no-print, #deleteModal, #changeStatus {
        display: none !important;
    }
    #content {
        width: 100% !important;
        margin: 0 !important;
        padding: 0 !important;
    }
    .card {
        border: none !important;
        box-shadow: none !important;
    }
    .card-header {
        background: none !important;
    }
}
</style>
