<div class="row mb-4">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center">
            <h4><i class="bi bi-outbox me-2"></i>Surat Keluar</h4>
            <div>
                <button class="btn btn-success me-2" id="btnExportAll" onclick="exportAllPDF()">
                    <i class="bi bi-file-pdf"></i> Export Semua
                </button>
                <a href="/surat-keluar/create" class="btn btn-primary">
                    <i class="bi bi-plus-circle"></i> Tambah Surat
                </a>
            </div>
        </div>
        <hr>
    </div>
</div>

<!-- Statistics Cards -->
<div class="row g-3 mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="card border-left-primary shadow-sm h-100">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col">
                        <div class="text-xs fw-bold text-primary text-uppercase mb-1">Total Surat</div>
                        <div class="h5 mb-0 fw-bold" id="totalSurat">0</div>
                    </div>
                    <div class="col-auto">
                        <i class="bi bi-outbox fs-1 text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card border-left-warning shadow-sm h-100">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col">
                        <div class="text-xs fw-bold text-warning text-uppercase mb-1">Draft</div>
                        <div class="h5 mb-0 fw-bold" id="totalDraft">0</div>
                    </div>
                    <div class="col-auto">
                        <i class="bi bi-pencil fs-1 text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card border-left-success shadow-sm h-100">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col">
                        <div class="text-xs fw-bold text-success text-uppercase mb-1">Terkirim</div>
                        <div class="h5 mb-0 fw-bold" id="totalDikirim">0</div>
                    </div>
                    <div class="col-auto">
                        <i class="bi bi-send fs-1 text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card border-left-info shadow-sm h-100">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col">
                        <div class="text-xs fw-bold text-info text-uppercase mb-1">Bulan Ini</div>
                        <div class="h5 mb-0 fw-bold" id="totalBulanIni">0</div>
                    </div>
                    <div class="col-auto">
                        <i class="bi bi-calendar fs-1 text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Search and Filters -->
<div class="card shadow-sm mb-4">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-3">
                <label class="form-label">Pencarian</label>
                <input type="text" id="searchSurat" class="form-control" placeholder="Cari nomor, tujuan, perihal...">
            </div>
            <div class="col-md-2">
                <label class="form-label">Status</label>
                <select id="filterStatus" class="form-select filter-surat">
                    <option value="">Semua Status</option>
                    <option value="draft">Draft</option>
                    <option value="dikirim">Dikirim</option>
                    <option value="selesai">Selesai</option>
                    <option value="arsip">Arsip</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Sifat</label>
                <select id="filterSifat" class="form-select filter-surat">
                    <option value="">Semua Sifat</option>
                    <option value="biasa">Biasa</option>
                    <option value="segera">Segera</option>
                    <option value="penting">Penting</option>
                    <option value="rahasia">Rahasia</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Kategori</label>
                <select id="filterKategori" class="form-select filter-surat">
                    <option value="">Semua Kategori</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Periode</label>
                <div class="input-group">
                    <input type="date" id="filterTanggalMulai" class="form-control filter-surat">
                    <span class="input-group-text">s/d</span>
                    <input type="date" id="filterTanggalSelesai" class="form-control filter-surat">
                </div>
            </div>
        </div>
        <div class="row mt-3">
            <div class="col-12">
                <button id="btnFilter" class="btn btn-primary me-2">
                    <i class="bi bi-search"></i> Terapkan Filter
                </button>
                <button id="resetFilter" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-counterclockwise"></i> Reset
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Table -->
<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Daftar Surat Keluar</h5>
        <div class="dropdown">
            <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                <i class="bi bi-gear"></i> Aksi Massal
            </button>
            <ul class="dropdown-menu dropdown-menu-end">
                <li><a class="dropdown-item" href="#" onclick="batchDelete()">
                    <i class="bi bi-trash text-danger"></i> Hapus Terpilih
                </a></li>
                <li><a class="dropdown-item" href="#" onclick="batchExportPDF()">
                    <i class="bi bi-file-pdf"></i> Export Terpilih
                </a></li>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item" href="#" onclick="selectAll()">
                    <i class="bi bi-check-all"></i> Pilih Semua
                </a></li>
                <li><a class="dropdown-item" href="#" onclick="deselectAll()">
                    <i class="bi bi-x-circle"></i> Hapus Pilihan
                </a></li>
            </ul>
        </div>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle" id="suratKeluarTable">
                <thead class="table-light">
                    <tr>
                        <th width="40">
                            <input type="checkbox" id="selectAllCheckbox" class="form-check-input">
                        </th>
                        <th width="50">No</th>
                        <th>Nomor Surat</th>
                        <th>Tanggal</th>
                        <th>Tujuan</th>
                        <th>Perihal</th>
                        <th>Kategori</th>
                        <th>Sifat</th>
                        <th>Status</th>
                        <th width="120">Penandatangan</th>
                        <th width="150">Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="11" class="text-center py-5">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                            <p class="mt-2 mb-0">Memuat data surat keluar...</p>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
        
        <!-- Pagination -->
        <div class="d-flex justify-content-between align-items-center mt-3">
            <div class="text-muted" id="pageInfo">
                Menampilkan 0 dari 0 data
            </div>
            <div id="pagination"></div>
        </div>
    </div>
</div>

<!-- Detail Modal -->
<div class="modal fade" id="detailModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Detail Surat Keluar</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="detailContent">
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-2">Memuat detail...</p>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Tutup</button>
                <button type="button" class="btn btn-primary" id="btnEditFromDetail">
                    <i class="bi bi-pencil"></i> Edit
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    let currentPage = 1;
    let perPage = 20;
    let totalData = 0;
    let selectedItems = new Set();
    let currentDetailId = null;
    
    document.addEventListener('DOMContentLoaded', async function() {
        await loadKategoriFilter();
        await loadSuratKeluar();
        await loadStatistics();
        
        // Search with debounce
        let debounceTimer;
        document.getElementById('searchSurat')?.addEventListener('input', function() {
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(() => {
                currentPage = 1;
                loadSuratKeluar();
            }, 500);
        });
        
        // Filter changes
        document.querySelectorAll('.filter-surat').forEach(filter => {
            filter.addEventListener('change', () => {
                currentPage = 1;
                loadSuratKeluar();
            });
        });
        
        // Filter button
        document.getElementById('btnFilter')?.addEventListener('click', () => {
            currentPage = 1;
            loadSuratKeluar();
        });
        
        // Reset filter
        document.getElementById('resetFilter')?.addEventListener('click', resetFilters);
        
        // Select all checkbox
        document.getElementById('selectAllCheckbox')?.addEventListener('change', function() {
            const checkboxes = document.querySelectorAll('.surat-checkbox');
            checkboxes.forEach(cb => {
                cb.checked = this.checked;
                if (this.checked) {
                    selectedItems.add(cb.value);
                } else {
                    selectedItems.delete(cb.value);
                }
            });
            updateSelectedCount();
        });
    });
    
    async function loadKategoriFilter() {
        try {
            const response = await axios.get('/api/kategori?perPage=100');
            const data = response.data.data.data;
            const select = document.getElementById('filterKategori');
            data.forEach(item => {
                select.innerHTML += `<option value="${item.id}">${item.nama_kategori}</option>`;
            });
        } catch (error) {
            console.error('Error loading kategori:', error);
        }
    }
    
    async function loadStatistics() {
        try {
            const params = getFilterParams();
            const response = await axios.get('/api/laporan/statistics', { params });
            const stats = response.data.data.surat?.surat_keluar || {};
            
            document.getElementById('totalSurat').textContent = stats.total || 0;
            document.getElementById('totalDraft').textContent = stats.per_status?.draft || 0;
            document.getElementById('totalDikirim').textContent = stats.per_status?.dikirim || 0;
            
            // Hitung bulan ini
            const now = new Date();
            const bulanIni = stats.per_bulan?.find(b => b.bulan === now.getMonth() + 1);
            document.getElementById('totalBulanIni').textContent = bulanIni?.jumlah || 0;
        } catch (error) {
            console.error('Error loading statistics:', error);
        }
    }
    
    async function loadSuratKeluar() {
        try {
            showLoading('#suratKeluarTable');
            
            const params = {
                page: currentPage,
                perPage: perPage,
                ...getFilterParams()
            };
            
            const response = await axios.get('/api/surat-keluar', { params });
            const data = response.data.data;
            
            renderTable(data.data);
            renderPagination(data.pagination);
            document.getElementById('pageInfo').textContent = 
                `Menampilkan ${data.data.length} dari ${data.pagination.total} data`;
            
            totalData = data.pagination.total;
            hideLoading('#suratKeluarTable');
        } catch (error) {
            hideLoading('#suratKeluarTable');
            console.error('Error loading surat keluar:', error);
            document.querySelector('#suratKeluarTable tbody').innerHTML = `
                <tr>
                    <td colspan="11" class="text-center py-5">
                        <i class="bi bi-exclamation-triangle text-danger fs-1"></i>
                        <p class="text-danger mt-2">Gagal memuat data. Silakan coba lagi.</p>
                        <button class="btn btn-sm btn-outline-primary" onclick="loadSuratKeluar()">
                            <i class="bi bi-arrow-clockwise"></i> Muat Ulang
                        </button>
                    </td>
                </tr>
            `;
        }
    }
    
    function getFilterParams() {
        return {
            search: document.getElementById('searchSurat')?.value || '',
            status: document.getElementById('filterStatus')?.value || '',
            sifat: document.getElementById('filterSifat')?.value || '',
            kategori_id: document.getElementById('filterKategori')?.value || '',
            tanggal_mulai: document.getElementById('filterTanggalMulai')?.value || '',
            tanggal_selesai: document.getElementById('filterTanggalSelesai')?.value || ''
        };
    }
    
    function resetFilters() {
        document.getElementById('searchSurat').value = '';
        document.getElementById('filterStatus').value = '';
        document.getElementById('filterSifat').value = '';
        document.getElementById('filterKategori').value = '';
        document.getElementById('filterTanggalMulai').value = '';
        document.getElementById('filterTanggalSelesai').value = '';
        currentPage = 1;
        loadSuratKeluar();
    }
    
    function renderTable(data) {
        const tbody = document.querySelector('#suratKeluarTable tbody');
        
        if (!data || data.length === 0) {
            tbody.innerHTML = `
                <tr>
                    <td colspan="11" class="text-center py-5">
                        <i class="bi bi-inbox fs-1 text-muted"></i>
                        <p class="text-muted mt-2 mb-0">Tidak ada data surat keluar</p>
                        <a href="/surat-keluar/create" class="btn btn-sm btn-primary mt-2">
                            <i class="bi bi-plus-circle"></i> Tambah Surat Keluar
                        </a>
                    </td>
                </tr>
            `;
            return;
        }
        
        tbody.innerHTML = data.map((surat, index) => `
            <tr class="${surat.status === 'draft' ? 'table-warning' : ''}">
                <td>
                    <input type="checkbox" class="form-check-input surat-checkbox" 
                           value="${surat.id}" 
                           ${selectedItems.has(surat.id.toString()) ? 'checked' : ''}
                           onchange="toggleSelect('${surat.id}', this.checked)">
                </td>
                <td>${(currentPage - 1) * perPage + index + 1}</td>
                <td>
                    <span class="fw-bold">${surat.nomor_surat}</span>
                    ${surat.instansi ? `<br><small class="text-muted">${surat.instansi.nama_instansi}</small>` : ''}
                </td>
                <td>${formatDate(surat.tanggal_surat)}</td>
                <td>
                    <span title="${surat.tujuan}">${truncate(surat.tujuan, 25)}</span>
                </td>
                <td>
                    <span title="${surat.perihal}">${truncate(surat.perihal, 30)}</span>
                </td>
                <td>
                    <span class="badge bg-secondary">${surat.kategori?.nama_kategori || 'Umum'}</span>
                </td>
                <td>
                    <span class="badge bg-${getSifatColor(surat.sifat)}">${surat.sifat.toUpperCase()}</span>
                </td>
                <td>
                    <span class="badge bg-${getStatusColor(surat.status)}">${surat.status.toUpperCase()}</span>
                </td>
                <td>${surat.penandatangan || '-'}</td>
                <td>
                    <div class="btn-group btn-group-sm">
                        <button class="btn btn-info" onclick="viewDetail(${surat.id})" title="Detail">
                            <i class="bi bi-eye"></i>
                        </button>
                        <a href="/surat-keluar/${surat.id}/edit" class="btn btn-warning" title="Edit">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <button class="btn btn-success" onclick="downloadSurat(${surat.id})" title="Download">
                            <i class="bi bi-download"></i>
                        </button>
                        <button class="btn btn-danger" onclick="deleteSurat(${surat.id})" title="Hapus">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                </td>
            </tr>
        `).join('');
    }
    
    function renderPagination(pagination) {
        const container = document.getElementById('pagination');
        if (!container || pagination.totalPages <= 1) {
            container.innerHTML = '';
            return;
        }
        
        let html = '<nav><ul class="pagination pagination-sm mb-0">';
        
        // Previous
        html += `
            <li class="page-item ${pagination.currentPage === 1 ? 'disabled' : ''}">
                <a class="page-link" href="#" onclick="goToPage(${pagination.currentPage - 1})">
                    <i class="bi bi-chevron-left"></i>
                </a>
            </li>
        `;
        
        // Page numbers
        let startPage = Math.max(1, pagination.currentPage - 2);
        let endPage = Math.min(pagination.totalPages, pagination.currentPage + 2);
        
        if (startPage > 1) {
            html += `<li class="page-item"><a class="page-link" href="#" onclick="goToPage(1)">1</a></li>`;
            if (startPage > 2) {
                html += `<li class="page-item disabled"><span class="page-link">...</span></li>`;
            }
        }
        
        for (let i = startPage; i <= endPage; i++) {
            html += `
                <li class="page-item ${i === pagination.currentPage ? 'active' : ''}">
                    <a class="page-link" href="#" onclick="goToPage(${i})">${i}</a>
                </li>
            `;
        }
        
        if (endPage < pagination.totalPages) {
            if (endPage < pagination.totalPages - 1) {
                html += `<li class="page-item disabled"><span class="page-link">...</span></li>`;
            }
            html += `<li class="page-item"><a class="page-link" href="#" onclick="goToPage(${pagination.totalPages})">${pagination.totalPages}</a></li>`;
        }
        
        // Next
        html += `
            <li class="page-item ${pagination.currentPage === pagination.totalPages ? 'disabled' : ''}">
                <a class="page-link" href="#" onclick="goToPage(${pagination.currentPage + 1})">
                    <i class="bi bi-chevron-right"></i>
                </a>
            </li>
        `;
        
        html += '</ul></nav>';
        container.innerHTML = html;
    }
    
    function goToPage(page) {
        if (page < 1 || page > Math.ceil(totalData / perPage)) return;
        currentPage = page;
        loadSuratKeluar();
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }
    
    function toggleSelect(id, checked) {
        if (checked) {
            selectedItems.add(id.toString());
        } else {
            selectedItems.delete(id.toString());
        }
        updateSelectedCount();
    }
    
    function selectAll() {
        document.querySelectorAll('.surat-checkbox').forEach(cb => {
            cb.checked = true;
            selectedItems.add(cb.value);
        });
        document.getElementById('selectAllCheckbox').checked = true;
        updateSelectedCount();
    }
    
    function deselectAll() {
        document.querySelectorAll('.surat-checkbox').forEach(cb => {
            cb.checked = false;
        });
        document.getElementById('selectAllCheckbox').checked = false;
        selectedItems.clear();
        updateSelectedCount();
    }
    
    function updateSelectedCount() {
        const count = selectedItems.size;
        const badge = document.getElementById('selectedCount');
        if (badge) {
            badge.textContent = count;
            badge.style.display = count > 0 ? 'inline' : 'none';
        }
    }
    
    async function viewDetail(id) {
        currentDetailId = id;
        
        try {
            showLoading('#detailContent');
            
            const response = await axios.get(`/api/surat-keluar/${id}`);
            const surat = response.data.data;
            
            document.getElementById('detailContent').innerHTML = `
                <table class="table table-bordered">
                    <tr><td class="fw-bold" width="180">Nomor Surat</td><td>${surat.nomor_surat}</td></tr>
                    <tr><td class="fw-bold">Tanggal Surat</td><td>${formatDate(surat.tanggal_surat)}</td></tr>
                    <tr><td class="fw-bold">Tujuan</td><td>${surat.tujuan}</td></tr>
                    <tr><td class="fw-bold">Instansi</td><td>${surat.instansi?.nama_instansi || '-'}</td></tr>
                    <tr><td class="fw-bold">Perihal</td><td>${surat.perihal}</td></tr>
                    <tr><td class="fw-bold">Kategori</td><td>${surat.kategori?.nama_kategori || '-'}</td></tr>
                    <tr><td class="fw-bold">Sifat</td><td><span class="badge bg-${getSifatColor(surat.sifat)}">${surat.sifat.toUpperCase()}</span></td></tr>
                    <tr><td class="fw-bold">Status</td><td><span class="badge bg-${getStatusColor(surat.status)}">${surat.status.toUpperCase()}</span></td></tr>
                    <tr><td class="fw-bold">Penandatangan</td><td>${surat.penandatangan || '-'}</td></tr>
                    ${surat.isi_ringkas ? `<tr><td class="fw-bold">Isi Ringkas</td><td>${surat.isi_ringkas}</td></tr>` : ''}
                    <tr><td class="fw-bold">Dibuat Oleh</td><td>${surat.creator?.nama_lengkap || '-'}</td></tr>
                    <tr><td class="fw-bold">Dibuat Pada</td><td>${formatDateTime(surat.created_at)}</td></tr>
                    ${surat.file_path ? `
                    <tr>
                        <td class="fw-bold">File</td>
                        <td>
                            <a href="/${surat.file_path}" target="_blank" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-download"></i> Download (${formatFileSize(surat.file_size)})
                            </a>
                        </td>
                    </tr>` : ''}
                </table>
            `;
            
            document.getElementById('btnEditFromDetail').onclick = () => {
                window.location.href = `/surat-keluar/${id}/edit`;
            };
            
            hideLoading('#detailContent');
            
            const modal = new bootstrap.Modal(document.getElementById('detailModal'));
            modal.show();
        } catch (error) {
            hideLoading('#detailContent');
            document.getElementById('detailContent').innerHTML = `
                <div class="alert alert-danger">Gagal memuat detail surat</div>
            `;
        }
    }
    
    async function deleteSurat(id) {
        const confirmed = await showConfirm('Apakah Anda yakin ingin menghapus surat keluar ini?');
        if (!confirmed) return;
        
        try {
            showLoading();
            await axios.delete(`/api/surat-keluar/${id}`);
            hideLoading();
            showAlert('Surat berhasil dihapus', 'success');
            selectedItems.delete(id.toString());
            await loadSuratKeluar();
            await loadStatistics();
        } catch (error) {
            hideLoading();
            showAlert(error.response?.data?.message || 'Gagal menghapus surat', 'danger');
        }
    }
    
    async function batchDelete() {
        if (selectedItems.size === 0) {
            showAlert('Pilih surat yang akan dihapus', 'warning');
            return;
        }
        
        const confirmed = await showConfirm(`Hapus ${selectedItems.size} surat keluar terpilih?`);
        if (!confirmed) return;
        
        try {
            showLoading();
            
            const ids = Array.from(selectedItems);
            for (const id of ids) {
                try {
                    await axios.delete(`/api/surat-keluar/${id}`);
                } catch (error) {
                    console.error(`Error deleting surat ${id}:`, error);
                }
            }
            
            hideLoading();
            selectedItems.clear();
            showAlert('Surat terpilih berhasil dihapus', 'success');
            await loadSuratKeluar();
            await loadStatistics();
        } catch (error) {
            hideLoading();
            showAlert('Gagal menghapus surat', 'danger');
        }
    }
    
    async function downloadSurat(id) {
        try {
            const response = await axios.get(`/api/surat-keluar/${id}/export-pdf`, {
                responseType: 'blob'
            });
            
            const url = window.URL.createObjectURL(new Blob([response.data]));
            const link = document.createElement('a');
            link.href = url;
            link.setAttribute('download', `surat-keluar-${id}.pdf`);
            document.body.appendChild(link);
            link.click();
            link.remove();
            window.URL.revokeObjectURL(url);
        } catch (error) {
            showAlert('Gagal mendownload surat', 'danger');
        }
    }
    
    async function batchExportPDF() {
        if (selectedItems.size === 0) {
            showAlert('Pilih surat yang akan diexport', 'warning');
            return;
        }
        
        const ids = Array.from(selectedItems);
        for (const id of ids) {
            await downloadSurat(id);
            await new Promise(resolve => setTimeout(resolve, 500)); // Delay between downloads
        }
    }
    
    async function exportAllPDF() {
        try {
            showLoading();
            
            const params = getFilterParams();
            const response = await axios.get('/api/laporan/export-pdf', {
                params: { ...params, tipe: 'keluar' },
                responseType: 'blob'
            });
            
            const url = window.URL.createObjectURL(new Blob([response.data]));
            const link = document.createElement('a');
            link.href = url;
            link.setAttribute('download', `laporan-surat-keluar-${Date.now()}.pdf`);
            document.body.appendChild(link);
            link.click();
            link.remove();
            
            hideLoading();
        } catch (error) {
            hideLoading();
            showAlert('Gagal mengexport PDF', 'danger');
        }
    }
    
    // Helper functions
    function formatDate(date) {
        return new Date(date).toLocaleDateString('id-ID', {
            year: 'numeric', month: 'long', day: 'numeric'
        });
    }
    
    function formatDateTime(date) {
        return new Date(date).toLocaleString('id-ID', {
            year: 'numeric', month: 'long', day: 'numeric',
            hour: '2-digit', minute: '2-digit'
        });
    }
    
    function formatFileSize(bytes) {
        if (!bytes) return '0 B';
        const k = 1024;
        const sizes = ['B', 'KB', 'MB', 'GB'];
        const i = Math.floor(Math.log(bytes) / Math.log(k));
        return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
    }
    
    function truncate(text, length) {
        if (!text) return '';
        return text.length > length ? text.substring(0, length) + '...' : text;
    }
    
    function getStatusColor(status) {
        const colors = {
            'draft': 'secondary',
            'dikirim': 'primary',
            'selesai': 'success',
            'arsip': 'dark'
        };
        return colors[status] || 'secondary';
    }
    
    function getSifatColor(sifat) {
        const colors = {
            'biasa': 'secondary',
            'segera': 'warning',
            'penting': 'danger',
            'rahasia': 'dark'
        };
        return colors[sifat] || 'secondary';
    }
    
    function showAlert(message, type = 'success') {
        // Create alert element
        const alertHtml = `
            <div class="alert alert-${type} alert-dismissible fade show position-fixed top-0 end-0 m-3" 
                 style="z-index: 9999; min-width: 300px;" role="alert">
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        `;
        
        const container = document.createElement('div');
        container.innerHTML = alertHtml;
        document.body.appendChild(container.firstElementChild);
        
        // Auto remove after 5 seconds
        setTimeout(() => {
            const alert = document.querySelector('.alert');
            if (alert) alert.remove();
        }, 5000);
    }
    
    function showConfirm(message) {
        return new Promise((resolve) => {
            const result = confirm(message);
            resolve(result);
        });
    }
    
    function showLoading(target) {
        const element = typeof target === 'string' ? document.querySelector(target) : target;
        if (element) {
            element.style.opacity = '0.6';
            element.style.pointerEvents = 'none';
        }
    }
    
    function hideLoading(target) {
        const element = typeof target === 'string' ? document.querySelector(target) : target;
        if (element) {
            element.style.opacity = '1';
            element.style.pointerEvents = 'auto';
        }
    }
</script>
