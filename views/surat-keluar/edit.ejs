<div class="row mb-4">
    <div class="col-12">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                <li class="breadcrumb-item"><a href="/surat-keluar">Surat Keluar</a></li>
                <li class="breadcrumb-item active">Edit Surat</li>
            </ol>
        </nav>
        <h4><i class="bi bi-pencil-square me-2"></i>Edit Surat Keluar</h4>
        <hr>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-body">
                <form id="suratKeluarForm" enctype="multipart/form-data">
                    <input type="hidden" name="id" id="suratId">
                    
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="nomor_surat" class="form-label">Nomor Surat <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="nomor_surat" name="nomor_surat" required>
                        </div>
                        
                        <div class="col-md-6">
                            <label for="tanggal_surat" class="form-label">Tanggal Surat <span class="text-danger">*</span></label>
                            <input type="date" class="form-control" id="tanggal_surat" name="tanggal_surat" required>
                        </div>
                        
                        <div class="col-md-6">
                            <label for="tujuan" class="form-label">Tujuan <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="tujuan" name="tujuan" required>
                        </div>
                        
                        <div class="col-md-6">
                            <label for="instansi_id" class="form-label">Instansi Tujuan</label>
                            <select class="form-select" id="instansi_id" name="instansi_id">
                                <option value="">Pilih Instansi</option>
                            </select>
                        </div>
                        
                        <div class="col-md-6">
                            <label for="kategori_id" class="form-label">Kategori</label>
                            <select class="form-select" id="kategori_id" name="kategori_id">
                                <option value="">Pilih Kategori</option>
                            </select>
                        </div>
                        
                        <div class="col-md-3">
                            <label for="sifat" class="form-label">Sifat <span class="text-danger">*</span></label>
                            <select class="form-select" id="sifat" name="sifat" required>
                                <option value="biasa">Biasa</option>
                                <option value="segera">Segera</option>
                                <option value="penting">Penting</option>
                                <option value="rahasia">Rahasia</option>
                            </select>
                        </div>
                        
                        <div class="col-md-3">
                            <label for="status" class="form-label">Status</label>
                            <select class="form-select" id="status" name="status">
                                <option value="draft">Draft</option>
                                <option value="dikirim">Dikirim</option>
                                <option value="selesai">Selesai</option>
                                <option value="arsip">Arsip</option>
                            </select>
                        </div>
                        
                        <div class="col-md-6">
                            <label for="penandatangan" class="form-label">Penandatangan</label>
                            <input type="text" class="form-control" id="penandatangan" name="penandatangan">
                        </div>
                        
                        <div class="col-12">
                            <label for="perihal" class="form-label">Perihal <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="perihal" name="perihal" required>
                        </div>
                        
                        <div class="col-12">
                            <label for="isi_ringkas" class="form-label">Isi Ringkas</label>
                            <textarea class="form-control" id="isi_ringkas" name="isi_ringkas" rows="4"></textarea>
                        </div>
                        
                        <div class="col-12">
                            <label for="fileSurat" class="form-label">File Surat (Biarkan kosong jika tidak ingin mengubah)</label>
                            <input type="file" class="form-control" id="fileSurat" name="file" 
                                   accept=".pdf,.doc,.docx,.jpg,.jpeg,.png">
                            <div id="filePreview"></div>
                            <div id="currentFile" class="mt-2"></div>
                        </div>
                    </div>
                    
                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save"></i> Update
                        </button>
                        <a href="/surat-keluar" class="btn btn-secondary ms-2">
                            <i class="bi bi-arrow-left"></i> Kembali
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    const suratId = '<%= id %>';
    
    document.addEventListener('DOMContentLoaded', async function() {
        await loadSuratData();
        await loadInstansi();
        await loadKategori();
        
        document.getElementById('suratKeluarForm')?.addEventListener('submit', async function(e) {
            e.preventDefault();
            await updateSurat();
        });
    });
    
    async function loadSuratData() {
        try {
            const response = await axios.get(`/api/surat-keluar/${suratId}`);
            const surat = response.data.data;
            
            document.getElementById('suratId').value = surat.id;
            document.getElementById('nomor_surat').value = surat.nomor_surat;
            document.getElementById('tanggal_surat').value = surat.tanggal_surat;
            document.getElementById('tujuan').value = surat.tujuan;
            document.getElementById('perihal').value = surat.perihal;
            document.getElementById('isi_ringkas').value = surat.isi_ringkas || '';
            document.getElementById('sifat').value = surat.sifat;
            document.getElementById('status').value = surat.status;
            document.getElementById('penandatangan').value = surat.penandatangan || '';
            
            if (surat.instansi_id) {
                document.getElementById('instansi_id').value = surat.instansi_id;
            }
            if (surat.kategori_id) {
                document.getElementById('kategori_id').value = surat.kategori_id;
            }
            
            if (surat.file_path) {
                document.getElementById('currentFile').innerHTML = `
                    <div class="alert alert-info">
                        <i class="bi bi-file-earmark"></i>
                        File saat ini: ${surat.file_name || 'File'}
                        <a href="/${surat.file_path}" target="_blank" class="ms-2">Lihat</a>
                    </div>
                `;
            }
        } catch (error) {
            alert('Gagal memuat data surat');
            window.location.href = '/surat-keluar';
        }
    }
    
    async function loadInstansi() {
        try {
            const response = await axios.get('/api/instansi');
            const data = response.data.data.data;
            const select = document.getElementById('instansi_id');
            data.forEach(item => {
                select.innerHTML += `<option value="${item.id}">${item.nama_instansi}</option>`;
            });
        } catch (error) {
            console.error('Error loading instansi:', error);
        }
    }
    
    async function loadKategori() {
        try {
            const response = await axios.get('/api/kategori');
            const data = response.data.data.data;
            const select = document.getElementById('kategori_id');
            data.forEach(item => {
                select.innerHTML += `<option value="${item.id}">${item.nama_kategori}</option>`;
            });
        } catch (error) {
            console.error('Error loading kategori:', error);
        }
    }
    
    async function updateSurat() {
        const form = document.getElementById('suratKeluarForm');
        const formData = new FormData(form);
        const data = Object.fromEntries(formData);
        delete data.id;
        
        try {
            showLoading();
            await axios.put(`/api/surat-keluar/${suratId}`, data);
            hideLoading();
            alert('Surat berhasil diupdate');
            window.location.href = '/surat-keluar';
        } catch (error) {
            hideLoading();
            alert(error.response?.data?.message || 'Gagal mengupdate surat');
        }
    }
</script>
