<div class="row mb-4">
    <div class="col-12">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                <li class="breadcrumb-item"><a href="/surat-keluar">Surat Keluar</a></li>
                <li class="breadcrumb-item active">Edit Surat Keluar</li>
            </ol>
        </nav>
        <div class="d-flex justify-content-between align-items-center">
            <h4><i class="bi bi-pencil-square me-2"></i>Edit Surat Keluar</h4>
            <div>
                <span class="badge bg-info me-2" id="suratStatus">Loading...</span>
                <a href="/surat-keluar/<%= id %>" class="btn btn-outline-info me-2">
                    <i class="bi bi-eye"></i> Lihat Detail
                </a>
                <button type="button" class="btn btn-outline-secondary" onclick="history.back()">
                    <i class="bi bi-arrow-left"></i> Kembali
                </button>
            </div>
        </div>
        <hr>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-header">
                <ul class="nav nav-tabs card-header-tabs" id="formTabs">
                    <li class="nav-item">
                        <a class="nav-link active" data-bs-toggle="tab" href="#tabUmum">
                            <i class="bi bi-info-circle"></i> Informasi Umum
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-bs-toggle="tab" href="#tabIsi">
                            <i class="bi bi-file-text"></i> Isi Surat
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-bs-toggle="tab" href="#tabLampiran">
                            <i class="bi bi-paperclip"></i> Lampiran
                        </a>
                    </li>
                </ul>
            </div>
            <div class="card-body">
                <form id="suratKeluarForm" enctype="multipart/form-data" novalidate>
                    <input type="hidden" id="suratId" value="<%= id %>">
                    
                    <div class="tab-content">
                        <!-- Tab Informasi Umum -->
                        <div class="tab-pane fade show active" id="tabUmum">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label for="nomor_surat" class="form-label">
                                        Nomor Surat <span class="text-danger">*</span>
                                    </label>
                                    <input type="text" class="form-control" id="nomor_surat" 
                                           name="nomor_surat" required>
                                </div>
                                
                                <div class="col-md-6">
                                    <label for="tanggal_surat" class="form-label">
                                        Tanggal Surat <span class="text-danger">*</span>
                                    </label>
                                    <input type="date" class="form-control" id="tanggal_surat" 
                                           name="tanggal_surat" required>
                                </div>
                                
                                <div class="col-md-6">
                                    <label for="tujuan" class="form-label">
                                        Tujuan <span class="text-danger">*</span>
                                    </label>
                                    <input type="text" class="form-control" id="tujuan" 
                                           name="tujuan" required>
                                </div>
                                
                                <div class="col-md-6">
                                    <label for="instansi_id" class="form-label">Instansi Tujuan</label>
                                    <select class="form-select" id="instansi_id" name="instansi_id">
                                        <option value="">Pilih Instansi</option>
                                    </select>
                                </div>
                                
                                <div class="col-md-6">
                                    <label for="kategori_id" class="form-label">Kategori</label>
                                    <select class="form-select" id="kategori_id" name="kategori_id">
                                        <option value="">Pilih Kategori</option>
                                    </select>
                                </div>
                                
                                <div class="col-md-3">
                                    <label for="sifat" class="form-label">
                                        Sifat <span class="text-danger">*</span>
                                    </label>
                                    <select class="form-select" id="sifat" name="sifat" required>
                                        <option value="biasa">Biasa</option>
                                        <option value="segera">Segera</option>
                                        <option value="penting">Penting</option>
                                        <option value="rahasia">Rahasia</option>
                                    </select>
                                </div>
                                
                                <div class="col-md-3">
                                    <label for="status" class="form-label">Status</label>
                                    <select class="form-select" id="status" name="status">
                                        <option value="draft">Draft</option>
                                        <option value="dikirim">Dikirim</option>
                                        <option value="selesai">Selesai</option>
                                        <option value="arsip">Arsip</option>
                                    </select>
                                </div>
                                
                                <div class="col-md-6">
                                    <label for="penandatangan" class="form-label">Penandatangan</label>
                                    <input type="text" class="form-control" id="penandatangan" 
                                           name="penandatangan">
                                </div>
                            </div>
                        </div>
                        
                        <!-- Tab Isi Surat -->
                        <div class="tab-pane fade" id="tabIsi">
                            <div class="mb-3">
                                <label for="perihal" class="form-label">
                                    Perihal <span class="text-danger">*</span>
                                </label>
                                <input type="text" class="form-control" id="perihal" 
                                       name="perihal" required>
                            </div>
                            
                            <div class="mb-3">
                                <label for="isi_ringkas" class="form-label">Isi Ringkas</label>
                                <textarea class="form-control" id="isi_ringkas" name="isi_ringkas" 
                                          rows="8"></textarea>
                            </div>
                        </div>
                        
                        <!-- Tab Lampiran -->
                        <div class="tab-pane fade" id="tabLampiran">
                            <div class="mb-4">
                                <label class="form-label">File Surat</label>
                                <div id="currentFile" class="mb-3"></div>
                                <input type="file" class="form-control" id="fileSurat" name="file" 
                                       accept=".pdf,.doc,.docx,.jpg,.jpeg,.png"
                                       onchange="handleFileSelect(this)">
                                <div class="form-text">Biarkan kosong jika tidak ingin mengubah file</div>
                                <div id="filePreview" class="mt-3"></div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="d-flex justify-content-end mt-4">
                        <a href="/surat-keluar" class="btn btn-secondary me-2">Batal</a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save"></i> Update Surat
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    
    <div class="col-lg-4">
        <!-- History -->
        <div class="card shadow-sm mb-4">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-clock-history"></i> Riwayat Perubahan</h5>
            </div>
            <div class="card-body" id="changeHistory">
                <div class="text-center py-3">
                    <small class="text-muted">Memuat riwayat...</small>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const suratId = '<%= id %>';
    
    document.addEventListener('DOMContentLoaded', async function() {
        await loadSuratData();
        await loadInstansi();
        await loadKategori();
        
        document.getElementById('suratKeluarForm')?.addEventListener('submit', async function(e) {
            e.preventDefault();
            await updateSurat();
        });
    });
    
    async function loadSuratData() {
        try {
            showLoading();
            
            const response = await axios.get(`/api/surat-keluar/${suratId}`);
            const surat = response.data.data;
            
            // Fill form fields
            document.getElementById('nomor_surat').value = surat.nomor_surat || '';
            document.getElementById('tanggal_surat').value = surat.tanggal_surat || '';
            document.getElementById('tujuan').value = surat.tujuan || '';
            document.getElementById('perihal').value = surat.perihal || '';
            document.getElementById('isi_ringkas').value = surat.isi_ringkas || '';
            document.getElementById('sifat').value = surat.sifat || 'biasa';
            document.getElementById('status').value = surat.status || 'draft';
            document.getElementById('penandatangan').value = surat.penandatangan || '';
            
            if (surat.instansi_id) {
                document.getElementById('instansi_id').value = surat.instansi_id;
            }
            if (surat.kategori_id) {
                document.getElementById('kategori_id').value = surat.kategori_id;
            }
            
            // Show current file
            if (surat.file_path) {
                document.getElementById('currentFile').innerHTML = `
                    <div class="alert alert-info d-flex align-items-center justify-content-between">
                        <div>
                            <i class="bi bi-file-earmark me-2"></i>
                            <strong>${surat.file_name || 'File Surat'}</strong>
                            <small class="text-muted ms-2">(${formatFileSize(surat.file_size)})</small>
                        </div>
                        <div>
                            <a href="/${surat.file_path}" target="_blank" class="btn btn-sm btn-outline-primary me-1">
                                <i class="bi bi-eye"></i> Lihat
                            </a>
                            <button type="button" class="btn btn-sm btn-outline-danger" onclick="deleteFile()">
                                <i class="bi bi-trash"></i> Hapus
                            </button>
                        </div>
                    </div>
                `;
            }
            
            // Update status badge
            document.getElementById('suratStatus').textContent = surat.status.toUpperCase();
            document.getElementById('suratStatus').className = `badge bg-${getStatusColor(surat.status)}`;
            
            hideLoading();
        } catch (error) {
            hideLoading();
            alert('Gagal memuat data surat');
            window.location.href = '/surat-keluar';
        }
    }
    
    async function loadInstansi() {
        try {
            const response = await axios.get('/api/instansi?perPage=100');
            const data = response.data.data.data;
            const select = document.getElementById('instansi_id');
            data.forEach(item => {
                select.innerHTML += `<option value="${item.id}">${item.nama_instansi}</option>`;
            });
        } catch (error) {
            console.error('Error loading instansi:', error);
        }
    }
    
    async function loadKategori() {
        try {
            const response = await axios.get('/api/kategori?perPage=100');
            const data = response.data.data.data;
            const select = document.getElementById('kategori_id');
            data.forEach(item => {
                select.innerHTML += `<option value="${item.id}">${item.nama_kategori}</option>`;
            });
        } catch (error) {
            console.error('Error loading kategori:', error);
        }
    }
    
    function handleFileSelect(input) {
        const file = input.files[0];
        const preview = document.getElementById('filePreview');
        
        if (file) {
            preview.innerHTML = `
                <div class="alert alert-warning">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    File akan diganti dengan: <strong>${file.name}</strong> (${formatFileSize(file.size)})
                </div>
            `;
        }
    }
    
    async function deleteFile() {
        const confirmed = await showConfirm('Hapus file surat ini?');
        if (!confirmed) return;
        
        try {
            // You might want to add an API endpoint for file deletion
            document.getElementById('currentFile').innerHTML = '';
            document.getElementById('fileSurat').value = '';
            alert('File akan dihapus saat surat diupdate');
        } catch (error) {
            alert('Gagal menghapus file');
        }
    }
    
    async function updateSurat() {
        const form = document.getElementById('suratKeluarForm');
        
        if (!form.checkValidity()) {
            form.classList.add('was-validated');
            return;
        }
        
        const formData = new FormData(form);
        
        try {
            showLoading();
            
            await axios.put(`/api/surat-keluar/${suratId}`, formData, {
                headers: { 'Content-Type': 'multipart/form-data' }
            });
            
            hideLoading();
            alert('Surat berhasil diupdate');
            window.location.href = '/surat-keluar';
        } catch (error) {
            hideLoading();
            const message = error.response?.data?.message || 'Gagal mengupdate surat';
            alert(message);
        }
    }
    
    function formatFileSize(bytes) {
        if (!bytes) return '0 B';
        const k = 1024;
        const sizes = ['B', 'KB', 'MB', 'GB'];
        const i = Math.floor(Math.log(bytes) / Math.log(k));
        return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
    }
    
    function getStatusColor(status) {
        const colors = {
            'draft': 'secondary',
            'dikirim': 'primary',
            'selesai': 'success',
            'arsip': 'dark'
        };
        return colors[status] || 'secondary';
    }
    
    function showConfirm(message) {
        return new Promise((resolve) => resolve(confirm(message)));
    }
    
    function showLoading() {
        const overlay = document.createElement('div');
        overlay.id = 'loadingOverlay';
        overlay.style.cssText = `
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.5); z-index: 9999;
            display: flex; align-items: center; justify-content: center;
        `;
        overlay.innerHTML = `
            <div class="text-center text-white">
                <div class="spinner-border mb-3" role="status"></div>
                <p>Memproses...</p>
            </div>
        `;
        document.body.appendChild(overlay);
    }
    
    function hideLoading() {
        const overlay = document.getElementById('loadingOverlay');
        if (overlay) overlay.remove();
    }
</script>
