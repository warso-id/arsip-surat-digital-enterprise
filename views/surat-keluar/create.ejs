<div class="row mb-4">
    <div class="col-12">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                <li class="breadcrumb-item"><a href="/surat-keluar">Surat Keluar</a></li>
                <li class="breadcrumb-item active">Tambah Surat Keluar</li>
            </ol>
        </nav>
        <div class="d-flex justify-content-between align-items-center">
            <h4><i class="bi bi-plus-circle me-2"></i>Tambah Surat Keluar</h4>
            <div>
                <button type="button" class="btn btn-outline-secondary me-2" onclick="history.back()">
                    <i class="bi bi-arrow-left"></i> Kembali
                </button>
            </div>
        </div>
        <hr>
    </div>
</div>

<div class="row">
    <!-- Main Form -->
    <div class="col-lg-8">
        <div class="card shadow-sm mb-4">
            <div class="card-header">
                <ul class="nav nav-tabs card-header-tabs" id="formTabs">
                    <li class="nav-item">
                        <a class="nav-link active" data-bs-toggle="tab" href="#tabUmum">
                            <i class="bi bi-info-circle"></i> Informasi Umum
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-bs-toggle="tab" href="#tabIsi">
                            <i class="bi bi-file-text"></i> Isi Surat
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-bs-toggle="tab" href="#tabLampiran">
                            <i class="bi bi-paperclip"></i> Lampiran
                        </a>
                    </li>
                </ul>
            </div>
            <div class="card-body">
                <form id="suratKeluarForm" enctype="multipart/form-data" novalidate>
                    <div class="tab-content">
                        <!-- Tab Informasi Umum -->
                        <div class="tab-pane fade show active" id="tabUmum">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label for="nomor_surat" class="form-label">
                                        Nomor Surat <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <input type="text" class="form-control" id="nomor_surat" 
                                               name="nomor_surat" placeholder="Masukkan nomor surat" required>
                                        <button class="btn btn-outline-secondary" type="button" 
                                                onclick="generateNomorSurat()" title="Generate nomor otomatis">
                                            <i class="bi bi-magic"></i>
                                        </button>
                                    </div>
                                    <div class="invalid-feedback">Nomor surat harus diisi</div>
                                </div>
                                
                                <div class="col-md-6">
                                    <label for="tanggal_surat" class="form-label">
                                        Tanggal Surat <span class="text-danger">*</span>
                                    </label>
                                    <input type="date" class="form-control" id="tanggal_surat" 
                                           name="tanggal_surat" value="<%= new Date().toISOString().split('T')[0] %>" required>
                                    <div class="invalid-feedback">Tanggal surat harus diisi</div>
                                </div>
                                
                                <div class="col-md-6">
                                    <label for="tujuan" class="form-label">
                                        Tujuan <span class="text-danger">*</span>
                                    </label>
                                    <input type="text" class="form-control" id="tujuan" 
                                           name="tujuan" placeholder="Nama penerima/instansi tujuan" required>
                                    <div class="invalid-feedback">Tujuan harus diisi</div>
                                </div>
                                
                                <div class="col-md-6">
                                    <label for="instansi_id" class="form-label">Instansi Tujuan</label>
                                    <select class="form-select" id="instansi_id" name="instansi_id">
                                        <option value="">Pilih Instansi</option>
                                    </select>
                                </div>
                                
                                <div class="col-md-6">
                                    <label for="kategori_id" class="form-label">Kategori Surat</label>
                                    <select class="form-select" id="kategori_id" name="kategori_id">
                                        <option value="">Pilih Kategori</option>
                                    </select>
                                </div>
                                
                                <div class="col-md-3">
                                    <label for="sifat" class="form-label">
                                        Sifat <span class="text-danger">*</span>
                                    </label>
                                    <select class="form-select" id="sifat" name="sifat" required>
                                        <option value="biasa">Biasa</option>
                                        <option value="segera">Segera</option>
                                        <option value="penting">Penting</option>
                                        <option value="rahasia">Rahasia</option>
                                    </select>
                                </div>
                                
                                <div class="col-md-3">
                                    <label for="penandatangan" class="form-label">Penandatangan</label>
                                    <input type="text" class="form-control" id="penandatangan" 
                                           name="penandatangan" placeholder="Nama penandatangan">
                                </div>
                            </div>
                            
                            <div class="d-flex justify-content-end mt-4">
                                <button type="button" class="btn btn-primary" onclick="nextTab('tabIsi')">
                                    Selanjutnya <i class="bi bi-arrow-right"></i>
                                </button>
                            </div>
                        </div>
                        
                        <!-- Tab Isi Surat -->
                        <div class="tab-pane fade" id="tabIsi">
                            <div class="mb-3">
                                <label for="perihal" class="form-label">
                                    Perihal <span class="text-danger">*</span>
                                </label>
                                <input type="text" class="form-control" id="perihal" 
                                       name="perihal" placeholder="Perihal surat" required>
                                <div class="invalid-feedback">Perihal harus diisi</div>
                            </div>
                            
                            <div class="mb-3">
                                <label for="isi_ringkas" class="form-label">Isi Ringkas Surat</label>
                                <textarea class="form-control" id="isi_ringkas" name="isi_ringkas" 
                                          rows="8" placeholder="Tulis ringkasan isi surat..."></textarea>
                                <div class="form-text">Tulis ringkasan atau poin-poin penting dari surat</div>
                            </div>
                            
                            <!-- Template Surat -->
                            <div class="mb-3">
                                <label class="form-label">Template Surat</label>
                                <div class="d-flex gap-2 flex-wrap" id="templateSurat">
                                    <button type="button" class="btn btn-outline-secondary btn-sm" 
                                            onclick="applyTemplate('undangan')">
                                        <i class="bi bi-envelope"></i> Undangan
                                    </button>
                                    <button type="button" class="btn btn-outline-secondary btn-sm" 
                                            onclick="applyTemplate('pemberitahuan')">
                                        <i class="bi bi-megaphone"></i> Pemberitahuan
                                    </button>
                                    <button type="button" class="btn btn-outline-secondary btn-sm" 
                                            onclick="applyTemplate('permohonan')">
                                        <i class="bi bi-file-earmark-text"></i> Permohonan
                                    </button>
                                    <button type="button" class="btn btn-outline-secondary btn-sm" 
                                            onclick="applyTemplate('laporan')">
                                        <i class="bi bi-graph-up"></i> Laporan
                                    </button>
                                </div>
                            </div>
                            
                            <div class="d-flex justify-content-between mt-4">
                                <button type="button" class="btn btn-outline-secondary" onclick="prevTab('tabUmum')">
                                    <i class="bi bi-arrow-left"></i> Sebelumnya
                                </button>
                                <button type="button" class="btn btn-primary" onclick="nextTab('tabLampiran')">
                                    Selanjutnya <i class="bi bi-arrow-right"></i>
                                </button>
                            </div>
                        </div>
                        
                        <!-- Tab Lampiran -->
                        <div class="tab-pane fade" id="tabLampiran">
                            <div class="mb-4">
                                <label class="form-label">Upload File Surat</label>
                                <div class="file-upload-area" id="fileUploadArea" 
                                     onclick="document.getElementById('fileSurat').click()">
                                    <input type="file" class="d-none" id="fileSurat" name="file" 
                                           accept=".pdf,.doc,.docx,.jpg,.jpeg,.png"
                                           onchange="handleFileSelect(this)">
                                    <i class="bi bi-cloud-upload fs-1 text-primary"></i>
                                    <p class="mt-2 mb-0">Klik untuk memilih file atau drag & drop disini</p>
                                    <small class="text-muted">Maksimal 10MB. Format: PDF, DOC, DOCX, JPG, PNG</small>
                                </div>
                                <div id="filePreview" class="mt-3"></div>
                            </div>
                            
                            <div class="mb-3">
                                <label class="form-label">Lampiran Tambahan</label>
                                <div id="additionalAttachments">
                                    <!-- Dynamic attachment fields -->
                                </div>
                                <button type="button" class="btn btn-outline-secondary btn-sm mt-2" 
                                        onclick="addAttachmentField()">
                                    <i class="bi bi-plus-circle"></i> Tambah Lampiran
                                </button>
                            </div>
                            
                            <div class="d-flex justify-content-between mt-4">
                                <button type="button" class="btn btn-outline-secondary" onclick="prevTab('tabIsi')">
                                    <i class="bi bi-arrow-left"></i> Sebelumnya
                                </button>
                                <div>
                                    <button type="submit" class="btn btn-success me-2" id="btnSimpanDraft">
                                        <i class="bi bi-save"></i> Simpan sebagai Draft
                                    </button>
                                    <button type="submit" class="btn btn-primary" id="btnSimpanKirim">
                                        <i class="bi bi-send"></i> Simpan & Kirim
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
    
    <!-- Sidebar -->
    <div class="col-lg-4">
        <!-- Informasi -->
        <div class="card shadow-sm mb-4">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-info-circle"></i> Informasi</h5>
            </div>
            <div class="card-body">
                <ul class="list-unstyled mb-0">
                    <li class="mb-2">
                        <i class="bi bi-check-circle text-success"></i>
                        <small>Field bertanda <span class="text-danger">*</span> wajib diisi</small>
                    </li>
                    <li class="mb-2">
                        <i class="bi bi-file-earmark text-primary"></i>
                        <small>Upload file surat untuk arsip digital</small>
                    </li>
                    <li class="mb-2">
                        <i class="bi bi-magic text-warning"></i>
                        <small>Gunakan tombol magic untuk generate nomor surat otomatis</small>
                    </li>
                    <li>
                        <i class="bi bi-lightbulb text-info"></i>
                        <small>Gunakan template surat untuk mempercepat penulisan</small>
                    </li>
                </ul>
            </div>
        </div>
        
        <!-- Surat Terakhir -->
        <div class="card shadow-sm mb-4">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-clock-history"></i> Surat Terakhir</h5>
            </div>
            <div class="card-body" id="recentSurat">
                <div class="text-center py-3">
                    <small class="text-muted">Memuat...</small>
                </div>
            </div>
        </div>
        
        <!-- Ceklis Pengiriman -->
        <div class="card shadow-sm">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-check2-square"></i> Ceklis Pengiriman</h5>
            </div>
            <div class="card-body">
                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" id="ceklis1">
                    <label class="form-check-label" for="ceklis1">Nomor surat sudah benar</label>
                </div>
                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" id="ceklis2">
                    <label class="form-check-label" for="ceklis2">Tujuan surat sudah sesuai</label>
                </div>
                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" id="ceklis3">
                    <label class="form-check-label" for="ceklis3">Perihal dan isi surat sudah dicek</label>
                </div>
                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" id="ceklis4">
                    <label class="form-check-label" for="ceklis4">Lampiran sudah lengkap</label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="ceklis5">
                    <label class="form-check-label" for="ceklis5">Penandatangan sudah ditentukan</label>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    let attachmentCount = 0;
    
    document.addEventListener('DOMContentLoaded', async function() {
        await loadInstansi();
        await loadKategori();
        await loadRecentSurat();
        
        // Form submission
        document.getElementById('suratKeluarForm')?.addEventListener('submit', function(e) {
            e.preventDefault();
            const submitter = e.submitter;
            const status = submitter.id === 'btnSimpanDraft' ? 'draft' : 'dikirim';
            saveSurat(status);
        });
        
        // File drag and drop
        const dropArea = document.getElementById('fileUploadArea');
        if (dropArea) {
            ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
                dropArea.addEventListener(eventName, preventDefaults, false);
            });
            
            ['dragenter', 'dragover'].forEach(eventName => {
                dropArea.addEventListener(eventName, () => dropArea.classList.add('dragover'), false);
            });
            
            ['dragleave', 'drop'].forEach(eventName => {
                dropArea.addEventListener(eventName, () => dropArea.classList.remove('dragover'), false);
            });
            
            dropArea.addEventListener('drop', handleDrop, false);
        }
        
        // Auto-save draft
        setInterval(autoSaveDraft, 60000); // Every minute
    });
    
    function preventDefaults(e) {
        e.preventDefault();
        e.stopPropagation();
    }
    
    function handleDrop(e) {
        const dt = e.dataTransfer;
        const files = dt.files;
        document.getElementById('fileSurat').files = files;
        handleFileSelect({ files });
    }
    
    function handleFileSelect(input) {
        const file = input.files[0];
        const preview = document.getElementById('filePreview');
        
        if (file) {
            const size = formatFileSize(file.size);
            const icon = getFileIcon(file.name);
            
            preview.innerHTML = `
                <div class="alert alert-info d-flex align-items-center justify-content-between">
                    <div>
                        <i class="${icon} me-2"></i>
                        <strong>${file.name}</strong>
                        <small class="text-muted ms-2">(${size})</small>
                    </div>
                    <button type="button" class="btn btn-sm btn-outline-danger" 
                            onclick="removeFile()">
                        <i class="bi bi-x"></i>
                    </button>
                </div>
            `;
        }
    }
    
    function removeFile() {
        document.getElementById('fileSurat').value = '';
        document.getElementById('filePreview').innerHTML = '';
    }
    
    function getFileIcon(filename) {
        const ext = filename.split('.').pop().toLowerCase();
        const icons = {
            'pdf': 'bi bi-file-pdf text-danger',
            'doc': 'bi bi-file-word text-primary',
            'docx': 'bi bi-file-word text-primary',
            'jpg': 'bi bi-file-image text-success',
            'jpeg': 'bi bi-file-image text-success',
            'png': 'bi bi-file-image text-success'
        };
        return icons[ext] || 'bi bi-file-earmark';
    }
    
    function formatFileSize(bytes) {
        if (!bytes) return '0 B';
        const k = 1024;
        const sizes = ['B', 'KB', 'MB', 'GB'];
        const i = Math.floor(Math.log(bytes) / Math.log(k));
        return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
    }
    
    function addAttachmentField() {
        attachmentCount++;
        const container = document.getElementById('additionalAttachments');
        const html = `
            <div class="input-group mb-2" id="attachment-${attachmentCount}">
                <input type="text" class="form-control" name="attachment_name[]" 
                       placeholder="Nama lampiran">
                <input type="file" class="form-control" name="attachment_file[]">
                <button class="btn btn-outline-danger" type="button" 
                        onclick="document.getElementById('attachment-${attachmentCount}').remove()">
                    <i class="bi bi-x"></i>
                </button>
            </div>
        `;
        container.insertAdjacentHTML('beforeend', html);
    }
    
    async function loadInstansi() {
        try {
            const response = await axios.get('/api/instansi?perPage=100');
            const data = response.data.data.data;
            const select = document.getElementById('instansi_id');
            data.forEach(item => {
                select.innerHTML += `<option value="${item.id}">${item.nama_instansi}</option>`;
            });
        } catch (error) {
            console.error('Error loading instansi:', error);
        }
    }
    
    async function loadKategori() {
        try {
            const response = await axios.get('/api/kategori?perPage=100');
            const data = response.data.data.data;
            const select = document.getElementById('kategori_id');
            data.forEach(item => {
                select.innerHTML += `<option value="${item.id}">${item.nama_kategori}</option>`;
            });
        } catch (error) {
            console.error('Error loading kategori:', error);
        }
    }
    
    async function loadRecentSurat() {
        try {
            const response = await axios.get('/api/surat-keluar?perPage=5');
            const data = response.data.data.data;
            
            const container = document.getElementById('recentSurat');
            if (data.length === 0) {
                container.innerHTML = '<p class="text-muted text-center mb-0">Belum ada surat keluar</p>';
                return;
            }
            
            container.innerHTML = data.map(surat => `
                <div class="mb-2 pb-2 border-bottom">
                    <small class="fw-bold">${surat.nomor_surat}</small><br>
                    <small class="text-muted">${surat.perihal}</small><br>
                    <small>${formatDate(surat.tanggal_surat)}</small>
                </div>
            `).join('');
        } catch (error) {
            console.error('Error loading recent surat:', error);
        }
    }
    
    function generateNomorSurat() {
        const now = new Date();
        const bulan = ['I', 'II', 'III', 'IV', 'V', 'VI', 'VII', 'VIII', 'IX', 'X', 'XI', 'XII'];
        const random = Math.floor(Math.random() * 900) + 100;
        const nomor = `${random}/SK/${bulan[now.getMonth()]}/${now.getFullYear()}`;
        document.getElementById('nomor_surat').value = nomor;
    }
    
    function applyTemplate(type) {
        const templates = {
            'undangan': {
                perihal: 'Undangan Rapat Koordinasi',
                isi_ringkas: 'Mengundang Bapak/Ibu untuk menghadiri rapat koordinasi yang akan dilaksanakan pada:\n\nHari/Tanggal: [isi tanggal]\nWaktu: [isi waktu]\nTempat: [isi tempat]\nAgenda: [isi agenda]\n\nDemikian undangan ini disampaikan, atas perhatian dan kehadirannya diucapkan terima kasih.'
            },
            'pemberitahuan': {
                perihal: 'Pemberitahuan',
                isi_ringkas: 'Bersama ini kami sampaikan pemberitahuan bahwa:\n\n[isi pemberitahuan]\n\nDemikian pemberitahuan ini disampaikan untuk dapat diketahui dan dilaksanakan sebagaimana mestinya.'
            },
            'permohonan': {
                perihal: 'Permohonan',
                isi_ringkas: 'Bersama ini kami mengajukan permohonan:\n\n[isi permohonan]\n\nDemikian permohonan ini disampaikan, atas perhatian dan kerjasamanya diucapkan terima kasih.'
            },
            'laporan': {
                perihal: 'Laporan Kegiatan',
                isi_ringkas: 'Bersama ini kami sampaikan laporan kegiatan:\n\nNama Kegiatan: [isi nama]\nWaktu Pelaksanaan: [isi waktu]\nTempat: [isi tempat]\nHasil: [isi hasil]\n\nDemikian laporan ini disampaikan sebagai bahan evaluasi.'
            }
        };
        
        const template = templates[type];
        if (template) {
            document.getElementById('perihal').value = template.perihal;
            document.getElementById('isi_ringkas').value = template.isi_ringkas;
            
            // Switch to isi tab
            const tab = new bootstrap.Tab(document.querySelector('#tabIsi'));
            tab.show();
        }
    }
    
    function nextTab(tabId) {
        const tab = new bootstrap.Tab(document.querySelector(`[href="#${tabId}"]`));
        tab.show();
    }
    
    function prevTab(tabId) {
        const tab = new bootstrap.Tab(document.querySelector(`[href="#${tabId}"]`));
        tab.show();
    }
    
    async function saveSurat(status) {
        const form = document.getElementById('suratKeluarForm');
        
        // Validate form
        if (!form.checkValidity()) {
            form.classList.add('was-validated');
            return;
        }
        
        const formData = new FormData(form);
        formData.append('status', status);
        
        // Add attachment names
        const attachmentNames = document.querySelectorAll('input[name="attachment_name[]"]');
        const attachmentFiles = document.querySelectorAll('input[name="attachment_file[]"]');
        
        const attachments = [];
        attachmentNames.forEach((nameInput, index) => {
            if (nameInput.value || attachmentFiles[index].files[0]) {
                attachments.push({
                    name: nameInput.value || 'Lampiran',
                    file: attachmentFiles[index].files[0]
                });
            }
        });
        
        if (attachments.length > 0) {
            formData.append('attachments', JSON.stringify(attachments.map(a => a.name)));
        }
        
        try {
            showLoading();
            
            await axios.post('/api/surat-keluar', formData, {
                headers: { 'Content-Type': 'multipart/form-data' }
            });
            
            hideLoading();
            
            const message = status === 'draft' ? 
                'Surat berhasil disimpan sebagai draft' : 
                'Surat berhasil disimpan dan dikirim';
            
            alert(message);
            window.location.href = '/surat-keluar';
        } catch (error) {
            hideLoading();
            const message = error.response?.data?.message || 'Gagal menyimpan surat';
            alert(message);
        }
    }
    
    function autoSaveDraft() {
        const form = document.getElementById('suratKeluarForm');
        const formData = new FormData(form);
        const data = Object.fromEntries(formData);
        
        // Save to localStorage as draft
        localStorage.setItem('suratKeluarDraft', JSON.stringify(data));
    }
    
    function loadDraft() {
        const draft = localStorage.getItem('suratKeluarDraft');
        if (draft) {
            const data = JSON.parse(draft);
            Object.keys(data).forEach(key => {
                const element = document.getElementById(key);
                if (element && key !== 'file') {
                    element.value = data[key];
                }
            });
        }
    }
    
    function formatDate(date) {
        return new Date(date).toLocaleDateString('id-ID', {
            year: 'numeric', month: 'long', day: 'numeric'
        });
    }
    
    function showLoading() {
        const overlay = document.createElement('div');
        overlay.id = 'loadingOverlay';
        overlay.style.cssText = `
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.5); z-index: 9999;
            display: flex; align-items: center; justify-content: center;
        `;
        overlay.innerHTML = `
            <div class="text-center text-white">
                <div class="spinner-border mb-3" role="status"></div>
                <p>Menyimpan surat...</p>
            </div>
        `;
        document.body.appendChild(overlay);
    }
    
    function hideLoading() {
        const overlay = document.getElementById('loadingOverlay');
        if (overlay) overlay.remove();
    }
    
    // Load draft on page load
    loadDraft();
</script>

<style>
.file-upload-area {
    border: 2px dashed #dee2e6;
    border-radius: 10px;
    padding: 30px;
    text-align: center;
    cursor: pointer;
    transition: all 0.3s;
}
.file-upload-area:hover, .file-upload-area.dragover {
    border-color: #007bff;
    background: rgba(0,123,255,0.05);
}
</style>
