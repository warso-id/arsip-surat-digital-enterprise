<div class="row mb-4">
    <div class="col-12">
        <h4><i class="bi bi-sliders me-2"></i>Pengaturan Sistem</h4>
        <hr>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card shadow-sm mb-4">
            <div class="card-header"><h5 class="mb-0">Pengaturan Umum</h5></div>
            <div class="card-body">
                <form id="generalSettingsForm">
                    <div class="mb-3">
                        <label for="app_name" class="form-label">Nama Aplikasi</label>
                        <input type="text" class="form-control" id="app_name" name="app_name">
                    </div>
                    <div class="mb-3">
                        <label for="app_description" class="form-label">Deskripsi Aplikasi</label>
                        <textarea class="form-control" id="app_description" name="app_description" rows="2"></textarea>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="items_per_page" class="form-label">Item per Halaman</label>
                            <select class="form-select" id="items_per_page" name="items_per_page">
                                <option value="10">10</option>
                                <option value="20">20</option>
                                <option value="50">50</option>
                                <option value="100">100</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="session_timeout" class="form-label">Timeout Session (menit)</label>
                            <input type="number" class="form-control" id="session_timeout" name="session_timeout">
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save"></i> Simpan Pengaturan
                    </button>
                </form>
            </div>
        </div>
        
        <div class="card shadow-sm mb-4">
            <div class="card-header"><h5 class="mb-0">Pengaturan Notifikasi</h5></div>
            <div class="card-body">
                <form id="notificationSettingsForm">
                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input" type="checkbox" id="notifikasi_email" name="notifikasi_email">
                        <label class="form-check-label" for="notifikasi_email">Aktifkan Notifikasi Email</label>
                    </div>
                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input" type="checkbox" id="backup_enabled" name="backup_enabled">
                        <label class="form-check-label" for="backup_enabled">Aktifkan Backup Otomatis</label>
                    </div>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save"></i> Simpan Pengaturan
                    </button>
                </form>
            </div>
        </div>
    </div>
    
    <div class="col-lg-4">
        <div class="card shadow-sm mb-4">
            <div class="card-header"><h5 class="mb-0">Informasi Sistem</h5></div>
            <div class="card-body" id="systemInfo">
                <div class="text-center py-3">Memuat...</div>
            </div>
        </div>
        
        <div class="card shadow-sm">
            <div class="card-header"><h5 class="mb-0">Backup Database</h5></div>
            <div class="card-body">
                <button class="btn btn-primary w-100 mb-2" onclick="createBackup()">
                    <i class="bi bi-download"></i> Backup Sekarang
                </button>
                <div id="backupList" class="mt-3"></div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', async function() {
        await loadSettings();
        await loadSystemInfo();
        await loadBackupList();
    });
    
    async function loadSettings() {
        try {
            const response = await axios.get('/api/pengaturan');
            const settings = response.data.data;
            
            document.getElementById('app_name').value = settings.app_name || '';
            document.getElementById('app_description').value = settings.app_description || '';
            document.getElementById('items_per_page').value = settings.items_per_page || '20';
            document.getElementById('session_timeout').value = settings.session_timeout || '30';
            document.getElementById('notifikasi_email').checked = settings.notifikasi_email === 'true';
            document.getElementById('backup_enabled').checked = settings.backup_enabled === 'true';
        } catch (error) {
            console.error('Error loading settings:', error);
        }
    }
    
    async function loadSystemInfo() {
        try {
            const response = await axios.get('/api/pengaturan/app-info');
            const info = response.data.data;
            
            document.getElementById('systemInfo').innerHTML = `
                <ul class="list-unstyled mb-0">
                    <li class="mb-2"><strong>Nama:</strong> ${info.name}</li>
                    <li class="mb-2"><strong>Versi:</strong> ${info.version}</li>
                    <li class="mb-2"><strong>Environment:</strong> ${info.environment}</li>
                    <li class="mb-2"><strong>Node.js:</strong> ${info.node_version}</li>
                </ul>
            `;
        } catch (error) {
            console.error('Error loading system info:', error);
        }
    }
    
    async function loadBackupList() {
        try {
            const response = await axios.get('/api/backup/list');
            const backups = response.data.data || [];
            
            if (backups.length === 0) {
                document.getElementById('backupList').innerHTML = '<p class="text-muted">Belum ada backup</p>';
                return;
            }
            
            document.getElementById('backupList').innerHTML = backups.map(b => `
                <div class="d-flex justify-content-between align-items-center mb-2 p-2 border rounded">
                    <div>
                        <small>${b.name}</small><br>
                        <small class="text-muted">${b.sizeFormatted} - ${new Date(b.createdAt).toLocaleString()}</small>
                    </div>
                    <a href="/api/backup/download/${b.name}" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-download"></i>
                    </a>
                </div>
            `).join('');
        } catch (error) {
            console.error('Error loading backups:', error);
        }
    }
    
    async function createBackup() {
        try {
            showLoading();
            await axios.post('/api/backup/create');
            hideLoading();
            alert('Backup berhasil dibuat');
            await loadBackupList();
        } catch (error) {
            hideLoading();
            alert('Gagal membuat backup');
        }
    }
    
    document.getElementById('generalSettingsForm')?.addEventListener('submit', async function(e) {
        e.preventDefault();
        const formData = new FormData(this);
        const data = Object.fromEntries(formData);
        
        try {
            await axios.put('/api/pengaturan', data);
            alert('Pengaturan berhasil disimpan');
        } catch (error) {
            alert('Gagal menyimpan pengaturan');
        }
    });
    
    document.getElementById('notificationSettingsForm')?.addEventListener('submit', async function(e) {
        e.preventDefault();
        const data = {
            notifikasi_email: document.getElementById('notifikasi_email').checked ? 'true' : 'false',
            backup_enabled: document.getElementById('backup_enabled').checked ? 'true' : 'false'
        };
        
        try {
            await axios.put('/api/pengaturan', data);
            alert('Pengaturan berhasil disimpan');
        } catch (error) {
            alert('Gagal menyimpan pengaturan');
        }
    });
</script>
