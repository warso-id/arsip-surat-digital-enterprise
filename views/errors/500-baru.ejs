<div class="text-center py-5">
    <div class="mb-4">
        <i class="bi bi-exclamation-triangle" style="font-size: 80px; color: #ffc107;"></i>
    </div>
    <h1 class="display-1 fw-bold">500</h1>
    <h3>Kesalahan Server</h3>
    <p class="text-muted mb-4">
        Maaf, terjadi kesalahan pada server. Silakan coba lagi nanti.
    </p>
    <% if (message) { %>
    <div class="alert alert-danger">
        <%= message %>
    </div>
    <% } %>
    <div>
        <a href="/dashboard" class="btn btn-primary">
            <i class="bi bi-house"></i> Kembali ke Dashboard
        </a>
        <button onclick="location.reload()" class="btn btn-secondary ms-2">
            <i class="bi bi-arrow-clockwise"></i> Coba Lagi
        </button>
    </div>
</div>
