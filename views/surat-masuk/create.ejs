<div class="row mb-4">
    <div class="col-12">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                <li class="breadcrumb-item"><a href="/surat-masuk">Surat Masuk</a></li>
                <li class="breadcrumb-item active">Tambah Surat</li>
            </ol>
        </nav>
        <h4><i class="bi bi-plus-circle me-2"></i>Tambah Surat Masuk</h4>
        <hr>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-body">
                <form id="suratForm" enctype="multipart/form-data">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="nomor_surat" class="form-label">Nomor Surat <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="nomor_surat" name="nomor_surat" required>
                        </div>
                        
                        <div class="col-md-6">
                            <label for="tanggal_surat" class="form-label">Tanggal Surat <span class="text-danger">*</span></label>
                            <input type="date" class="form-control" id="tanggal_surat" name="tanggal_surat" required>
                        </div>
                        
                        <div class="col-md-6">
                            <label for="pengirim" class="form-label">Pengirim <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="pengirim" name="pengirim" required>
                        </div>
                        
                        <div class="col-md-6">
                            <label for="instansi_id" class="form-label">Instansi</label>
                            <select class="form-select" id="instansi_id" name="instansi_id">
                                <option value="">Pilih Instansi</option>
                            </select>
                        </div>
                        
                        <div class="col-md-6">
                            <label for="tanggal_terima" class="form-label">Tanggal Terima <span class="text-danger">*</span></label>
                            <input type="date" class="form-control" id="tanggal_terima" name="tanggal_terima" required>
                        </div>
                        
                        <div class="col-md-6">
                            <label for="kategori_id" class="form-label">Kategori</label>
                            <select class="form-select" id="kategori_id" name="kategori_id">
                                <option value="">Pilih Kategori</option>
                            </select>
                        </div>
                        
                        <div class="col-md-6">
                            <label for="sifat" class="form-label">Sifat <span class="text-danger">*</span></label>
                            <select class="form-select" id="sifat" name="sifat" required>
                                <option value="biasa">Biasa</option>
                                <option value="segera">Segera</option>
                                <option value="penting">Penting</option>
                                <option value="rahasia">Rahasia</option>
                            </select>
                        </div>
                        
                        <div class="col-12">
                            <label for="perihal" class="form-label">Perihal <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="perihal" name="perihal" required>
                        </div>
                        
                        <div class="col-12">
                            <label for="isi_ringkas" class="form-label">Isi Ringkas</label>
                            <textarea class="form-control" id="isi_ringkas" name="isi_ringkas" rows="4"></textarea>
                        </div>
                        
                        <div class="col-12">
                            <label for="fileSurat" class="form-label">File Surat</label>
                            <input type="file" class="form-control" id="fileSurat" name="file" 
                                   accept=".pdf,.doc,.docx,.jpg,.jpeg,.png">
                            <div class="form-text">Maksimal 10MB. Format: PDF, DOC, DOCX, JPG, PNG</div>
                            <div id="filePreview"></div>
                        </div>
                    </div>
                    
                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save"></i> Simpan
                        </button>
                        <a href="/surat-masuk" class="btn btn-secondary ms-2">
                            <i class="bi bi-arrow-left"></i> Kembali
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
    
    <div class="col-lg-4">
        <div class="card shadow-sm">
            <div class="card-header">
                <h6 class="mb-0">Informasi</h6>
            </div>
            <div class="card-body">
                <ul class="list-unstyled mb-0">
                    <li class="mb-2">
                        <i class="bi bi-info-circle text-primary"></i>
                        <small>Field bertanda <span class="text-danger">*</span> wajib diisi</small>
                    </li>
                    <li class="mb-2">
                        <i class="bi bi-file-earmark text-primary"></i>
                        <small>Upload file surat untuk arsip digital</small>
                    </li>
                    <li>
                        <i class="bi bi-clock text-primary"></i>
                        <small>Nomor agenda akan digenerate otomatis</small>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', async function() {
        // Load instansi for dropdown
        try {
            const response = await axios.get('/api/instansi');
            const instansi = response.data.data.data;
            const select = document.getElementById('instansi_id');
            instansi.forEach(item => {
                select.innerHTML += `<option value="${item.id}">${item.nama_instansi}</option>`;
            });
        } catch (error) {
            console.error('Error loading instansi:', error);
        }
        
        // Load kategori for dropdown
        try {
            const response = await axios.get('/api/kategori');
            const kategori = response.data.data.data;
            const select = document.getElementById('kategori_id');
            kategori.forEach(item => {
                select.innerHTML += `<option value="${item.id}">${item.nama_kategori}</option>`;
            });
        } catch (error) {
            console.error('Error loading kategori:', error);
        }
    });
</script>
