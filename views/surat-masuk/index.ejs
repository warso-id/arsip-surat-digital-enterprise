<div class="row mb-4">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center">
            <h4><i class="bi bi-inbox me-2"></i>Surat Masuk</h4>
            <a href="/surat-masuk/create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Tambah Surat
            </a>
        </div>
        <hr>
    </div>
</div>

<!-- Filters -->
<div class="row mb-3">
    <div class="col-md-3 mb-2">
        <input type="text" id="searchSurat" class="form-control" placeholder="Cari surat...">
    </div>
    <div class="col-md-2 mb-2">
        <select id="filterStatus" class="form-select filter-surat" name="status">
            <option value="">Semua Status</option>
            <option value="draft">Draft</option>
            <option value="diterima">Diterima</option>
            <option value="didisposisikan">Didisposisikan</option>
            <option value="selesai">Selesai</option>
            <option value="arsip">Arsip</option>
        </select>
    </div>
    <div class="col-md-2 mb-2">
        <select id="filterSifat" class="form-select filter-surat" name="sifat">
            <option value="">Semua Sifat</option>
            <option value="biasa">Biasa</option>
            <option value="segera">Segera</option>
            <option value="penting">Penting</option>
            <option value="rahasia">Rahasia</option>
        </select>
    </div>
    <div class="col-md-2 mb-2">
        <input type="date" id="filterTanggalMulai" class="form-control filter-surat" name="tanggal_mulai" placeholder="Tanggal Mulai">
    </div>
    <div class="col-md-2 mb-2">
        <input type="date" id="filterTanggalSelesai" class="form-control filter-surat" name="tanggal_selesai" placeholder="Tanggal Selesai">
    </div>
    <div class="col-md-1 mb-2">
        <button id="resetFilter" class="btn btn-outline-secondary w-100">
            <i class="bi bi-arrow-counterclockwise"></i>
        </button>
    </div>
</div>

<!-- Table -->
<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table id="suratTable" class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>No</th>
                        <th>No. Agenda</th>
                        <th>No. Surat</th>
                        <th>Tanggal</th>
                        <th>Pengirim</th>
                        <th>Perihal</th>
                        <th>Status</th>
                        <th>Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="8" class="text-center py-5">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                            <p class="mt-2">Memuat data surat masuk...</p>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
        
        <!-- Pagination -->
        <div id="pagination" class="mt-3"></div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Initialize surat manager
        if (typeof SuratManager !== 'undefined') {
            window.suratManager = new SuratManager();
        }
        
        // Reset filter
        document.getElementById('resetFilter')?.addEventListener('click', function() {
            document.querySelectorAll('.filter-surat').forEach(el => {
                el.value = '';
            });
            document.getElementById('searchSurat').value = '';
            if (window.suratManager) {
                window.suratManager.filters = {};
                window.suratManager.currentPage = 1;
                window.suratManager.loadSurat();
            }
        });
    });
</script>
