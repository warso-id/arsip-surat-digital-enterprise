<div class="row mb-4">
    <div class="col-12">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                <li class="breadcrumb-item"><a href="/surat-masuk">Surat Masuk</a></li>
                <li class="breadcrumb-item active">Detail Surat</li>
            </ol>
        </nav>
        <div class="d-flex justify-content-between align-items-center">
            <h4><i class="bi bi-eye me-2"></i>Detail Surat Masuk</h4>
            <div>
                <a href="/surat-masuk/<%= id %>/edit" class="btn btn-warning">
                    <i class="bi bi-pencil"></i> Edit
                </a>
                <button class="btn btn-danger btn-delete-surat" data-id="<%= id %>">
                    <i class="bi bi-trash"></i> Hapus
                </button>
                <button class="btn btn-secondary btn-export-pdf" data-id="<%= id %>">
                    <i class="bi bi-file-pdf"></i> Export PDF
                </button>
            </div>
        </div>
        <hr>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card shadow-sm mb-4">
            <div class="card-header">
                <h5 class="mb-0">Informasi Surat</h5>
            </div>
            <div class="card-body" id="suratDetail">
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <p class="mt-2">Memuat data surat...</p>
                </div>
            </div>
        </div>
        
        <!-- Disposisi Section -->
        <div class="card shadow-sm mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Disposisi</h5>
                <button class="btn btn-primary btn-sm" onclick="showDisposisiForm()">
                    <i class="bi bi-plus-circle"></i> Tambah Disposisi
                </button>
            </div>
            <div class="card-body" id="disposisiSection">
                <div class="text-center py-3">
                    <span class="text-muted">Memuat data disposisi...</span>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-lg-4">
        <div class="card shadow-sm mb-4">
            <div class="card-header">
                <h5 class="mb-0">Informasi Tambahan</h5>
            </div>
            <div class="card-body" id="additionalInfo">
                <div class="text-center py-3">
                    <span class="text-muted">Memuat...</span>
                </div>
            </div>
        </div>
        
        <div class="card shadow-sm">
            <div class="card-header">
                <h5 class="mb-0">File Lampiran</h5>
            </div>
            <div class="card-body" id="attachmentsSection">
                <div class="text-center py-3">
                    <span class="text-muted">Memuat lampiran...</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Disposisi Form Modal -->
<div class="modal fade" id="disposisiModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Tambah Disposisi</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="disposisiForm">
                    <input type="hidden" name="surat_masuk_id" value="<%= id %>">
                    
                    <div class="mb-3">
                        <label for="kepada_user_id" class="form-label">Kepada <span class="text-danger">*</span></label>
                        <select class="form-select" id="kepada_user_id" name="kepada_user_id" required>
                            <option value="">Pilih Penerima</option>
                        </select>
                    </div>
                    
                    <div class="mb-3">
                        <label for="instruksi" class="form-label">Instruksi <span class="text-danger">*</span></label>
                        <textarea class="form-control" id="instruksi" name="instruksi" rows="3" required></textarea>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="batas_waktu" class="form-label">Batas Waktu</label>
                            <input type="date" class="form-control" id="batas_waktu" name="batas_waktu">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="sifat_disposisi" class="form-label">Sifat</label>
                            <select class="form-select" id="sifat_disposisi" name="sifat">
                                <option value="biasa">Biasa</option>
                                <option value="segera">Segera</option>
                                <option value="penting">Penting</option>
                                <option value="rahasia">Rahasia</option>
                            </select>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
                <button type="button" class="btn btn-primary" onclick="submitDisposisi()">Simpan</button>
            </div>
        </div>
    </div>
</div>

<script>
    let suratData = null;
    
    document.addEventListener('DOMContentLoaded', async function() {
        const suratId = '<%= id %>';
        
        // Load surat detail
        await loadSuratDetail(suratId);
        
        // Load disposisi
        await loadDisposisi(suratId);
        
        // Load users for disposisi form
        await loadUsersForDisposisi();
    });
    
    async function loadSuratDetail(id) {
        try {
            const response = await axios.get(`/api/surat-masuk/${id}`);
            suratData = response.data.data;
            
            renderSuratDetail(suratData);
            renderAdditionalInfo(suratData);
            renderAttachments(suratData);
        } catch (error) {
            document.getElementById('suratDetail').innerHTML = `
                <div class="alert alert-danger">
                    Gagal memuat data surat
                </div>
            `;
        }
    }
    
    function renderSuratDetail(surat) {
        const html = `
            <table class="table table-bordered">
                <tr>
                    <td class="fw-bold" width="200">Nomor Agenda</td>
                    <td>${surat.nomor_agenda || '-'}</td>
                </tr>
                <tr>
                    <td class="fw-bold">Nomor Surat</td>
                    <td>${surat.nomor_surat}</td>
                </tr>
                <tr>
                    <td class="fw-bold">Tanggal Surat</td>
                    <td>${app.formatDate(surat.tanggal_surat)}</td>
                </tr>
                <tr>
                    <td class="fw-bold">Tanggal Terima</td>
                    <td>${app.formatDate(surat.tanggal_terima)}</td>
                </tr>
                <tr>
                    <td class="fw-bold">Pengirim</td>
                    <td>${surat.pengirim}</td>
                </tr>
                <tr>
                    <td class="fw-bold">Instansi</td>
                    <td>${surat.instansi?.nama_instansi || '-'}</td>
                </tr>
                <tr>
                    <td class="fw-bold">Perihal</td>
                    <td>${surat.perihal}</td>
                </tr>
                <tr>
                    <td class="fw-bold">Kategori</td>
                    <td>${surat.kategori?.nama_kategori || '-'}</td>
                </tr>
                <tr>
                    <td class="fw-bold">Sifat</td>
                    <td><span class="badge bg-${getSifatColor(surat.sifat)}">${surat.sifat.toUpperCase()}</span></td>
                </tr>
                <tr>
                    <td class="fw-bold">Status</td>
                    <td><span class="badge bg-${getStatusColor(surat.status)}">${surat.status.toUpperCase()}</span></td>
                </tr>
                ${surat.isi_ringkas ? `
                <tr>
                    <td class="fw-bold">Isi Ringkas</td>
                    <td>${surat.isi_ringkas}</td>
                </tr>
                ` : ''}
                <tr>
                    <td class="fw-bold">Dibuat Oleh</td>
                    <td>${surat.creator?.nama_lengkap || '-'}</td>
                </tr>
                <tr>
                    <td class="fw-bold">Dibuat Pada</td>
                    <td>${app.formatDateTime(surat.created_at)}</td>
                </tr>
            </table>
        `;
        
        document.getElementById('suratDetail').innerHTML = html;
    }
    
    function renderAdditionalInfo(surat) {
        const html = `
            <ul class="list-unstyled mb-0">
                <li class="mb-2">
                    <i class="bi bi-person text-primary"></i>
                    <small>Dibuat oleh: ${surat.creator?.nama_lengkap || '-'}</small>
                </li>
                <li class="mb-2">
                    <i class="bi bi-clock text-primary"></i>
                    <small>Dibuat: ${app.formatDateTime(surat.created_at)}</small>
                </li>
                ${surat.updated_by ? `
                <li class="mb-2">
                    <i class="bi bi-pencil text-primary"></i>
                    <small>Diupdate oleh: ${surat.updater?.nama_lengkap || '-'}</small>
                </li>
                <li class="mb-2">
                    <i class="bi bi-clock-history text-primary"></i>
                    <small>Diupdate: ${app.formatDateTime(surat.updated_at)}</small>
                </li>
                ` : ''}
            </ul>
        `;
        
        document.getElementById('additionalInfo').innerHTML = html;
    }
    
    function renderAttachments(surat) {
        if (surat.file_path) {
            const html = `
                <div class="attachment-card">
                    <div class="d-flex align-items-center">
                        <div class="attachment-icon me-3">
                            <i class="bi bi-file-earmark-pdf"></i>
                        </div>
                        <div class="flex-grow-1">
                            <p class="mb-1">${surat.file_name || 'File Surat'}</p>
                            <small class="text-muted">${formatFileSize(surat.file_size)}</small>
                        </div>
                        <a href="/${surat.file_path}" class="btn btn-outline-primary btn-sm" target="_blank">
                            <i class="bi bi-download"></i> Download
                        </a>
                    </div>
                </div>
            `;
            document.getElementById('attachmentsSection').innerHTML = html;
        } else {
            document.getElementById('attachmentsSection').innerHTML = `
                <p class="text-muted text-center mb-0">Tidak ada lampiran</p>
            `;
        }
    }
    
    async function loadDisposisi(suratId) {
        try {
            const response = await axios.get(`/api/disposisi?surat_masuk_id=${suratId}`);
            const disposisi = response.data.data.data;
            
            if (disposisi.length === 0) {
                document.getElementById('disposisiSection').innerHTML = `
                    <p class="text-muted text-center mb-0">Belum ada disposisi</p>
                `;
                return;
            }
            
            const html = disposisi.map(disp => `
                <div class="disposisi-item mb-3 p-3 border rounded">
                    <div class="d-flex justify-content-between">
                        <div>
                            <strong>Dari:</strong> ${disp.dari_user?.nama_lengkap || '-'}
                        </div>
                        <div>
                            <span class="badge bg-${getStatusColor(disp.status)}">${disp.status.toUpperCase()}</span>
                        </div>
                    </div>
                    <div class="mt-2">
                        <strong>Kepada:</strong> ${disp.kepada_user?.nama_lengkap || '-'}
                    </div>
                    <div class="mt-2">
                        <strong>Instruksi:</strong>
                        <p class="mb-0">${disp.instruksi}</p>
                    </div>
                    ${disp.batas_waktu ? `
                    <div class="mt-2">
                        <strong>Batas Waktu:</strong> ${app.formatDate(disp.batas_waktu)}
                    </div>
                    ` : ''}
                    <div class="mt-2">
                        <small class="text-muted">${app.formatDateTime(disp.created_at)}</small>
                    </div>
                </div>
            `).join('');
            
            document.getElementById('disposisiSection').innerHTML = html;
        } catch (error) {
            document.getElementById('disposisiSection').innerHTML = `
                <div class="alert alert-danger">Gagal memuat data disposisi</div>
            `;
        }
    }
    
    async function loadUsersForDisposisi() {
        try {
            const response = await axios.get('/api/pengguna?perPage=100');
            const users = response.data.data.data;
            
            const select = document.getElementById('kepada_user_id');
            users.forEach(user => {
                select.innerHTML += `<option value="${user.id}">${user.nama_lengkap} - ${user.jabatan || 'Tanpa Jabatan'}</option>`;
            });
        } catch (error) {
            console.error('Error loading users:', error);
        }
    }
    
    function showDisposisiForm() {
        const modal = new bootstrap.Modal(document.getElementById('disposisiModal'));
        modal.show();
    }
    
    async function submitDisposisi() {
        const form = document.getElementById('disposisiForm');
        const formData = new FormData(form);
        const data = Object.fromEntries(formData);
        
        try {
            showLoading();
            await axios.post('/api/disposisi', data);
            hideLoading();
            
            alert('Disposisi berhasil dibuat');
            
            // Close modal
            bootstrap.Modal.getInstance(document.getElementById('disposisiModal')).hide();
            
            // Reload disposisi
            await loadDisposisi(data.surat_masuk_id);
            
            // Reset form
            form.reset();
        } catch (error) {
            hideLoading();
            alert(error.response?.data?.message || 'Gagal membuat disposisi');
        }
    }
    
    function getStatusColor(status) {
        const colors = {
            'draft': 'secondary',
            'diterima': 'info',
            'didisposisikan': 'warning',
            'selesai': 'success',
            'arsip': 'dark',
            'dikirim': 'primary',
            'dibaca': 'info',
            'diproses': 'primary'
        };
        return colors[status] || 'secondary';
    }
    
    function getSifatColor(sifat) {
        const colors = {
            'biasa': 'secondary',
            'segera': 'warning',
            'penting': 'danger',
            'rahasia': 'dark'
        };
        return colors[sifat] || 'secondary';
    }
    
    function formatFileSize(bytes) {
        if (!bytes) return '0 Bytes';
        const k = 1024;
        const sizes = ['Bytes', 'KB', 'MB', 'GB'];
        const i = Math.floor(Math.log(bytes) / Math.log(k));
        return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
    }
</script>
