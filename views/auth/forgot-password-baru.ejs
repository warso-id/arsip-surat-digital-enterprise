<div class="text-center mb-4">
    <i class="bi bi-question-circle fs-1 text-primary"></i>
    <h3>Lupa Password</h3>
    <p class="text-muted">Masukkan email Anda untuk mereset password</p>
</div>

<form id="forgotPasswordForm" onsubmit="handleForgotPassword(event)">
    <div class="mb-3">
        <label for="email" class="form-label">Email</label>
        <div class="input-group">
            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
            <input type="email" class="form-control" id="email" name="email" 
                   placeholder="Masukkan email terdaftar" required autofocus>
        </div>
    </div>
    
    <button type="submit" class="btn btn-primary w-100">
        <i class="bi bi-send"></i> Kirim Link Reset
    </button>
    
    <div class="text-center mt-3">
        <a href="/login" class="text-decoration-none">
            <i class="bi bi-arrow-left"></i> Kembali ke Login
        </a>
    </div>
</form>

<div id="resultMessage" class="mt-3" style="display: none;"></div>

<script>
    async function handleForgotPassword(e) {
        e.preventDefault();
        
        const email = document.getElementById('email').value;
        
        try {
            showLoading();
            
            await axios.post('/api/auth/forgot-password', { email });
            
            hideLoading();
            
            document.getElementById('forgotPasswordForm').style.display = 'none';
            document.getElementById('resultMessage').style.display = 'block';
            document.getElementById('resultMessage').innerHTML = `
                <div class="alert alert-success">
                    <i class="bi bi-check-circle"></i>
                    Link reset password telah dikirim ke email <strong>${email}</strong>.
                    Silakan cek inbox atau folder spam Anda.
                </div>
            `;
        } catch (error) {
            hideLoading();
            const message = error.response?.data?.message || 'Gagal mengirim link reset';
            alert(message);
        }
    }
</script>
