<div class="row mb-4">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center">
            <h4><i class="bi bi-tags me-2"></i>Manajemen Kategori</h4>
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#kategoriModal" onclick="resetForm()">
                <i class="bi bi-plus-circle"></i> Tambah Kategori
            </button>
        </div>
        <hr>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>No</th>
                                <th>Kode</th>
                                <th>Nama Kategori</th>
                                <th>Parent</th>
                                <th>Deskripsi</th>
                                <th>Aksi</th>
                            </tr>
                        </thead>
                        <tbody id="kategoriTableBody">
                            <tr><td colspan="6" class="text-center py-3">Memuat data...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card shadow-sm">
            <div class="card-header"><h5 class="mb-0">Struktur Kategori</h5></div>
            <div class="card-body" id="kategoriTree">
                <div class="text-center py-3">Memuat...</div>
            </div>
        </div>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="kategoriModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">Tambah Kategori</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="kategoriForm">
                    <input type="hidden" id="kategoriId">
                    <div class="mb-3">
                        <label for="nama_kategori" class="form-label">Nama Kategori <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="nama_kategori" name="nama_kategori" required>
                    </div>
                    <div class="mb-3">
                        <label for="kode" class="form-label">Kode</label>
                        <input type="text" class="form-control" id="kode" name="kode">
                    </div>
                    <div class="mb-3">
                        <label for="parent_id" class="form-label">Parent Kategori</label>
                        <select class="form-select" id="parent_id" name="parent_id">
                            <option value="">Tidak Ada (Root)</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="deskripsi" class="form-label">Deskripsi</label>
                        <textarea class="form-control" id="deskripsi" name="deskripsi" rows="2"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
                <button type="button" class="btn btn-primary" onclick="saveKategori()">Simpan</button>
            </div>
        </div>
    </div>
</div>

<script>
    let kategoriList = [];
    
    document.addEventListener('DOMContentLoaded', async function() {
        await loadKategori();
        await loadKategoriTree();
        await loadParentOptions();
    });
    
    async function loadKategori() {
        try {
            const response = await axios.get('/api/kategori?perPage=100');
            kategoriList = response.data.data.data;
            renderTable(kategoriList);
        } catch (error) {
            console.error('Error loading kategori:', error);
        }
    }
    
    function renderTable(data) {
        const tbody = document.getElementById('kategoriTableBody');
        
        if (data.length === 0) {
            tbody.innerHTML = '<tr><td colspan="6" class="text-center py-3">Tidak ada data</td></tr>';
            return;
        }
        
        tbody.innerHTML = data.map((item, index) => `
            <tr>
                <td>${index + 1}</td>
                <td><span class="badge bg-secondary">${item.kode || '-'}</span></td>
                <td>${item.nama_kategori}</td>
                <td>${item.parent?.nama_kategori || '-'}</td>
                <td>${item.deskripsi || '-'}</td>
                <td>
                    <button class="btn btn-sm btn-warning" onclick="editKategori(${item.id})">
                        <i class="bi bi-pencil"></i>
                    </button>
                    <button class="btn btn-sm btn-danger" onclick="deleteKategori(${item.id})">
                        <i class="bi bi-trash"></i>
                    </button>
                </td>
            </tr>
        `).join('');
    }
    
    async function loadKategoriTree() {
        try {
            const response = await axios.get('/api/kategori/tree');
            const tree = response.data.data;
            
            document.getElementById('kategoriTree').innerHTML = buildTreeHTML(tree);
        } catch (error) {
            console.error('Error loading tree:', error);
        }
    }
    
    function buildTreeHTML(items, level = 0) {
        if (!items || items.length === 0) return '<p class="text-muted">Tidak ada kategori</p>';
        
        let html = '<ul class="list-unstyled">';
        items.forEach(item => {
            html += `
                <li class="mb-1">
                    <div class="d-flex align-items-center">
                        <span class="me-2">${'—'.repeat(level)}</span>
                        <span class="badge bg-primary me-2">${item.kode || '-'}</span>
                        <span>${item.nama_kategori}</span>
                    </div>
                    ${item.children ? buildTreeHTML(item.children, level + 1) : ''}
                </li>
            `;
        });
        html += '</ul>';
        return html;
    }
    
    async function loadParentOptions() {
        const select = document.getElementById('parent_id');
        kategoriList.forEach(item => {
            select.innerHTML += `<option value="${item.id}">${item.nama_kategori}</option>`;
        });
    }
    
    function resetForm() {
        document.getElementById('kategoriForm').reset();
        document.getElementById('kategoriId').value = '';
        document.getElementById('modalTitle').textContent = 'Tambah Kategori';
    }
    
    function editKategori(id) {
        const item = kategoriList.find(i => i.id === id);
        if (!item) return;
        
        document.getElementById('kategoriId').value = item.id;
        document.getElementById('nama_kategori').value = item.nama_kategori;
        document.getElementById('kode').value = item.kode || '';
        document.getElementById('parent_id').value = item.parent_id || '';
        document.getElementById('deskripsi').value = item.deskripsi || '';
        document.getElementById('modalTitle').textContent = 'Edit Kategori';
        
        new bootstrap.Modal(document.getElementById('kategoriModal')).show();
    }
    
    async function saveKategori() {
        const form = document.getElementById('kategoriForm');
        const formData = new FormData(form);
        const data = Object.fromEntries(formData);
        const id = document.getElementById('kategoriId').value;
        
        if (!data.parent_id) delete data.parent_id;
        
        try {
            if (id) {
                await axios.put(`/api/kategori/${id}`, data);
            } else {
                await axios.post('/api/kategori', data);
            }
            
            bootstrap.Modal.getInstance(document.getElementById('kategoriModal')).hide();
            await loadKategori();
            await loadKategoriTree();
            alert('Data berhasil disimpan');
        } catch (error) {
            alert(error.response?.data?.message || 'Gagal menyimpan data');
        }
    }
    
    async function deleteKategori(id) {
        const confirmed = await app.confirm('Hapus kategori ini?');
        if (!confirmed) return;
        
        try {
            await axios.delete(`/api/kategori/${id}`);
            await loadKategori();
            await loadKategoriTree();
            alert('Kategori berhasil dihapus');
        } catch (error) {
            alert(error.response?.data?.message || 'Gagal menghapus kategori');
        }
    }
</script>
