<div class="row mb-4">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center">
            <h4><i class="bi bi-file-text me-2"></i>Laporan</h4>
            <div>
                <button id="btnExportPDF" class="btn btn-danger">
                    <i class="bi bi-file-pdf"></i> Export PDF
                </button>
                <button id="btnExportExcel" class="btn btn-success">
                    <i class="bi bi-file-excel"></i> Export Excel
                </button>
            </div>
        </div>
        <hr>
    </div>
</div>

<!-- Filters -->
<div class="card shadow-sm mb-4">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-2">
                <label class="form-label">Tipe Surat</label>
                <select id="filterTipe" class="form-select">
                    <option value="semua">Semua</option>
                    <option value="masuk">Surat Masuk</option>
                    <option value="keluar">Surat Keluar</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Tanggal Mulai</label>
                <input type="date" id="filterTanggalMulai" class="form-control">
            </div>
            <div class="col-md-2">
                <label class="form-label">Tanggal Selesai</label>
                <input type="date" id="filterTanggalSelesai" class="form-control">
            </div>
            <div class="col-md-2">
                <label class="form-label">Kategori</label>
                <select id="filterKategori" class="form-select">
                    <option value="">Semua</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Status</label>
                <select id="filterStatus" class="form-select">
                    <option value="">Semua</option>
                    <option value="draft">Draft</option>
                    <option value="diterima">Diterima</option>
                    <option value="dikirim">Dikirim</option>
                    <option value="selesai">Selesai</option>
                    <option value="arsip">Arsip</option>
                </select>
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button id="btnFilter" class="btn btn-primary w-100">
                    <i class="bi bi-search"></i> Filter
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Statistics Cards -->
<div class="row g-3 mb-4" id="statisticsCards">
    <div class="col-md-3">
        <div class="card bg-primary text-white">
            <div class="card-body">
                <h6>Total Surat Masuk</h6>
                <h2 id="statSuratMasuk">0</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-success text-white">
            <div class="card-body">
                <h6>Total Surat Keluar</h6>
                <h2 id="statSuratKeluar">0</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-warning text-white">
            <div class="card-body">
                <h6>Total Disposisi</h6>
                <h2 id="statDisposisi">0</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-info text-white">
            <div class="card-body">
                <h6>Disposisi Pending</h6>
                <h2 id="statPendingDisposisi">0</h2>
            </div>
        </div>
    </div>
</div>

<!-- Report Table -->
<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table id="laporanTable" class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>No</th>
                        <th>Tipe</th>
                        <th>Nomor Surat</th>
                        <th>Tanggal</th>
                        <th>Pengirim/Tujuan</th>
                        <th>Perihal</th>
                        <th>Status</th>
                        <th>Sifat</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="8" class="text-center py-5">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                            <p class="mt-2">Memuat data laporan...</p>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', async function() {
        // Load kategori filter
        try {
            const response = await axios.get('/api/kategori');
            const kategori = response.data.data.data;
            const select = document.getElementById('filterKategori');
            kategori.forEach(item => {
                select.innerHTML += `<option value="${item.id}">${item.nama_kategori}</option>`;
            });
        } catch (error) {
            console.error('Error loading kategori:', error);
        }
        
        // Load statistics
        await loadStatistics();
        
        // Load laporan
        await loadLaporan();
        
        // Filter button
        document.getElementById('btnFilter')?.addEventListener('click', async function() {
            await loadStatistics();
            await loadLaporan();
        });
        
        // Export buttons
        document.getElementById('btnExportPDF')?.addEventListener('click', exportPDF);
        document.getElementById('btnExportExcel')?.addEventListener('click', exportExcel);
    });
    
    async function loadStatistics() {
        try {
            const params = getFilterParams();
            const response = await axios.get('/api/laporan/statistics', { params });
            const data = response.data.data;
            
            document.getElementById('statSuratMasuk').textContent = data.surat?.surat_masuk?.total || 0;
            document.getElementById('statSuratKeluar').textContent = data.surat?.surat_keluar?.total || 0;
            document.getElementById('statDisposisi').textContent = data.disposisi?.total || 0;
            document.getElementById('statPendingDisposisi').textContent = data.disposisi?.belum_dibaca || 0;
        } catch (error) {
            console.error('Error loading statistics:', error);
        }
    }
    
    async function loadLaporan() {
        try {
            showLoading();
            
            const params = getFilterParams();
            const response = await axios.get('/api/laporan', { params });
            const data = response.data.data;
            
            renderTable(data);
            hideLoading();
        } catch (error) {
            hideLoading();
            console.error('Error loading laporan:', error);
        }
    }
    
    function renderTable(data) {
        const tbody = document.querySelector('#laporanTable tbody');
        
        if (!data || data.length === 0) {
            tbody.innerHTML = `
                <tr>
                    <td colspan="8" class="text-center py-5">
                        <i class="bi bi-inbox fs-1 text-muted"></i>
                        <p class="text-muted mt-2">Tidak ada data laporan</p>
                    </td>
                </tr>
            `;
            return;
        }
        
        tbody.innerHTML = data.map((item, index) => `
            <tr>
                <td>${index + 1}</td>
                <td>
                    <span class="badge bg-${item.tipe_surat === 'masuk' ? 'primary' : 'success'}">
                        ${item.tipe_surat === 'masuk' ? 'Masuk' : 'Keluar'}
                    </span>
                </td>
                <td>${item.nomor_surat || '-'}</td>
                <td>${app.formatDate(item.tanggal_surat || item.tanggal_terima)}</td>
                <td>${item.pengirim || item.tujuan || '-'}</td>
                <td>${item.perihal}</td>
                <td>
                    <span class="badge bg-${getStatusColor(item.status)}">
                        ${item.status.toUpperCase()}
                    </span>
                </td>
                <td>
                    <span class="badge bg-${getSifatColor(item.sifat)}">
                        ${item.sifat.toUpperCase()}
                    </span>
                </td>
            </tr>
        `).join('');
    }
    
    function getFilterParams() {
        return {
            tipe: document.getElementById('filterTipe')?.value || 'semua',
            tanggal_mulai: document.getElementById('filterTanggalMulai')?.value || '',
            tanggal_selesai: document.getElementById('filterTanggalSelesai')?.value || '',
            kategori_id: document.getElementById('filterKategori')?.value || '',
            status: document.getElementById('filterStatus')?.value || ''
        };
    }
    
    async function exportPDF() {
        try {
            showLoading();
            
            const params = getFilterParams();
            const response = await axios.get('/api/laporan/export-pdf', {
                params,
                responseType: 'blob'
            });
            
            const url = window.URL.createObjectURL(new Blob([response.data]));
            const link = document.createElement('a');
            link.href = url;
            link.setAttribute('download', `laporan-surat-${Date.now()}.pdf`);
            document.body.appendChild(link);
            link.click();
            link.remove();
            
            hideLoading();
        } catch (error) {
            hideLoading();
            alert('Gagal mengexport PDF');
        }
    }
    
    async function exportExcel() {
        try {
            showLoading();
            
            const params = getFilterParams();
            const response = await axios.get('/api/laporan/export-excel', {
                params,
                responseType: 'blob'
            });
            
            const url = window.URL.createObjectURL(new Blob([response.data]));
            const link = document.createElement('a');
            link.href = url;
            link.setAttribute('download', `laporan-surat-${Date.now()}.xlsx`);
            document.body.appendChild(link);
            link.click();
            link.remove();
            
            hideLoading();
        } catch (error) {
            hideLoading();
            alert('Gagal mengexport Excel');
        }
    }
    
    function getStatusColor(status) {
        const colors = {
            'draft': 'secondary',
            'diterima': 'info',
            'didisposisikan': 'warning',
            'selesai': 'success',
            'arsip': 'dark',
            'dikirim': 'primary'
        };
        return colors[status] || 'secondary';
    }
    
    function getSifatColor(sifat) {
        const colors = {
            'biasa': 'secondary',
            'segera': 'warning',
            'penting': 'danger',
            'rahasia': 'dark'
        };
        return colors[sifat] || 'secondary';
    }
</script>
