<div class="row mb-4">
    <div class="col-12">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                <li class="breadcrumb-item"><a href="/disposisi">Disposisi</a></li>
                <li class="breadcrumb-item active">Detail Disposisi</li>
            </ol>
        </nav>
        <h4><i class="bi bi-eye me-2"></i>Detail Disposisi</h4>
        <hr>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <!-- Disposisi Detail -->
        <div class="card shadow-sm mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Informasi Disposisi</h5>
                <span class="badge bg-info" id="dispStatus">Loading...</span>
            </div>
            <div class="card-body" id="disposisiDetail">
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-2">Memuat data...</p>
                </div>
            </div>
        </div>
        
        <!-- Surat Terkait -->
        <div class="card shadow-sm mb-4">
            <div class="card-header"><h5 class="mb-0">Surat Terkait</h5></div>
            <div class="card-body" id="suratTerkait">
                <div class="text-center py-3">Memuat...</div>
            </div>
        </div>
        
        <!-- Reply Section -->
        <div class="card shadow-sm mb-4">
            <div class="card-header"><h5 class="mb-0">Balasan Disposisi</h5></div>
            <div class="card-body" id="repliesSection">
                <div class="text-center py-3">Memuat...</div>
            </div>
        </div>
        
        <!-- Reply Form -->
        <div class="card shadow-sm mb-4" id="replyFormCard" style="display: none;">
            <div class="card-header"><h5 class="mb-0">Kirim Balasan</h5></div>
            <div class="card-body">
                <form id="replyForm">
                    <input type="hidden" id="disposisiId" value="<%= id %>">
                    
                    <div class="mb-3">
                        <label for="kepada_user_id" class="form-label">Kepada</label>
                        <select class="form-select" id="kepada_user_id" name="kepada_user_id">
                            <option value="">Pilih Penerima</option>
                        </select>
                    </div>
                    
                    <div class="mb-3">
                        <label for="instruksi" class="form-label">Instruksi <span class="text-danger">*</span></label>
                        <textarea class="form-control" id="instruksi" name="instruksi" rows="3" required></textarea>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="batas_waktu" class="form-label">Batas Waktu</label>
                            <input type="date" class="form-control" id="batas_waktu" name="batas_waktu">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="sifat" class="form-label">Sifat</label>
                            <select class="form-select" id="sifat" name="sifat">
                                <option value="biasa">Biasa</option>
                                <option value="segera">Segera</option>
                                <option value="penting">Penting</option>
                                <option value="rahasia">Rahasia</option>
                            </select>
                        </div>
                    </div>
                    
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-reply"></i> Kirim Balasan
                    </button>
                </form>
            </div>
        </div>
    </div>
    
    <div class="col-lg-4">
        <!-- Action Buttons -->
        <div class="card shadow-sm mb-4">
            <div class="card-header"><h5 class="mb-0">Aksi</h5></div>
            <div class="card-body">
                <div class="d-grid gap-2" id="actionButtons">
                    <button class="btn btn-success" onclick="updateStatus('diproses')">
                        <i class="bi bi-check-circle"></i> Proses
                    </button>
                    <button class="btn btn-primary" onclick="updateStatus('selesai')">
                        <i class="bi bi-check-all"></i> Selesai
                    </button>
                    <button class="btn btn-info" onclick="toggleReplyForm()">
                        <i class="bi bi-reply"></i> Balas
                    </button>
                    <button class="btn btn-secondary" onclick="exportPDF()">
                        <i class="bi bi-file-pdf"></i> Export PDF
                    </button>
                </div>
            </div>
        </div>
        
        <!-- Timeline -->
        <div class="card shadow-sm">
            <div class="card-header"><h5 class="mb-0">Timeline</h5></div>
            <div class="card-body" id="timeline">
                <div class="text-center py-3">Memuat...</div>
            </div>
        </div>
    </div>
</div>

<script>
    const disposisiId = '<%= id %>';
    let disposisiData = null;
    
    document.addEventListener('DOMContentLoaded', async function() {
        await loadDisposisiDetail();
        await loadUsers();
        
        document.getElementById('replyForm')?.addEventListener('submit', async function(e) {
            e.preventDefault();
            await submitReply();
        });
    });
    
    async function loadDisposisiDetail() {
        try {
            const response = await axios.get(`/api/disposisi/${disposisiId}`);
            disposisiData = response.data.data;
            
            renderDisposisiDetail(disposisiData);
            renderSuratTerkait(disposisiData.surat_masuk);
            renderReplies(disposisiData.replies);
            renderTimeline(disposisiData);
            
            // Update status badge
            document.getElementById('dispStatus').textContent = disposisiData.status.toUpperCase();
            document.getElementById('dispStatus').className = `badge bg-${getStatusColor(disposisiData.status)}`;
            
            // Show/hide action buttons based on status
            if (disposisiData.status === 'selesai') {
                document.getElementById('actionButtons').style.display = 'none';
            }
        } catch (error) {
            alert('Gagal memuat data disposisi');
        }
    }
    
    function renderDisposisiDetail(data) {
        document.getElementById('disposisiDetail').innerHTML = `
            <table class="table table-bordered">
                <tr>
                    <td class="fw-bold" width="150">Dari</td>
                    <td>${data.dari_user?.nama_lengkap || '-'} (${data.dari_user?.jabatan || '-'})</td>
                </tr>
                <tr>
                    <td class="fw-bold">Kepada</td>
                    <td>${data.kepada_user?.nama_lengkap || '-'} (${data.kepada_user?.jabatan || '-'})</td>
                </tr>
                <tr>
                    <td class="fw-bold">Instruksi</td>
                    <td>${data.instruksi}</td>
                </tr>
                <tr>
                    <td class="fw-bold">Batas Waktu</td>
                    <td>${data.batas_waktu ? app.formatDate(data.batas_waktu) : '-'}</td>
                </tr>
                <tr>
                    <td class="fw-bold">Sifat</td>
                    <td><span class="badge bg-${getSifatColor(data.sifat)}">${data.sifat.toUpperCase()}</span></td>
                </tr>
                <tr>
                    <td class="fw-bold">Dibuat Pada</td>
                    <td>${app.formatDateTime(data.created_at)}</td>
                </tr>
                ${data.catatan ? `
                <tr>
                    <td class="fw-bold">Catatan</td>
                    <td>${data.catatan}</td>
                </tr>` : ''}
            </table>
        `;
    }
    
    function renderSuratTerkait(surat) {
        if (!surat) {
            document.getElementById('suratTerkait').innerHTML = '<p class="text-muted">Data surat tidak tersedia</p>';
            return;
        }
        
        document.getElementById('suratTerkait').innerHTML = `
            <table class="table table-sm">
                <tr><td class="fw-bold">Nomor Agenda</td><td>${surat.nomor_agenda || '-'}</td></tr>
                <tr><td class="fw-bold">Nomor Surat</td><td>${surat.nomor_surat}</td></tr>
                <tr><td class="fw-bold">Pengirim</td><td>${surat.pengirim}</td></tr>
                <tr><td class="fw-bold">Perihal</td><td>${surat.perihal}</td></tr>
                <tr><td class="fw-bold">Tanggal Surat</td><td>${app.formatDate(surat.tanggal_surat)}</td></tr>
            </table>
            <a href="/surat-masuk/${surat.id}" class="btn btn-sm btn-outline-primary">
                <i class="bi bi-eye"></i> Lihat Surat
            </a>
        `;
    }
    
    function renderReplies(replies) {
        const container = document.getElementById('repliesSection');
        
        if (!replies || replies.length === 0) {
            container.innerHTML = '<p class="text-muted text-center">Belum ada balasan</p>';
            return;
        }
        
        container.innerHTML = replies.map(reply => `
            <div class="card mb-2">
                <div class="card-body py-2">
                    <div class="d-flex justify-content-between">
                        <strong>${reply.dari_user?.nama_lengkap || '-'}</strong>
                        <small class="text-muted">${app.timeAgo(reply.created_at)}</small>
                    </div>
                    <p class="mb-1 mt-1">${reply.instruksi}</p>
                    <small class="text-muted">
                        Kepada: ${reply.kepada_user?.nama_lengkap || '-'} | 
                        Status: <span class="badge bg-${getStatusColor(reply.status)}">${reply.status}</span>
                    </small>
                </div>
            </div>
        `).join('');
    }
    
    function renderTimeline(data) {
        const items = [
            { text: 'Disposisi dibuat', time: data.created_at, icon: 'bi-send' },
            data.read_at ? { text: 'Dibaca', time: data.read_at, icon: 'bi-eye' } : null,
            data.updated_at && data.status !== 'dikirim' ? 
                { text: `Status: ${data.status}`, time: data.updated_at, icon: 'bi-check-circle' } : null
        ].filter(Boolean);
        
        document.getElementById('timeline').innerHTML = `
            <div class="timeline">
                ${items.map((item, index) => `
                    <div class="timeline-item ${index === items.length - 1 ? 'active' : ''}">
                        <i class="bi ${item.icon}"></i>
                        <div>
                            <p class="mb-0">${item.text}</p>
                            <small class="text-muted">${app.formatDateTime(item.time)}</small>
                        </div>
                    </div>
                `).join('')}
            </div>
        `;
    }
    
    async function loadUsers() {
        try {
            const response = await axios.get('/api/pengguna?perPage=100');
            const users = response.data.data.data;
            const select = document.getElementById('kepada_user_id');
            
            users.forEach(user => {
                select.innerHTML += `<option value="${user.id}">${user.nama_lengkap} - ${user.jabatan || 'Tanpa Jabatan'}</option>`;
            });
        } catch (error) {
            console.error('Error loading users:', error);
        }
    }
    
    async function updateStatus(status) {
        try {
            showLoading();
            await axios.put(`/api/disposisi/${disposisiId}/status`, {
                status: status,
                catatan: `Disposisi di${status}kan`
            });
            hideLoading();
            alert(`Disposisi berhasil di${status}`);
            await loadDisposisiDetail();
        } catch (error) {
            hideLoading();
            alert('Gagal mengupdate status');
        }
    }
    
    function toggleReplyForm() {
        const form = document.getElementById('replyFormCard');
        form.style.display = form.style.display === 'none' ? 'block' : 'none';
    }
    
    async function submitReply() {
        const form = document.getElementById('replyForm');
        const formData = new FormData(form);
        const data = Object.fromEntries(formData);
        
        if (!data.kepada_user_id) {
            alert('Pilih penerima disposisi');
            return;
        }
        
        try {
            showLoading();
            await axios.post(`/api/disposisi/${disposisiId}/reply`, data);
            hideLoading();
            alert('Balasan berhasil dikirim');
            form.reset();
            document.getElementById('replyFormCard').style.display = 'none';
            await loadDisposisiDetail();
        } catch (error) {
            hideLoading();
            alert('Gagal mengirim balasan');
        }
    }
    
    async function exportPDF() {
        try {
            const response = await axios.get(`/api/disposisi/${disposisiId}/export-pdf`, {
                responseType: 'blob'
            });
            
            const url = window.URL.createObjectURL(new Blob([response.data]));
            const link = document.createElement('a');
            link.href = url;
            link.download = `disposisi-${disposisiId}.pdf`;
            link.click();
        } catch (error) {
            alert('Gagal export PDF');
        }
    }
    
    function getStatusColor(status) {
        const colors = {
            'draft': 'secondary', 'dikirim': 'warning', 'dibaca': 'info',
            'diproses': 'primary', 'selesai': 'success'
        };
        return colors[status] || 'secondary';
    }
    
    function getSifatColor(sifat) {
        const colors = {
            'biasa': 'secondary', 'segera': 'warning',
            'penting': 'danger', 'rahasia': 'dark'
        };
        return colors[sifat] || 'secondary';
    }
</script>

<style>
.timeline {
    position: relative;
    padding-left: 30px;
}
.timeline::before {
    content: '';
    position: absolute;
    left: 10px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: #dee2e6;
}
.timeline-item {
    position: relative;
    margin-bottom: 20px;
    padding-left: 20px;
}
.timeline-item i {
    position: absolute;
    left: -24px;
    top: 0;
    width: 20px;
    height: 20px;
    background: white;
    border: 2px solid #007bff;
    border-radius: 50%;
    text-align: center;
    font-size: 10px;
    line-height: 16px;
}
.timeline-item.active i {
    background: #007bff;
    color: white;
}
</style>
