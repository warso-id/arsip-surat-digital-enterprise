<div class="row mb-4">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center">
            <h4><i class="bi bi-send me-2"></i>Disposisi</h4>
            <div>
                <button id="btnBatchProcess" class="btn btn-success me-2" disabled>
                    <i class="bi bi-check-all"></i> Proses Terpilih
                </button>
                <a href="/surat-masuk" class="btn btn-primary">
                    <i class="bi bi-plus-circle"></i> Buat Disposisi
                </a>
            </div>
        </div>
        <hr>
    </div>
</div>

<!-- Filters -->
<div class="row mb-3">
    <div class="col-md-3 mb-2">
        <input type="text" id="searchDisposisi" class="form-control" placeholder="Cari disposisi...">
    </div>
    <div class="col-md-2 mb-2">
        <select id="filterStatus" class="form-select">
            <option value="">Semua Status</option>
            <option value="dikirim">Dikirim</option>
            <option value="dibaca">Dibaca</option>
            <option value="diproses">Diproses</option>
            <option value="selesai">Selesai</option>
        </select>
    </div>
    <div class="col-md-2 mb-2">
        <select id="filterSifat" class="form-select">
            <option value="">Semua Sifat</option>
            <option value="biasa">Biasa</option>
            <option value="segera">Segera</option>
            <option value="penting">Penting</option>
            <option value="rahasia">Rahasia</option>
        </select>
    </div>
</div>

<!-- Tabs -->
<ul class="nav nav-tabs mb-3">
    <li class="nav-item">
        <a class="nav-link active" data-bs-toggle="tab" href="#inbox">
            <i class="bi bi-inbox"></i> Masuk
            <span class="badge bg-danger ms-1" id="inboxCount">0</span>
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link" data-bs-toggle="tab" href="#outbox">
            <i class="bi bi-outbox"></i> Keluar
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link" data-bs-toggle="tab" href="#all">
            <i class="bi bi-list"></i> Semua
        </a>
    </li>
</ul>

<!-- Tab Content -->
<div class="tab-content">
    <div class="tab-pane fade show active" id="inbox">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="table-responsive">
                    <table id="disposisiTable" class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th width="40">
                                    <input type="checkbox" id="selectAll">
                                </th>
                                <th>No</th>
                                <th>Surat</th>
                                <th>Dari</th>
                                <th>Instruksi</th>
                                <th>Batas Waktu</th>
                                <th>Status</th>
                                <th>Aksi</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td colspan="8" class="text-center py-5">
                                    <div class="spinner-border text-primary" role="status">
                                        <span class="visually-hidden">Loading...</span>
                                    </div>
                                    <p class="mt-2">Memuat data disposisi...</p>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div id="pagination" class="mt-3"></div>
            </div>
        </div>
    </div>
    
    <div class="tab-pane fade" id="outbox">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="table-responsive">
                    <table id="outboxTable" class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>No</th>
                                <th>Surat</th>
                                <th>Kepada</th>
                                <th>Instruksi</th>
                                <th>Batas Waktu</th>
                                <th>Status</th>
                                <th>Aksi</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td colspan="7" class="text-center py-5">
                                    <span class="text-muted">Pilih tab untuk melihat disposisi keluar</span>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    
    <div class="tab-pane fade" id="all">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="table-responsive">
                    <table id="allTable" class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>No</th>
                                <th>Surat</th>
                                <th>Dari</th>
                                <th>Kepada</th>
                                <th>Instruksi</th>
                                <th>Status</th>
                                <th>Aksi</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td colspan="7" class="text-center py-5">
                                    <span class="text-muted">Pilih tab untuk melihat semua disposisi</span>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Initialize disposisi manager
        if (typeof DisposisiManager !== 'undefined') {
            window.disposisiManager = new DisposisiManager();
        }
        
        // Select all checkbox
        document.getElementById('selectAll')?.addEventListener('change', function() {
            const checkboxes = document.querySelectorAll('.disposisi-checkbox');
            checkboxes.forEach(cb => cb.checked = this.checked);
            updateBatchButton();
        });
        
        // Update batch button on checkbox change
        document.addEventListener('change', function(e) {
            if (e.target.matches('.disposisi-checkbox')) {
                updateBatchButton();
            }
        });
    });
    
    function updateBatchButton() {
        const checked = document.querySelectorAll('.disposisi-checkbox:checked');
        const batchBtn = document.getElementById('btnBatchProcess');
        if (batchBtn) {
            batchBtn.disabled = checked.length === 0;
            if (checked.length > 0) {
                batchBtn.innerHTML = `<i class="bi bi-check-all"></i> Proses ${checked.length} Terpilih`;
            } else {
                batchBtn.innerHTML = '<i class="bi bi-check-all"></i> Proses Terpilih';
            }
        }
    }
</script>
