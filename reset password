<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Password - Arsip Surat Digital</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: 'Segoe UI', system-ui, sans-serif;
            background: linear-gradient(135deg, #1a2332 0%, #2c3e50 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .reset-container {
            width: 100%;
            max-width: 420px;
            padding: 20px;
        }
        .reset-box {
            background: #ffffff;
            border-radius: 16px;
            padding: 40px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
        }
        .reset-header {
            text-align: center;
            margin-bottom: 30px;
        }
        .reset-logo {
            font-size: 48px;
            display: block;
            margin-bottom: 10px;
        }
        .reset-header h1 {
            font-size: 24px;
            font-weight: 700;
            color: #1a2332;
        }
        .reset-header .subtitle {
            color: #5a6a7a;
            font-size: 14px;
            margin-top: 4px;
        }
        .form-group {
            margin-bottom: 16px;
        }
        .form-group label {
            display: block;
            font-size: 13px;
            font-weight: 600;
            color: #5a6a7a;
            margin-bottom: 5px;
        }
        .form-group label i {
            margin-right: 8px;
        }
        .form-group input {
            width: 100%;
            padding: 10px 14px;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            font-size: 14px;
            transition: all 0.3s ease;
        }
        .form-group input:focus {
            outline: none;
            border-color: #1976D2;
            box-shadow: 0 0 0 3px rgba(25, 118, 210, 0.1);
        }
        .btn {
            width: 100%;
            padding: 12px;
            border: none;
            border-radius: 8px;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }
        .btn-primary {
            background: #1976D2;
            color: white;
        }
        .btn-primary:hover {
            background: #1565C0;
        }
        .btn-primary:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }
        .btn-outline {
            background: transparent;
            border: 1px solid #e2e8f0;
            color: #5a6a7a;
        }
        .btn-outline:hover {
            background: #f0f2f5;
        }
        .alert {
            padding: 12px 16px;
            border-radius: 8px;
            margin-top: 12px;
            font-size: 13px;
            display: none;
        }
        .alert-danger {
            background: #FFEBEE;
            color: #C62828;
            border: 1px solid #FFCDD2;
        }
        .alert-success {
            background: #E8F5E9;
            color: #2E7D32;
            border: 1px solid #C8E6C9;
        }
        .alert-info {
            background: #E3F2FD;
            color: #0D47A1;
            border: 1px solid #BBDEFB;
        }
        .login-link {
            text-align: center;
            margin-top: 16px;
            font-size: 14px;
            color: #5a6a7a;
        }
        .login-link a {
            color: #1976D2;
            text-decoration: none;
            font-weight: 600;
        }
        .login-link a:hover {
            text-decoration: underline;
        }
        .loading-spinner {
            display: inline-block;
            width: 16px;
            height: 16px;
            border: 2px solid #fff;
            border-top-color: transparent;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }
        @keyframes spin {
            to { transform: rotate(360deg); }
        }
        .text-center { text-align: center; }
        .mt-2 { margin-top: 12px; }
        .mb-2 { margin-bottom: 12px; }
        .hidden { display: none !important; }
        .step {
            display: none;
        }
        .step.active {
            display: block;
        }
        .step-indicators {
            display: flex;
            justify-content: center;
            gap: 12px;
            margin-bottom: 24px;
        }
        .step-indicator {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: #e2e8f0;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            color: #5a6a7a;
            transition: all 0.3s ease;
        }
        .step-indicator.active {
            background: #1976D2;
            color: white;
        }
        .step-indicator.done {
            background: #4CAF50;
            color: white;
        }
        .step-line {
            flex: 1;
            height: 2px;
            background: #e2e8f0;
            align-self: center;
            max-width: 40px;
        }
        .step-line.done {
            background: #4CAF50;
        }
        .flex-step {
            display: flex;
            align-items: center;
            gap: 4px;
        }
        .mt-2 { margin-top: 12px; }
    </style>
</head>
<body>
    <div class="reset-container">
        <div class="reset-box">
            <div class="reset-header">
                <span class="reset-logo">🔐</span>
                <h1>Reset Password</h1>
                <p class="subtitle">Arsip Surat Digital Enterprise v3.2.2</p>
            </div>

            <!-- Step Indicators -->
            <div class="step-indicators">
                <div class="flex-step">
                    <div class="step-indicator active" id="step1Indicator">1</div>
                    <div class="step-line" id="line1"></div>
                </div>
                <div class="flex-step">
                    <div class="step-indicator" id="step2Indicator">2</div>
                    <div class="step-line" id="line2"></div>
                </div>
                <div class="flex-step">
                    <div class="step-indicator" id="step3Indicator">3</div>
                </div>
            </div>

            <!-- Step 1: Request Reset -->
            <div class="step active" id="step1">
                <p style="text-align: center; color: #5a6a7a; margin-bottom: 20px;">
                    Masukkan username atau email Anda. Kami akan mengirimkan link reset password.
                </p>
                <form id="resetRequestForm">
                    <div class="form-group">
                        <label><i class="fas fa-user"></i> Username atau Email</label>
                        <input type="text" id="resetIdentifier" placeholder="Masukkan username atau email" required />
                    </div>
                    <button type="submit" class="btn btn-primary" id="resetRequestBtn">
                        <i class="fas fa-paper-plane"></i> Kirim Link Reset
                    </button>
                    <div id="resetRequestError" class="alert alert-danger"></div>
                    <div id="resetRequestSuccess" class="alert alert-success"></div>
                    <div id="resetRequestInfo" class="alert alert-info"></div>
                </form>
            </div>

            <!-- Step 2: Enter OTP/Code (Simulated) -->
            <div class="step" id="step2">
                <p style="text-align: center; color: #5a6a7a; margin-bottom: 20px;">
                    Masukkan kode verifikasi yang telah dikirim ke email Anda.
                </p>
                <form id="resetVerifyForm">
                    <div class="form-group">
                        <label><i class="fas fa-key"></i> Kode Verifikasi</label>
                        <input type="text" id="resetCode" placeholder="Masukkan kode 6 digit" required maxlength="6" />
                    </div>
                    <div style="display: flex; gap: 8px;">
                        <button type="submit" class="btn btn-primary" id="resetVerifyBtn">
                            <i class="fas fa-check"></i> Verifikasi
                        </button>
                        <button type="button" class="btn btn-outline" id="resendCodeBtn">
                            <i class="fas fa-sync"></i> Kirim Ulang
                        </button>
                    </div>
                    <div id="resetVerifyError" class="alert alert-danger"></div>
                    <div id="resetVerifySuccess" class="alert alert-success"></div>
                </form>
            </div>

            <!-- Step 3: Set New Password -->
            <div class="step" id="step3">
                <p style="text-align: center; color: #5a6a7a; margin-bottom: 20px;">
                    Buat password baru untuk akun Anda.
                </p>
                <form id="resetPasswordForm">
                    <div class="form-group">
                        <label><i class="fas fa-lock"></i> Password Baru</label>
                        <input type="password" id="resetNewPassword" placeholder="Minimal 8 karakter" required minlength="8" autocomplete="new-password" />
                    </div>
                    <div class="form-group">
                        <label><i class="fas fa-lock"></i> Konfirmasi Password</label>
                        <input type="password" id="resetConfirmPassword" placeholder="Konfirmasi password" required autocomplete="new-password" />
                    </div>
                    <button type="submit" class="btn btn-success" id="resetPasswordBtn">
                        <i class="fas fa-save"></i> Reset Password
                    </button>
                    <div id="resetPasswordError" class="alert alert-danger"></div>
                    <div id="resetPasswordSuccess" class="alert alert-success"></div>
                </form>
            </div>

            <div class="login-link">
                <a href="login.html"><i class="fas fa-arrow-left"></i> Kembali ke Login</a>
            </div>
        </div>
    </div>

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <script>
        // ========== CONFIGURATION ==========
        const API_BASE_URL = 'https://script.google.com/macros/s/AKfycbwblauw29Cv8rmrjQHhfXgdl0csBHlxO3xvZJimyBsSyA4F5f9qH25Ej5QYIu--OGy6Bw/exec';

        // ========== DOM ELEMENTS ==========
        const steps = {
            step1: document.getElementById('step1'),
            step2: document.getElementById('step2'),
            step3: document.getElementById('step3')
        };
        const indicators = {
            step1: document.getElementById('step1Indicator'),
            step2: document.getElementById('step2Indicator'),
            step3: document.getElementById('step3Indicator')
        };
        const lines = {
            line1: document.getElementById('line1'),
            line2: document.getElementById('line2')
        };

        // Step 1
        const resetRequestForm = document.getElementById('resetRequestForm');
        const resetRequestBtn = document.getElementById('resetRequestBtn');
        const resetIdentifier = document.getElementById('resetIdentifier');
        const resetRequestError = document.getElementById('resetRequestError');
        const resetRequestSuccess = document.getElementById('resetRequestSuccess');
        const resetRequestInfo = document.getElementById('resetRequestInfo');

        // Step 2
        const resetVerifyForm = document.getElementById('resetVerifyForm');
        const resetVerifyBtn = document.getElementById('resetVerifyBtn');
        const resetCode = document.getElementById('resetCode');
        const resetVerifyError = document.getElementById('resetVerifyError');
        const resetVerifySuccess = document.getElementById('resetVerifySuccess');
        const resendCodeBtn = document.getElementById('resendCodeBtn');

        // Step 3
        const resetPasswordForm = document.getElementById('resetPasswordForm');
        const resetPasswordBtn = document.getElementById('resetPasswordBtn');
        const resetNewPassword = document.getElementById('resetNewPassword');
        const resetConfirmPassword = document.getElementById('resetConfirmPassword');
        const resetPasswordError = document.getElementById('resetPasswordError');
        const resetPasswordSuccess = document.getElementById('resetPasswordSuccess');

        let currentStep = 1;
        let resetToken = null;

        // ========== STEP NAVIGATION ==========
        function goToStep(step) {
            // Hide all steps
            Object.values(steps).forEach(s => s.classList.remove('active'));
            // Show target step
            const stepKey = 'step' + step;
            if (steps[stepKey]) steps[stepKey].classList.add('active');

            // Update indicators
            Object.keys(indicators).forEach((key, index) => {
                const num = index + 1;
                if (num < step) {
                    indicators[key].className = 'step-indicator done';
                    indicators[key].textContent = '✓';
                } else if (num === step) {
                    indicators[key].className = 'step-indicator active';
                    indicators[key].textContent = num;
                } else {
                    indicators[key].className = 'step-indicator';
                    indicators[key].textContent = num;
                }
            });

            // Update lines
            if (step > 1 && lines.line1) {
                lines.line1.className = 'step-line done';
            } else if (lines.line1) {
                lines.line1.className = 'step-line';
            }
            if (step > 2 && lines.line2) {
                lines.line2.className = 'step-line done';
            } else if (lines.line2) {
                lines.line2.className = 'step-line';
            }

            currentStep = step;
        }

        // ========== SHOW/HIDE ALERTS ==========
        function showError(el, message) {
            el.textContent = message;
            el.style.display = 'block';
        }

        function showSuccess(el, message) {
            el.textContent = message;
            el.style.display = 'block';
        }

        function hideAlerts() {
            resetRequestError.style.display = 'none';
            resetRequestSuccess.style.display = 'none';
            resetRequestInfo.style.display = 'none';
            resetVerifyError.style.display = 'none';
            resetVerifySuccess.style.display = 'none';
            resetPasswordError.style.display = 'none';
            resetPasswordSuccess.style.display = 'none';
        }

        // ========== STEP 1: REQUEST RESET ==========
        resetRequestForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            hideAlerts();

            const identifier = resetIdentifier.value.trim();

            if (!identifier) {
                showError(resetRequestError, 'Username atau email harus diisi');
                return;
            }

            resetRequestBtn.disabled = true;
            resetRequestBtn.innerHTML = '<span class="loading-spinner"></span> Mengirim...';
            showSuccess(resetRequestInfo, '⏳ Mengirim permintaan...');

            try {
                // Simulasi request ke backend
                // Untuk reset password, kita akan cek user exist
                const formData = new URLSearchParams();
                formData.append('action', 'checkUser');
                formData.append('identifier', identifier);

                const response = await fetch(API_BASE_URL, {
                    method: 'POST',
                    mode: 'cors',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: formData.toString()
                });

                const result = await response.json();
                console.log('📥 Check user response:', result);

                // Simulasi - untuk demo, selalu sukses
                // Dalam implementasi nyata, backend harus mengecek user
                showSuccess(resetRequestSuccess, '✅ Link reset telah dikirim ke email Anda. Cek kotak masuk atau spam.');
                
                // Generate fake code untuk demo
                resetToken = '123456';
                
                // Go to step 2 after 1.5 seconds
                setTimeout(() => {
                    goToStep(2);
                }, 1500);

            } catch (error) {
                console.error('❌ Reset request error:', error);
                showError(resetRequestError, 'Gagal mengirim permintaan: ' + error.message);
            } finally {
                resetRequestBtn.disabled = false;
                resetRequestBtn.innerHTML = '<i class="fas fa-paper-plane"></i> Kirim Link Reset';
            }
        });

        // ========== STEP 2: VERIFY CODE ==========
        resetVerifyForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            hideAlerts();

            const code = resetCode.value.trim();

            if (!code || code.length < 6) {
                showError(resetVerifyError, 'Masukkan kode verifikasi 6 digit');
                return;
            }

            resetVerifyBtn.disabled = true;
            resetVerifyBtn.innerHTML = '<span class="loading-spinner"></span> Memverifikasi...';

            try {
                // Simulasi verifikasi
                await new Promise(resolve => setTimeout(resolve, 1000));

                if (code === resetToken) {
                    showSuccess(resetVerifySuccess, '✅ Kode verifikasi valid!');
                    setTimeout(() => {
                        goToStep(3);
                    }, 1000);
                } else {
                    showError(resetVerifyError, '❌ Kode verifikasi salah. Silakan coba lagi.');
                }

            } catch (error) {
                showError(resetVerifyError, 'Verifikasi gagal: ' + error.message);
            } finally {
                resetVerifyBtn.disabled = false;
                resetVerifyBtn.innerHTML = '<i class="fas fa-check"></i> Verifikasi';
            }
        });

        // Resend code
        resendCodeBtn.addEventListener('click', async () => {
            resetCode.value = '';
            hideAlerts();
            showSuccess(resetVerifySuccess, '✅ Kode baru telah dikirim ke email Anda.');
            // Generate new code
            resetToken = '123456';
        });

        // ========== STEP 3: RESET PASSWORD ==========
        resetPasswordForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            hideAlerts();

            const newPassword = resetNewPassword.value;
            const confirmPassword = resetConfirmPassword.value;

            if (newPassword.length < 8) {
                showError(resetPasswordError, 'Password minimal 8 karakter');
                return;
            }

            if (newPassword !== confirmPassword) {
                showError(resetPasswordError, 'Password dan konfirmasi tidak cocok');
                return;
            }

            resetPasswordBtn.disabled = true;
            resetPasswordBtn.innerHTML = '<span class="loading-spinner"></span> Menyimpan...';

            try {
                // Simulasi reset password
                await new Promise(resolve => setTimeout(resolve, 1500));

                showSuccess(resetPasswordSuccess, '✅ Password berhasil direset! Mengalihkan ke login...');
                
                setTimeout(() => {
                    window.location.href = 'login.html';
                }, 2000);

            } catch (error) {
                showError(resetPasswordError, 'Reset password gagal: ' + error.message);
            } finally {
                resetPasswordBtn.disabled = false;
                resetPasswordBtn.innerHTML = '<i class="fas fa-save"></i> Reset Password';
            }
        });

        // ========== TEST CONNECTION ==========
        async function testConnection() {
            try {
                console.log('🔗 Testing connection...');
                const response = await fetch(API_BASE_URL + '?action=ping');
                const result = await response.json();
                console.log('✅ Connection test:', result);
                if (result.status === 'success') {
                    console.log('📦 Backend version:', result.data?.version);
                }
            } catch (error) {
                console.warn('⚠️ Connection test failed:', error.message);
            }
        }

        setTimeout(testConnection, 500);

        console.log('📄 Reset Password page loaded');
        console.log('📍 API URL:', API_BASE_URL);
    </script>
</body>
</html>
