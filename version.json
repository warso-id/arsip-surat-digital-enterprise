        "webpack-cli": "^5.1.0",
        "babel-loader": "^9.1.0",
        "@babel/core": "^7.22.0",
        "@babel/preset-env": "^7.22.0",
        "css-loader": "^6.8.0",
        "style-loader": "^3.3.0",
        "jest": "^29.6.0",
        "eslint": "^8.45.0",
        "prettier": "^3.0.0",
