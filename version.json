{
  "version": "3.1.0",
  "buildDate": "2026-07-10",
  "buildNumber": "20260710.1",
  "codename": "Grand Master Final",
  
  "releaseNotes": {
    "en": "Major release with AI Engine, Blockchain Audit Trail, Biometric Authentication, Voice Commands, Dark Mode, and Multi-Language support.",
    "id": "Rilis utama dengan AI Engine, Blockchain Audit Trail, Biometric Authentication, Voice Commands, Dark Mode, dan dukungan Multi-Language."
  },
  
  "features": {
    "ai": {
      "enabled": true,
      "smartSearch": true,
      "autoTagging": true,
      "anomalyDetection": true,
      "predictiveAnalytics": true,
      "modelVersion": "3.1.0"
    },
    "blockchain": {
      "enabled": true,
      "difficulty": 3,
      "algorithm": "SHA-256",
      "consensus": "Proof of Work"
    },
    "biometric": {
      "enabled": true,
      "standard": "WebAuthn/FIDO2",
      "methods": ["face", "fingerprint", "pin"]
    },
    "voice": {
      "enabled": true,
      "languages": ["id-ID", "en-US"],
      "commands": 9
    },
    "ui": {
      "darkMode": true,
      "multiLanguage": true,
      "languages": ["id", "en"],
      "materialDesign": 3
    },
    "pwa": {
      "offlineMode": true,
      "pushNotifications": true,
      "backgroundSync": true,
      "windowControlsOverlay": true,
      "fileHandler": true,
      "shareTarget": true
    }
  },
  
  "compatibility": {
    "browsers": {
      "chrome": "120+",
      "edge": "120+",
      "safari": "17+",
      "firefox": "121+",
      "opera": "106+",
      "samsungInternet": "23+"
    },
    "os": {
      "windows": "11+",
      "macos": "14+",
      "linux": "Any",
      "android": "14+",
      "ios": "18+",
      "ipados": "18+"
    },
    "devices": ["desktop", "tablet", "mobile"]
  },
  
  "api": {
    "version": "v3",
    "endpoints": 60,
    "baseUrl": "https://script.google.com/macros/s/[SCRIPT_ID]/exec",
    "authMethod": "JWT",
    "rateLimit": 100
  },
  
  "database": {
    "type": "Google Sheets",
    "tables": 14,
    "maxRows": 10000,
    "cacheEnabled": true
  },
  
  "dependencies": {
    "chart.js": "4.4.0",
    "fuse.js": "7.0.0",
    "crypto-js": "4.2.0",
    "workbox": "7.0.0"
  },
  
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/arsip-surat-digital-enterprise"
  },
  
  "license": "MIT",
  "copyright": "2024-2026 Arsip Surat Digital Enterprise Team",
  
  "forceUpdate": false,
  "minRequiredVersion": "3.0.0",
  "updateUrl": "https://github.com/yourusername/arsip-surat-digital-enterprise/releases/latest"
}