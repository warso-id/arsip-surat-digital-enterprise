# ==================== EDITOR CONFIG ====================
# Arsip Surat Digital Enterprise

root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{json,yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
indent_size = 2

[Makefile]
indent_style = tab

[*.sh]
indent_style = tab

[*.{html,ejs,css}]
indent_size = 4

[*.{svg,xml}]
indent_size = 2
