# ============================================================
# ARSIP SURAT DIGITAL ENTERPRISE v3.0.0
# Editor Configuration
# ============================================================

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 150

[*.html]
indent_size = 4

[*.css]
indent_size = 4

[*.json]
indent_size = 2

[*.yml]
indent_size = 2
indent_style = space

[*.yaml]
indent_size = 2
indent_style = space

[*.md]
indent_size = 2
trim_trailing_whitespace = false
max_line_length = 80

[*.sh]
indent_size = 4
indent_style = tab

[Makefile]
indent_size = 4
indent_style = tab

[*.env]
indent_size = 2

[.htaccess]
indent_size = 4

[Dockerfile]
indent_size = 4

[nginx.conf]
indent_size = 4
