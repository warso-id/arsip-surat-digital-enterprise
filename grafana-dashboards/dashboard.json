{
    "dashboard": {
        "title": "Arsip Surat Digital Enterprise - Monitoring",
        "uid": "arsip-surat-enterprise",
        "version": 1,
        "panels": [
            {
                "title": "Application Status",
                "type": "stat",
                "gridPos": { "x": 0, "y": 0, "w": 6, "h": 3 },
                "targets": [
                    {
                        "expr": "up{job='arsip-surat-app'}",
                        "legendFormat": "Status"
                    }
                ],
                "options": {
                    "colorMode": "background",
                    "graphMode": "none",
                    "justifyMode": "auto",
                    "textMode": "auto"
                },
                "fieldConfig": {
                    "defaults": {
                        "mappings": [
                            { "type": "value", "value": "1", "text": "✅ ONLINE" },
                            { "type": "value", "value": "0", "text": "❌ OFFLINE" }
                        ],
                        "thresholds": {
                            "mode": "absolute",
                            "steps": [
                                { "color": "red", "value": null },
                                { "color": "green", "value": 1 }
                            ]
                        }
                    }
                }
            },
            {
                "title": "Response Time (ms)",
                "type": "gauge",
                "gridPos": { "x": 6, "y": 0, "w": 6, "h": 3 },
                "targets": [
                    {
                        "expr": "rate(http_request_duration_seconds_sum[5m]) / rate(http_request_duration_seconds_count[5m]) * 1000",
                        "legendFormat": "Response Time"
                    }
                ],
                "fieldConfig": {
                    "defaults": {
                        "thresholds": {
                            "mode": "absolute",
                            "steps": [
                                { "color": "green", "value": null },
                                { "color": "yellow", "value": 500 },
                                { "color": "red", "value": 1000 }
                            ]
                        },
                        "unit": "ms"
                    }
                }
            },
            {
                "title": "HTTP Requests/sec",
                "type": "graph",
                "gridPos": { "x": 0, "y": 3, "w": 12, "h": 8 },
                "targets": [
                    {
                        "expr": "rate(http_requests_total[1m])",
                        "legendFormat": "Requests/sec"
                    }
                ],
                "options": {
                    "legend": { "showLegend": true, "placement": "bottom" }
                }
            },
            {
                "title": "Error Rate",
                "type": "graph",
                "gridPos": { "x": 0, "y": 11, "w": 6, "h": 8 },
                "targets": [
                    {
                        "expr": "rate(http_errors_total[5m])",
                        "legendFormat": "Errors/sec"
                    }
                ],
                "fieldConfig": {
                    "defaults": {
                        "color": { "mode": "palette-classic" },
                        "thresholds": {
                            "steps": [
                                { "color": "green", "value": null },
                                { "color": "red", "value": 1 }
                            ]
                        }
                    }
                }
            },
            {
                "title": "Active Users",
                "type": "stat",
                "gridPos": { "x": 6, "y": 11, "w": 6, "h": 3 },
                "targets": [
                    {
                        "expr": "active_users_total",
                        "legendFormat": "Users"
                    }
                ]
            },
            {
                "title": "Google Apps Script Latency",
                "type": "graph",
                "gridPos": { "x": 6, "y": 14, "w": 6, "h": 5 },
                "targets": [
                    {
                        "expr": "rate(gas_request_duration_seconds_sum[5m]) / rate(gas_request_duration_seconds_count[5m]) * 1000",
                        "legendFormat": "GAS Latency (ms)"
                    }
                ]
            },
            {
                "title": "Cache Hit Rate",
                "type": "gauge",
                "gridPos": { "x": 0, "y": 19, "w": 4, "h": 3 },
                "targets": [
                    {
                        "expr": "(cache_hits_total / (cache_hits_total + cache_misses_total)) * 100",
                        "legendFormat": "Hit Rate"
                    }
                ],
                "fieldConfig": {
                    "defaults": {
                        "unit": "percent",
                        "max": 100,
                        "thresholds": {
                            "steps": [
                                { "color": "red", "value": null },
                                { "color": "yellow", "value": 50 },
                                { "color": "green", "value": 80 }
                            ]
                        }
                    }
                }
            },
            {
                "title": "Storage Usage",
                "type": "gauge",
                "gridPos": { "x": 4, "y": 19, "w": 4, "h": 3 },
                "targets": [
                    {
                        "expr": "(storage_used_bytes / storage_total_bytes) * 100",
                        "legendFormat": "Storage"
                    }
                ],
                "fieldConfig": {
                    "defaults": {
                        "unit": "percent",
                        "max": 100,
                        "thresholds": {
                            "steps": [
                                { "color": "green", "value": null },
                                { "color": "yellow", "value": 70 },
                                { "color": "red", "value": 90 }
                            ]
                        }
                    }
                }
            },
            {
                "title": "Offline Sync Queue",
                "type": "stat",
                "gridPos": { "x": 8, "y": 19, "w": 4, "h": 3 },
                "targets": [
                    {
                        "expr": "offline_sync_queue_size",
                        "legendFormat": "Pending Sync"
                    }
                ]
            }
        ],
        "refresh": "30s",
        "time": { "from": "now-1h", "to": "now" },
        "timezone": "Asia/Jakarta"
    }
}
