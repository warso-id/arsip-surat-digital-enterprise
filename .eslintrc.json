{
    "env": {
        "browser": true,
        "es2021": true,
        "node": true,
        "jest": true,
        "serviceworker": true
    },
    "extends": [
        "eslint:recommended"
    ],
    "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "module",
        "ecmaFeatures": {
            "jsx": false,
            "impliedStrict": true
        }
    },
    "globals": {
        "EnterpriseCore": "readonly",
        "EnterpriseConnector": "readonly",
        "EnterpriseDB": "readonly",
        "EnterpriseAuth": "readonly",
        "EnterpriseCache": "readonly",
        "EnterpriseI18n": "readonly",
        "EnterpriseTheme": "readonly",
        "EnterpriseMonitor": "readonly",
        "EnterpriseBackup": "readonly",
        "EnterpriseRealtime": "readonly",
        "EnterpriseOfflineSync": "readonly",
        "EnterpriseSecurity": "readonly",
        "EnterprisePerformance": "readonly",
        "EnterpriseLogger": "readonly",
        "EnterpriseErrorBoundary": "readonly",
        "EnterpriseDevTools": "readonly",
        "EnterpriseAnalytics": "readonly",
        "EnterpriseAutoUpdate": "readonly",
        "EnterpriseUtils": "readonly",
        "EnterpriseRouter": "readonly",
        "EnterpriseApp": "readonly",
        "GASAPI": "readonly",
        "MasterLoader": "readonly",
        "__BASE64": "readonly",
        "__GAS": "readonly",
        "__STORE": "readonly",
        "__LOG": "readonly",
        "__AUTH": "readonly",
        "__ONLINE": "readonly",
        "__STARTUP_TIME": "readonly",
        "ENTERPRISE_CONFIG": "readonly",
        "startup": "readonly",
        "google": "readonly",
        "SpreadsheetApp": "readonly",
        "Utilities": "readonly",
        "ContentService": "readonly",
        "UrlFetchApp": "readonly",
        "Session": "readonly",
        "PropertiesService": "readonly"
    },
    "rules": {
        "no-unused-vars": ["warn", { 
            "argsIgnorePattern": "^_",
            "varsIgnorePattern": "^_"
        }],
        "no-console": "off",
        "no-debugger": "warn",
        "no-alert": "warn",
        "no-eval": "error",
        "no-implied-eval": "error",
        "no-new-func": "error",
        "no-param-reassign": "warn",
        "no-return-assign": "error",
        "no-script-url": "error",
        "no-self-compare": "error",
        "no-sequences": "error",
        "no-throw-literal": "error",
        "no-unused-expressions": "warn",
        "no-useless-call": "warn",
        "no-useless-concat": "warn",
        "no-useless-return": "warn",
        "no-var": "error",
        "prefer-const": "error",
        "prefer-arrow-callback": "warn",
        "prefer-template": "warn",
        "prefer-spread": "warn",
        "prefer-rest-params": "warn",
        "prefer-destructuring": ["warn", {
            "array": false,
            "object": true
        }],
        "object-shorthand": "warn",
        "arrow-spacing": "warn",
        "block-spacing": "warn",
        "comma-spacing": "warn",
        "computed-property-spacing": "warn",
        "func-call-spacing": "warn",
        "key-spacing": "warn",
        "keyword-spacing": "warn",
        "no-multi-spaces": "warn",
        "no-trailing-spaces": "warn",
        "semi": ["warn", "always"],
        "quotes": ["warn", "single", { "avoidEscape": true }],
        "indent": ["warn", 4, { "SwitchCase": 1 }],
        "max-len": ["warn", { "code": 150, "ignoreComments": true, "ignoreStrings": true }],
        "complexity": ["warn", 15],
        "max-depth": ["warn", 4],
        "max-nested-callbacks": ["warn", 4],
        "max-params": ["warn", 5],
        "max-statements": ["warn", 50],
        "eqeqeq": ["error", "always"],
        "curly": ["warn", "multi-line"],
        "dot-notation": "warn",
        "guard-for-in": "warn",
        "no-caller": "error",
        "no-case-declarations": "error",
        "no-else-return": "warn",
        "no-empty-function": "warn",
        "no-eq-null": "error",
        "no-extra-bind": "warn",
        "no-extra-label": "warn",
        "no-floating-decimal": "warn",
        "no-implicit-coercion": "warn",
        "no-iterator": "error",
        "no-lone-blocks": "warn",
        "no-loop-func": "warn",
        "no-new": "warn",
        "no-new-wrappers": "error",
        "no-proto": "error",
        "no-redeclare": "error",
        "no-return-await": "warn",
        "no-self-assign": "error",
        "no-unmodified-loop-condition": "warn",
        "no-unneeded-ternary": "warn",
        "no-useless-escape": "warn",
        "no-with": "error",
        "require-await": "warn",
        "valid-typeof": "error"
    },
    "overrides": [
        {
            "files": ["*.test.js", "*.spec.js"],
            "rules": {
                "max-statements": "off",
                "max-len": "off"
            }
        },
        {
            "files": ["Code.gs"],
            "rules": {
                "no-var": "off",
                "prefer-const": "off",
                "prefer-template": "off"
            }
        }
    ]
}
