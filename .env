# ============================================
# SECURITY CONFIGURATION
# ============================================
# JWT / Token Secrets (CHANGE THESE IN PRODUCTION)
JWT_SECRET=arsip-surat-digital-enterprise-secret-key-v3
JWT_EXPIRY=3600000
JWT_REFRESH_SECRET=arsip-surat-digital-enterprise-refresh-secret-v3
JWT_REFRESH_EXPIRY=86400000

# CSRF Protection
CSRF_SECRET=csrf-protection-secret-key-v3
CSRF_EXPIRY=3600000

# Session
SESSION_TIMEOUT=3600000
SESSION_REFRESH_BEFORE=300000
MAX_LOGIN_ATTEMPTS=5
LOCK_DURATION_MINUTES=15

# Encryption
ENCRYPTION_ALGORITHM=AES-GCM
ENCRYPTION_KEY_LENGTH=256
ENCRYPTION_SECRET=change-this-encryption-secret-in-production
ENCRYPTION_IV=change-this-iv-in-production

# API Key (for server-to-server)
API_KEY=change-this-api-key-in-production
API_KEY_HEADER=X-API-Key

# ============================================
# AUTHENTICATION CONFIGURATION
# ============================================
# LDAP (Optional)
LDAP_ENABLED=false
LDAP_URL=ldap://your-ldap-server:389
LDAP_BASE_DN=dc=example,dc=com
LDAP_USERNAME=cn=admin,dc=example,dc=com
LDAP_PASSWORD=your-ldap-password

# SSO / OAuth (Optional)
SSO_ENABLED=false
OAUTH_CLIENT_ID=your-oauth-client-id
OAUTH_CLIENT_SECRET=your-oauth-client-secret
OAUTH_REDIRECT_URI=http://localhost:8080/oauth/callback
OAUTH_AUTH_URL=https://accounts.google.com/o/oauth2/auth
OAUTH_TOKEN_URL=https://oauth2.googleapis.com/token

# 2FA / MFA
TWO_FACTOR_ENABLED=true
TWO_FACTOR_ISSUER=Arsip Surat Digital
TWO_FACTOR_ALGORITHM=SHA1
TWO_FACTOR_DIGITS=6
TWO_FACTOR_PERIOD=30

# ============================================
# PUSH NOTIFICATIONS
# ============================================
PUSH_ENABLED=true
PUSH_VAPID_PUBLIC_KEY=your-vapid-public-key
PUSH_VAPID_PRIVATE_KEY=your-vapid-private-key
PUSH_VAPID_SUBJECT=mailto:admin@example.com

# ============================================
# EMAIL CONFIGURATION
# ============================================
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=Arsip Surat Digital
SMTP_FROM_EMAIL=noreply@example.com
SMTP_REPLY_TO=support@example.com

# ============================================
# TELEGRAM NOTIFICATIONS
# ============================================
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
TELEGRAM_GROUP_ID=your-telegram-group-id

# ============================================
# WEBHOOK CONFIGURATION
# ============================================
WEBHOOK_ENABLED=false
WEBHOOK_SECRET=your-webhook-secret
WEBHOOK_MAX_RETRIES=3
WEBHOOK_TIMEOUT=10000

# ============================================
# FEATURE FLAGS
# ============================================
FEATURE_BIOMETRIC=true
FEATURE_TWO_FACTOR=true
FEATURE_PUSH_NOTIFICATIONS=true
FEATURE_VOICE_COMMANDS=false
FEATURE_OFFLINE_MODE=true
FEATURE_AI=true
FEATURE_AI_AUTO_TAG=true
FEATURE_AI_CLASSIFY=true
FEATURE_AI_RECOMMEND=true
FEATURE_OCR=true
FEATURE_BLOCKCHAIN=true
FEATURE_PDF_GENERATION=true
FEATURE_DIGITAL_SIGNATURE=true
FEATURE_WEBHOOKS=true
FEATURE_LDAP=false
FEATURE_SSO=false
FEATURE_CHATBOT=false
FEATURE_DARK_MODE=true
FEATURE_EXPORT_EXCEL=true
FEATURE_EXPORT_PDF=true
FEATURE_BULK_OPERATIONS=true
FEATURE_AUTO_SAVE=true
FEATURE_REALTIME_DASHBOARD=true
FEATURE_ADVANCED_SEARCH=true

# ============================================
# CACHE CONFIGURATION
# ============================================
CACHE_ENABLED=true
CACHE_PREFIX=asd_
CACHE_TTL=300
CACHE_MAX_SIZE=104857600
CACHE_STORAGE=indexeddb

# Redis (Optional)
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_PREFIX=asd:

# ============================================
# DATABASE CONFIGURATION (Optional)
# ============================================
# Primary storage is Google Sheets
# Optional: External database for additional features
DB_ENABLED=false
DB_TYPE=sqlite
DB_HOST=localhost
DB_PORT=5432
DB_NAME=arsip_surat_digital
DB_USERNAME=postgres
DB_PASSWORD=your-db-password
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10

# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================
UPLOAD_ENABLED=true
UPLOAD_MAX_FILE_SIZE=10485760
UPLOAD_ALLOWED_TYPES=pdf,doc,docx,xls,xlsx,ppt,pptx,jpg,jpeg,png,gif
UPLOAD_MAX_FILES=10
UPLOAD_CHUNK_SIZE=1048576

# ============================================
# OCR CONFIGURATION
# ============================================
OCR_ENABLED=true
OCR_ENGINE=tesseract
OCR_LANGUAGE=ind+eng
OCR_CONFIDENCE_THRESHOLD=80

# ============================================
# BLOCKCHAIN CONFIGURATION
# ============================================
BLOCKCHAIN_ENABLED=true
BLOCKCHAIN_DIFFICULTY=2
BLOCKCHAIN_MINING_REWARD=0
BLOCKCHAIN_NODE_URL=http://localhost:8545

# ============================================
# RETENTION POLICY
# ============================================
RETENTION_ACTIVE_YEARS=5
RETENTION_INACTIVE_YEARS=10
RETENTION_PERMANENT_YEARS=0
RETENTION_AUTO_ARCHIVE=true
RETENTION_AUTO_DESTROY=false

# ============================================
# BACKUP CONFIGURATION
# ============================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 0 * * *
BACKUP_RETENTION_COUNT=30
BACKUP_INCLUDE_FILES=true
BACKUP_COMPRESS=true
BACKUP_LOCATION=./backups

# ============================================
# ANALYTICS CONFIGURATION
# ============================================
ANALYTICS_ENABLED=true
ANALYTICS_TRACK_PAGE_VIEWS=true
ANALYTICS_TRACK_CLICKS=true
ANALYTICS_TRACK_ERRORS=true
ANALYTICS_TRACK_PERFORMANCE=true
ANALYTICS_BATCH_SIZE=10
ANALYTICS_FLUSH_INTERVAL=30000

# Google Analytics (Optional)
GA_ENABLED=false
GA_TRACKING_ID=UA-XXXXXXXXX-X
GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# ============================================
# LOGGING CONFIGURATION
# ============================================
LOG_LEVEL=debug
LOG_FORMAT=json
LOG_OUTPUT=console
LOG_FILE=./logs/app.log
LOG_MAX_SIZE=10485760
LOG_MAX_FILES=10
LOG_INCLUDE_TIMESTAMP=true

# ============================================
# PWA CONFIGURATION
# ============================================
PWA_ENABLED=true
PWA_CACHE_NAME=asd-v3.2.2
PWA_THEME_COLOR=#1565C0
PWA_BACKGROUND_COLOR=#FFFFFF
PWA_DISPLAY=standalone
PWA_ORIENTATION=portrait-primary

# ============================================
# UI CONFIGURATION
# ============================================
UI_DEFAULT_THEME=light
UI_SIDEBAR_COLLAPSED=false
UI_DEFAULT_PAGE_SIZE=20
UI_PAGE_SIZE_OPTIONS=10,20,50,100
UI_TOAST_DURATION=5000
UI_TOAST_POSITION=bottom-right
UI_ANIMATION_DURATION=300
UI_DATE_FORMAT=DD/MM/YYYY
UI_DATETIME_FORMAT=DD/MM/YYYY HH:mm
UI_MOBILE_BREAKPOINT=768
UI_TABLET_BREAKPOINT=1024

# ============================================
# PERFORMANCE CONFIGURATION
# ============================================
PERF_LAZY_LOAD_IMAGES=true
PERF_LAZY_LOAD_COMPONENTS=true
PERF_DEBOUNCE_DELAY=300
PERF_THROTTLE_DELAY=100
PERF_VIRTUAL_SCROLL_THRESHOLD=100
PERF_PREFETCH_LINKS=true
PERF_MINIFY_HTML=true
PERF_MINIFY_CSS=true
PERF_MINIFY_JS=true
PERF_GZIP=true
PERF_BROTLI=false

# ============================================
# SECURITY HEADERS
# ============================================
SECURITY_CSP_ENABLED=true
SECURITY_CSP_POLICY=default-src 'self'; script-src 'self' 'unsafe-inline' https://script.google.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self'; connect-src 'self' https://script.google.com
SECURITY_XSS_PROTECTION=true
SECURITY_HSTS_ENABLED=true
SECURITY_HSTS_MAX_AGE=31536000
SECURITY_X_FRAME_OPTIONS=DENY
SECURITY_X_CONTENT_TYPE_OPTIONS=nosniff
SECURITY_REFERRER_POLICY=strict-origin-when-cross-origin

# ============================================
# CORS CONFIGURATION
# ============================================
CORS_ENABLED=true
CORS_ORIGIN=*
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_HEADERS=Content-Type,Authorization,X-CSRF-Token,X-API-Key
CORS_CREDENTIALS=true
CORS_MAX_AGE=86400

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_API_MAX=1000

# ============================================
# DEVELOPMENT TOOLS
# ============================================
DEV_SERVER_PORT=8080
DEV_SERVER_HOST=localhost
DEV_LIVERELOAD_PORT=35729
DEV_MOCK_API=true
DEV_MOCK_API_DELAY=200
DEV_HOT_RELOAD=true
DEV_SOURCE_MAPS=true
DEV_VERBOSE_LOGGING=false

# ============================================
# TESTING CONFIGURATION
# ============================================
TEST_ENABLED=true
TEST_TIMEOUT=30000
TEST_RETRIES=2
TEST_COVERAGE_THRESHOLD=80
TEST_E2E_BROWSER=chromium
TEST_E2E_HEADLESS=true
TEST_E2E_SLOW_MO=0

# ============================================
# BUILD CONFIGURATION
# ============================================
BUILD_OUTPUT_DIR=./build
BUILD_SOURCE_MAPS=false
BUILD_MINIFY=true
BUILD_BUNDLE=true
BUILD_GZIP=true
BUILD_CACHE_BUST=true
BUILD_CLEAN=true

# ============================================
# DEPLOY CONFIGURATION
# ============================================
DEPLOY_TARGET=github
DEPLOY_BRANCH=gh-pages
DEPLOY_REMOTE=origin
DEPLOY_FORCE=false
DEPLOY_BACKUP_ENABLED=true
DEPLOY_BACKUP_KEEP=5
DEPLOY_CREATE_TAG=true
DEPLOY_UPDATE_CHANGELOG=true

# Netlify
NETLIFY_SITE_ID=your-netlify-site-id
NETLIFY_AUTH_TOKEN=your-netlify-auth-token

# Vercel
VERCEL_TOKEN=your-vercel-token
VERCEL_ORG_ID=your-vercel-org-id
VERCEL_PROJECT_ID=your-vercel-project-id

# ============================================
# GITHUB CONFIGURATION
# ============================================
GITHUB_REPO=warso-id/arsip-surat-digital-enterprise
GITHUB_PAGES_URL=https://warso-id.github.io/arsip-surat-digital-enterprise
GITHUB_TOKEN=your-github-personal-access-token

# ============================================
# MONITORING & HEALTH CHECKS
# ============================================
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_ENDPOINT=/health
HEALTH_CHECK_INTERVAL=30000
MONITORING_ENABLED=false
MONITORING_SERVICE=sentry

# Sentry (Optional)
SENTRY_DSN=your-sentry-dsn
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1.0

# ============================================
# SLACK NOTIFICATIONS (Optional)
# ============================================
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=your-slack-webhook-url
SLACK_CHANNEL=#app-notifications
SLACK_USERNAME=Arsip Surat Digital Bot

# ============================================
# BASE64 ENCODING CONFIGURATION
# ============================================
# Used for securing data transmission between frontend and GAS
BASE64_ENABLED=true
BASE64_ENCODE_PAYLOAD=true
BASE64_ENCODE_RESPONSE=true
BASE64_ENCODE_FILES=true
BASE64_ENCODE_TOKENS=true

# ============================================
# CUSTOM CONFIGURATION (Extensible)
# ============================================
# Add any custom configuration below
# Format: CUSTOM_KEY=value
CUSTOM_DEFAULT_DISPOSISI_PRIORITY=normal
CUSTOM_DEFAULT_DISPOSISI_TENGGAT_DAYS=3
CUSTOM_AUTO_NUMBERING=true
CUSTOM_NUMBERING_FORMAT={NOMOR}/UN/{BULAN_ROMAN}/{TAHUN}
CUSTOM_SIGNATURE_REQUIRED=true
CUSTOM_APPROVAL_LEVELS=3
CUSTOM_NOTIFICATION_RETENTION_DAYS=30
CUSTOM_AUDIT_LOG_RETENTION_DAYS=365

# ============================================
# IMPORTANT NOTES:
# ============================================
# 1. NEVER commit this file with real secrets to GitHub
# 2. Use .env.example for public repository
# 3. Add .env to .gitignore
# 4. Use environment-specific files:
#    - .env.development
#    - .env.staging
#    - .env.production
# 5. All sensitive values above are PLACEHOLDERS
# 6. Generate real secrets using: node tools/generate-secrets.js
# ============================================
