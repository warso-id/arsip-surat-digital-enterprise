<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <style>
        body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; margin: 0; padding: 0; }
        .container { max-width: 600px; margin: 0 auto; }
        .header { background: linear-gradient(135deg, #28a745, #20c997); color: white; padding: 30px; text-align: center; }
        .content { padding: 30px; background: #fff; }
        .footer { text-align: center; padding: 20px; color: #666; font-size: 12px; background: #f8f9fa; }
        .btn { display: inline-block; background: #28a745; color: white; padding: 12px 30px; text-decoration: none; border-radius: 5px; margin: 20px 0; }
        .info-box { background: #e7f3ff; border-left: 4px solid #007bff; padding: 15px; margin: 20px 0; }
        .urgent { color: #dc3545; font-weight: bold; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>Disposisi Baru</h1>
            <p>Arsip Surat Digital Enterprise</p>
        </div>
        <div class="content">
            <p>Halo <strong><%= user.nama_lengkap %></strong>,</p>
            <p>Anda menerima disposisi baru dengan detail:</p>
            
            <div class="info-box">
                <p><strong>Nomor Surat:</strong> <%= surat.nomor_surat %></p>
                <p><strong>Pengirim:</strong> <%= surat.pengirim %></p>
                <p><strong>Perihal:</strong> <%= surat.perihal %></p>
                <p><strong>Instruksi:</strong> <%= disposisi.instruksi %></p>
                <% if (disposisi.batas_waktu) { %>
                <p><strong>Batas Waktu:</strong> <span class="<%= isUrgent ? 'urgent' : '' %>"><%= disposisi.batas_waktu %></span></p>
                <% } %>
                <% if (disposisi.sifat) { %>
                <p><strong>Sifat:</strong> <%= disposisi.sifat.toUpperCase() %></p>
                <% } %>
            </div>

            <% if (isUrgent) { %>
            <p class="urgent">Mohon segera ditindaklanjuti!</p>
            <% } %>

            <div style="text-align: center;">
                <a href="<%= appUrl %>/disposisi/<%= disposisi.id %>" class="btn">Lihat Disposisi</a>
            </div>
        </div>
        <div class="footer">
            <p>&copy; <%= new Date().getFullYear() %> Arsip Surat Digital Enterprise. All rights reserved.</p>
            <p>Email ini dikirim secara otomatis, mohon tidak membalas.</p>
        </div>
    </div>
</body>
</html>
