-- database.sqlite.example - Contoh Struktur Database SQLite
-- File ini hanya sebagai referensi struktur database
-- Database utama menggunakan Google Sheets via Google Apps Script

-- Tabel Roles
CREATE TABLE IF NOT EXISTS roles (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    nama_role TEXT NOT NULL,
    kode TEXT UNIQUE NOT NULL,
    deskripsi TEXT,
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    updated_at DATETIME DEFAULT CURRENT_TIMESTAMP
);

-- Tabel Pengguna
CREATE TABLE IF NOT EXISTS pengguna (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    nama TEXT NOT NULL,
    email TEXT UNIQUE NOT NULL,
    password TEXT NOT NULL,
    role_id INTEGER REFERENCES roles(id),
    instansi_id INTEGER REFERENCES instansi(id),
    jabatan TEXT,
    telepon TEXT,
    avatar TEXT,
    status TEXT DEFAULT 'aktif',
    remember_token TEXT,
    last_login DATETIME,
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    updated_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    created_by INTEGER,
    updated_by INTEGER
);

-- Tabel Kategori
CREATE TABLE IF NOT EXISTS kategori (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    nama_kategori TEXT NOT NULL,
    kode TEXT UNIQUE NOT NULL,
    deskripsi TEXT,
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    updated_at DATETIME DEFAULT CURRENT_TIMESTAMP
);

-- Tabel Instansi
CREATE TABLE IF NOT EXISTS instansi (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    nama_instansi TEXT NOT NULL,
    kode_instansi TEXT UNIQUE,
    alamat TEXT,
    telepon TEXT,
    email TEXT,
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    updated_at DATETIME DEFAULT CURRENT_TIMESTAMP
);

-- Tabel Surat Masuk
CREATE TABLE IF NOT EXISTS surat_masuk (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    no_agenda TEXT UNIQUE NOT NULL,
    tanggal_terima DATE NOT NULL,
    pengirim TEXT NOT NULL,
    instansi_id INTEGER REFERENCES instansi(id),
    perihal TEXT NOT NULL,
    kategori_id INTEGER REFERENCES kategori(id),
    sifat TEXT DEFAULT 'biasa',
    status TEXT DEFAULT 'baru',
    file_path TEXT,
    catatan TEXT,
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    updated_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    created_by INTEGER,
    updated_by INTEGER
);

-- Tabel Surat Keluar
CREATE TABLE IF NOT EXISTS surat_keluar (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    no_surat TEXT UNIQUE NOT NULL,
    tanggal_surat DATE NOT NULL,
    tujuan TEXT NOT NULL,
    instansi_id INTEGER REFERENCES instansi(id),
    perihal TEXT NOT NULL,
    isi_surat TEXT,
    kategori_id INTEGER REFERENCES kategori(id),
    status TEXT DEFAULT 'draft',
    file_path TEXT,
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    updated_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    created_by INTEGER,
    updated_by INTEGER
);

-- Tabel Disposisi
CREATE TABLE IF NOT EXISTS disposisi (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    no_disposisi TEXT UNIQUE NOT NULL,
    surat_masuk_id INTEGER REFERENCES surat_masuk(id),
    dari_user_id INTEGER REFERENCES pengguna(id),
    kepada_user_id INTEGER REFERENCES pengguna(id),
    instruksi TEXT NOT NULL,
    sifat TEXT DEFAULT 'biasa',
    status TEXT DEFAULT 'pending',
    batas_waktu DATE,
    catatan TEXT,
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    updated_at DATETIME DEFAULT CURRENT_TIMESTAMP
);

-- Tabel Lampiran
CREATE TABLE IF NOT EXISTS lampiran (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    surat_type TEXT NOT NULL,
    surat_id INTEGER NOT NULL,
    nama_file TEXT NOT NULL,
    file_path TEXT NOT NULL,
    tipe_file TEXT,
    ukuran INTEGER,
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP
);

-- Tabel Notifikasi
CREATE TABLE IF NOT EXISTS notifikasi (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    user_id INTEGER REFERENCES pengguna(id),
    tipe TEXT NOT NULL,
    judul TEXT NOT NULL,
    pesan TEXT,
    is_read INTEGER DEFAULT 0,
    link TEXT,
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP
);

-- Tabel Log Aktivitas
CREATE TABLE IF NOT EXISTS log_aktivitas (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    user_id INTEGER,
    user_name TEXT,
    aktivitas TEXT NOT NULL,
    modul TEXT NOT NULL,
    deskripsi TEXT,
    ip_address TEXT,
    user_agent TEXT,
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP
);

-- Tabel Pengaturan
CREATE TABLE IF NOT EXISTS pengaturan (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    kunci TEXT UNIQUE NOT NULL,
    nilai TEXT,
    deskripsi TEXT,
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    updated_at DATETIME DEFAULT CURRENT_TIMESTAMP
);

-- Indexes
CREATE INDEX idx_pengguna_email ON pengguna(email);
CREATE INDEX idx_pengguna_role ON pengguna(role_id);
CREATE INDEX idx_surat_masuk_tanggal ON surat_masuk(tanggal_terima);
CREATE INDEX idx_surat_masuk_status ON surat_masuk(status);
CREATE INDEX idx_surat_masuk_kategori ON surat_masuk(kategori_id);
CREATE INDEX idx_surat_keluar_tanggal ON surat_keluar(tanggal_surat);
CREATE INDEX idx_surat_keluar_status ON surat_keluar(status);
CREATE INDEX idx_disposisi_status ON disposisi(status);
CREATE INDEX idx_disposisi_dari ON disposisi(dari_user_id);
CREATE INDEX idx_disposisi_kepada ON disposisi(kepada_user_id);
CREATE INDEX idx_notifikasi_user ON notifikasi(user_id);
CREATE INDEX idx_notifikasi_read ON notifikasi(is_read);
CREATE INDEX idx_log_user ON log_aktivitas(user_id);
CREATE INDEX idx_log_modul ON log_aktivitas(modul);
