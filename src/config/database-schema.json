{
    "database": {
        "name": "ArsipSuratEnterprise",
        "version": 3,
        "description": "Enterprise Database Schema"
    },
    "tables": {
        "users": {
            "name": "tbl_users",
            "keyPath": "id",
            "autoIncrement": true,
            "description": "User accounts",
            "fields": {
                "id": { "type": "number", "required": true, "description": "Unique user ID" },
                "nama_lengkap": { "type": "string", "required": true, "maxLength": 200 },
                "email": { "type": "string", "required": true, "unique": true, "maxLength": 200 },
                "password": { "type": "string", "required": true, "encrypted": true },
                "role_id": { "type": "number", "required": true, "foreignKey": "roles.id" },
                "instansi_id": { "type": "number", "foreignKey": "instansi.id" },
                "jabatan": { "type": "string", "maxLength": 200 },
                "phone": { "type": "string", "maxLength": 20 },
                "avatar": { "type": "string", "description": "Base64 encoded image" },
                "status": { "type": "string", "default": "active", "enum": ["active", "inactive", "blocked"] },
                "last_login": { "type": "datetime" },
                "created_at": { "type": "datetime", "auto": true },
                "updated_at": { "type": "datetime", "auto": true }
            },
            "indexes": [
                { "name": "idx_email", "keyPath": "email", "unique": true },
                { "name": "idx_role", "keyPath": "role_id" },
                { "name": "idx_instansi", "keyPath": "instansi_id" },
                { "name": "idx_status", "keyPath": "status" }
            ]
        },
        "instansi": {
            "name": "tbl_instansi",
            "keyPath": "id",
            "autoIncrement": true,
            "description": "Institutions/organizations",
            "fields": {
                "id": { "type": "number", "required": true },
                "kode": { "type": "string", "required": true, "unique": true, "maxLength": 20 },
                "nama": { "type": "string", "required": true, "maxLength": 300 },
                "alamat": { "type": "string", "maxLength": 500 },
                "phone": { "type": "string", "maxLength": 20 },
                "email": { "type": "string", "maxLength": 200 },
                "logo": { "type": "string", "description": "Base64 encoded" },
                "created_at": { "type": "datetime", "auto": true }
            },
            "indexes": [
                { "name": "idx_kode", "keyPath": "kode", "unique": true }
            ]
        },
        "surat_masuk": {
            "name": "tbl_surat_masuk",
            "keyPath": "id",
            "autoIncrement": true,
            "description": "Incoming letters",
            "fields": {
                "id": { "type": "number", "required": true },
                "no_agenda": { "type": "string", "required": true, "unique": true, "maxLength": 50 },
                "no_surat": { "type": "string", "maxLength": 100 },
                "tanggal_terima": { "type": "date", "required": true },
                "tanggal_surat": { "type": "date", "required": true },
                "pengirim": { "type": "string", "required": true, "maxLength": 300 },
                "perihal": { "type": "string", "required": true, "maxLength": 500 },
                "sifat": { "type": "string", "default": "biasa", "enum": ["biasa", "penting", "segera", "rahasia"] },
                "status": { "type": "string", "default": "baru", "enum": ["baru", "proses", "selesai", "arsip"] },
                "file": { "type": "string", "description": "Base64 encoded file" },
                "file_name": { "type": "string", "maxLength": 300 },
                "file_type": { "type": "string", "maxLength": 100 },
                "instansi_id": { "type": "number", "foreignKey": "instansi.id" },
                "created_by": { "type": "number", "foreignKey": "users.id" },
                "created_at": { "type": "datetime", "auto": true },
                "updated_at": { "type": "datetime", "auto": true }
            },
            "indexes": [
                { "name": "idx_no_agenda", "keyPath": "no_agenda", "unique": true },
                { "name": "idx_tanggal", "keyPath": "tanggal_terima" },
                { "name": "idx_status", "keyPath": "status" },
                { "name": "idx_pengirim", "keyPath": "pengirim" }
            ]
        },
        "surat_keluar": {
            "name": "tbl_surat_keluar",
            "keyPath": "id",
            "autoIncrement": true,
            "description": "Outgoing letters",
            "fields": {
                "id": { "type": "number", "required": true },
                "no_agenda": { "type": "string", "required": true, "unique": true, "maxLength": 50 },
                "no_surat": { "type": "string", "maxLength": 100 },
                "tanggal_surat": { "type": "date", "required": true },
                "tanggal_kirim": { "type": "date" },
                "tujuan": { "type": "string", "required": true, "maxLength": 300 },
                "perihal": { "type": "string", "required": true, "maxLength": 500 },
                "klasifikasi": { "type": "string", "default": "biasa" },
                "status": { "type": "string", "default": "draft", "enum": ["draft", "terkirim", "pending", "arsip"] },
                "file": { "type": "string", "description": "Base64 encoded" },
                "created_by": { "type": "number", "foreignKey": "users.id" },
                "created_at": { "type": "datetime", "auto": true },
                "updated_at": { "type": "datetime", "auto": true }
            },
            "indexes": [
                { "name": "idx_no_agenda", "keyPath": "no_agenda", "unique": true },
                { "name": "idx_tanggal", "keyPath": "tanggal_surat" },
                { "name": "idx_status", "keyPath": "status" }
            ]
        },
        "disposisi": {
            "name": "tbl_disposisi",
            "keyPath": "id",
            "autoIncrement": true,
            "description": "Letter dispositions",
            "fields": {
                "id": { "type": "number", "required": true },
                "surat_id": { "type": "number", "required": true, "foreignKey": "surat_masuk.id" },
                "no_disposisi": { "type": "string", "maxLength": 50 },
                "dari_user_id": { "type": "number", "required": true, "foreignKey": "users.id" },
                "kepada_user_id": { "type": "number", "required": true, "foreignKey": "users.id" },
                "instruksi": { "type": "string", "required": true, "maxLength": 1000 },
                "batas_waktu": { "type": "date" },
                "prioritas": { "type": "string", "default": "normal" },
                "status": { "type": "string", "default": "pending" },
                "created_at": { "type": "datetime", "auto": true },
                "updated_at": { "type": "datetime", "auto": true }
            },
            "indexes": [
                { "name": "idx_surat", "keyPath": "surat_id" },
                { "name": "idx_dari", "keyPath": "dari_user_id" },
                { "name": "idx_kepada", "keyPath": "kepada_user_id" },
                { "name": "idx_status", "keyPath": "status" }
            ]
        },
        "activity_logs": {
            "name": "tbl_activity_logs",
            "keyPath": "id",
            "autoIncrement": true,
            "description": "System activity logs",
            "fields": {
                "id": { "type": "number", "required": true },
                "user_id": { "type": "number", "foreignKey": "users.id" },
                "action": { "type": "string", "required": true, "maxLength": 100 },
                "description": { "type": "string", "maxLength": 500 },
                "ip_address": { "type": "string", "maxLength": 50 },
                "user_agent": { "type": "string", "maxLength": 500 },
                "metadata": { "type": "string", "description": "JSON string" },
                "timestamp": { "type": "datetime", "auto": true }
            },
            "indexes": [
                { "name": "idx_user", "keyPath": "user_id" },
                { "name": "idx_timestamp", "keyPath": "timestamp" },
                { "name": "idx_action", "keyPath": "action" }
            ]
        }
    }
}
