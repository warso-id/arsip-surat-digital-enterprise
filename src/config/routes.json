{
    "version": "3.0.0",
    "baseUrl": "/",
    "defaultRoute": "/dashboard.html",
    "loginRoute": "/login.html",
    "errorRoute": "/404.html",
    "offlineRoute": "/offline.html",
    
    "routes": {
        "public": [
            {
                "path": "/",
                "file": "index.html",
                "title": "Beranda - Arsip Surat Digital Enterprise",
                "meta": {
                    "description": "Sistem Manajemen Arsip Surat Digital Enterprise",
                    "requiresAuth": false
                }
            },
            {
                "path": "/index.html",
                "file": "index.html",
                "title": "Beranda - Arsip Surat Digital Enterprise",
                "requiresAuth": false
            },
            {
                "path": "/login.html",
                "file": "login.html",
                "title": "Login - Arsip Surat Digital Enterprise",
                "requiresAuth": false
            }
        ],
        "protected": [
            {
                "path": "/dashboard.html",
                "file": "dashboard.html",
                "title": "Dashboard - Arsip Surat Digital Enterprise",
                "requiresAuth": true,
                "permissions": ["dashboard:view"],
                "icon": "📊"
            },
            {
                "path": "/surat-masuk.html",
                "file": "surat-masuk.html",
                "title": "Surat Masuk - Arsip Surat Digital Enterprise",
                "requiresAuth": true,
                "permissions": ["surat-masuk:read"],
                "icon": "📥",
                "apiEndpoints": {
                    "list": "surat-masuk/list",
                    "create": "surat-masuk/create",
                    "update": "surat-masuk/update",
                    "delete": "surat-masuk/delete"
                }
            },
            {
                "path": "/surat-keluar.html",
                "file": "surat-keluar.html",
                "title": "Surat Keluar - Arsip Surat Digital Enterprise",
                "requiresAuth": true,
                "permissions": ["surat-keluar:read"],
                "icon": "📤",
                "apiEndpoints": {
                    "list": "surat-keluar/list",
                    "create": "surat-keluar/create",
                    "update": "surat-keluar/update",
                    "delete": "surat-keluar/delete"
                }
            },
            {
                "path": "/disposisi.html",
                "file": "disposisi.html",
                "title": "Disposisi - Arsip Surat Digital Enterprise",
                "requiresAuth": true,
                "permissions": ["disposisi:read"],
                "icon": "📋",
                "apiEndpoints": {
                    "list": "disposisi/list",
                    "create": "disposisi/create",
                    "update": "disposisi/update"
                }
            },
            {
                "path": "/laporan.html",
                "file": "laporan.html",
                "title": "Laporan - Arsip Surat Digital Enterprise",
                "requiresAuth": true,
                "permissions": ["laporan:read"],
                "icon": "📈",
                "apiEndpoints": {
                    "generate": "laporan/generate",
                    "pdf": "laporan/pdf",
                    "excel": "laporan/excel"
                }
            },
            {
                "path": "/admin.html",
                "file": "admin.html",
                "title": "Admin Panel - Arsip Surat Digital Enterprise",
                "requiresAuth": true,
                "permissions": ["admin:access"],
                "icon": "⚙️"
            },
            {
                "path": "/profile.html",
                "file": "profile.html",
                "title": "Profil - Arsip Surat Digital Enterprise",
                "requiresAuth": true,
                "icon": "👤"
            }
        ],
        "error": [
            {
                "path": "/404.html",
                "file": "404.html",
                "title": "404 - Halaman Tidak Ditemukan",
                "requiresAuth": false
            },
            {
                "path": "/offline.html",
                "file": "offline.html",
                "title": "Offline - Arsip Surat Digital Enterprise",
                "requiresAuth": false
            }
        ]
    },
    
    "navigation": {
        "sidebar": [
            { "label": "Dashboard", "icon": "📊", "route": "/dashboard.html", "permission": "dashboard:view" },
            { "label": "Surat Masuk", "icon": "📥", "route": "/surat-masuk.html", "permission": "surat-masuk:read" },
            { "label": "Surat Keluar", "icon": "📤", "route": "/surat-keluar.html", "permission": "surat-keluar:read" },
            { "label": "Disposisi", "icon": "📋", "route": "/disposisi.html", "permission": "disposisi:read" },
            { "label": "Laporan", "icon": "📈", "route": "/laporan.html", "permission": "laporan:read" }
        ],
        "admin": [
            { "label": "Admin Panel", "icon": "⚙️", "route": "/admin.html", "permission": "admin:access" },
            { "label": "Profil Saya", "icon": "👤", "route": "/profile.html" }
        ]
    },
    
    "scripts": {
        "common": [
            "connector.js",
            "error-boundary.js",
            "logger.js",
            "utils.js"
        ],
        "auth": [
            "gas-api.js",
            "database.js",
            "auth-manager.js"
        ],
        "features": [
            "router.js",
            "monitoring.js",
            "cache-manager.js",
            "offline-sync.js"
        ],
        "optional": [
            "websocket.js",
            "i18n.js",
            "theme-manager.js",
            "backup.js",
            "performance.js"
        ],
        "application": [
            "enterprise-core.js",
            "app.js"
        ]
    }
}
