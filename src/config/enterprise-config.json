{
    "system": {
        "name": "Arsip Surat Digital Enterprise",
        "version": "3.0.0",
        "build": "2024.01.15",
        "environment": "production",
        "debug": false,
        "maintenance": false,
        "maintenanceMessage": "Sistem sedang dalam pemeliharaan. Silakan coba beberapa saat lagi."
    },
    
    "api": {
        "googleAppsScript": {
            "primary": "https://script.google.com/macros/s/AKfycbwblauw29Cv8rmrjQHhfXgdl0csBHlxO3xvZJimyBsSyA4F5f9qH25Ej5QYIu--OGy6Bw/exec",
            "fallback": "https://script.google.com/macros/s/AKfycbwblauw29Cv8rmrjQHhfXgdl0csBHlxO3xvZJimyBsSyA4F5f9qH25Ej5QYIu--OGy6Bw/exec",
            "timeout": 30000,
            "retryAttempts": 3,
            "retryDelay": 1000,
            "useBase64": true
        },
        "endpoints": {
            "auth": {
                "login": "auth/login",
                "logout": "auth/logout",
                "refresh": "auth/refresh",
                "verify": "auth/verify"
            },
            "suratMasuk": {
                "list": "surat-masuk/list",
                "detail": "surat-masuk/detail",
                "create": "surat-masuk/create",
                "update": "surat-masuk/update",
                "delete": "surat-masuk/delete"
            },
            "suratKeluar": {
                "list": "surat-keluar/list",
                "detail": "surat-keluar/detail",
                "create": "surat-keluar/create",
                "update": "surat-keluar/update",
                "delete": "surat-keluar/delete"
            },
            "disposisi": {
                "list": "disposisi/list",
                "detail": "disposisi/detail",
                "create": "disposisi/create",
                "update": "disposisi/update"
            },
            "laporan": {
                "generate": "laporan/generate",
                "exportPdf": "laporan/export-pdf",
                "exportExcel": "laporan/export-excel"
            },
            "dashboard": {
                "stats": "dashboard/stats",
                "chartData": "dashboard/chart-data"
            }
        }
    },
    
    "database": {
        "name": "ArsipSuratEnterprise",
        "version": 3,
        "tables": [
            "tbl_users",
            "tbl_instansi",
            "tbl_roles",
            "tbl_permissions",
            "tbl_surat_masuk",
            "tbl_surat_keluar",
            "tbl_disposisi",
            "tbl_attachments",
            "tbl_activity_logs",
            "tbl_settings",
            "tbl_notifications"
        ]
    },
    
    "security": {
        "tokenExpiry": 86400,
        "refreshTokenExpiry": 604800,
        "maxLoginAttempts": 5,
        "lockoutDuration": 900,
        "sessionTimeout": 3600,
        "encryptionEnabled": true,
        "csrfProtection": true,
        "corsEnabled": true,
        "allowedOrigins": ["*"]
    },
    
    "features": {
        "multiInstansi": true,
        "rbac": true,
        "auditTrail": true,
        "notifications": true,
        "exportPdf": true,
        "exportExcel": true,
        "qrCode": true,
        "digitalSign": false,
        "apiAccess": true,
        "backupSystem": true,
        "offlineMode": true,
        "pwaEnabled": true,
        "darkMode": false,
        "multiLanguage": false
    },
    
    "ui": {
        "theme": "light",
        "primaryColor": "#1a56db",
        "secondaryColor": "#64748b",
        "sidebarCollapsed": false,
        "tablePageSize": 25,
        "dateFormat": "DD/MM/YYYY",
        "timeFormat": "HH:mm",
        "currency": "IDR",
        "language": "id",
        "timezone": "Asia/Jakarta"
    },
    
    "notifications": {
        "email": {
            "enabled": false,
            "smtp": {
                "host": "",
                "port": 587,
                "secure": true,
                "auth": {
                    "user": "",
                    "pass": ""
                }
            }
        },
        "push": {
            "enabled": true,
            "vapidPublicKey": ""
        }
    },
    
    "backup": {
        "enabled": true,
        "schedule": "0 0 * * *",
        "retentionDays": 30,
        "includeFiles": true
    },
    
    "logging": {
        "level": "info",
        "console": true,
        "remote": true,
        "remoteEndpoint": "logs/create"
    }
}
