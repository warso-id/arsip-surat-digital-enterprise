<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sitemap - Arsip Surat Digital Enterprise</title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml;base64,">
    <style>
        :root {
            --primary: #1a56db; --secondary: #64748b; --dark: #1f2937;
            --light: #f9fafb; --lighter: #ffffff; --border: #e5e7eb;
            --font-sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: var(--font-sans); background: var(--light); color: var(--dark); }
        
        .header { background: linear-gradient(135deg, var(--primary), #7c3aed); color: white; padding: 40px 20px; text-align: center; }
        .header h1 { font-size: 28px; font-weight: 800; }
        
        .container { max-width: 900px; margin: 40px auto; padding: 0 20px; }
        .back-link { display: inline-flex; align-items: center; gap: 8px; color: var(--primary); text-decoration: none; font-weight: 600; margin-bottom: 20px; }
        
        .sitemap-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; }
        .sitemap-section { background: var(--lighter); border-radius: 12px; padding: 20px 25px; border: 1px solid var(--border); }
        .sitemap-title { font-size: 16px; font-weight: 700; margin-bottom: 12px; color: var(--primary); }
        .sitemap-list { list-style: none; }
        .sitemap-item { padding: 6px 0; }
        .sitemap-item a { color: var(--dark); text-decoration: none; font-size: 14px; }
        .sitemap-item a:hover { color: var(--primary); text-decoration: underline; }
        .sitemap-item .icon { margin-right: 6px; }
        
        @media (max-width: 768px) { .header h1 { font-size: 24px; } }
    </style>
</head>
<body>
    <div class="header">
        <h1>🗺️ Sitemap</h1>
        <p style="opacity: 0.9;">Struktur Halaman Arsip Surat Digital Enterprise</p>
    </div>
    
    <div class="container">
        <a href="/" class="back-link">← Kembali ke Beranda</a>
        
        <div class="sitemap-grid">
            <div class="sitemap-section">
                <div class="sitemap-title">🏠 Umum</div>
                <ul class="sitemap-list">
                    <li class="sitemap-item"><a href="/"><span class="icon">🏠</span> Beranda</a></li>
                    <li class="sitemap-item"><a href="/login"><span class="icon">🔐</span> Login</a></li>
                    <li class="sitemap-item"><a href="/register"><span class="icon">📝</span> Register</a></li>
                    <li class="sitemap-item"><a href="/help"><span class="icon">🆘</span> Bantuan</a></li>
                    <li class="sitemap-item"><a href="/sitemap"><span class="icon">🗺️</span> Sitemap</a></li>
                </ul>
            </div>
            
            <div class="sitemap-section">
                <div class="sitemap-title">📊 Dashboard</div>
                <ul class="sitemap-list">
                    <li class="sitemap-item"><a href="/dashboard"><span class="icon">📊</span> Dashboard</a></li>
                    <li class="sitemap-item"><a href="/dashboard/statistik"><span class="icon">📈</span> Statistik</a></li>
                </ul>
            </div>
            
            <div class="sitemap-section">
                <div class="sitemap-title">📥 Surat Masuk</div>
                <ul class="sitemap-list">
                    <li class="sitemap-item"><a href="/surat-masuk"><span class="icon">📋</span> Daftar Surat Masuk</a></li>
                    <li class="sitemap-item"><a href="/surat-masuk/create"><span class="icon">➕</span> Tambah Surat Masuk</a></li>
                </ul>
            </div>
            
            <div class="sitemap-section">
                <div class="sitemap-title">📤 Surat Keluar</div>
                <ul class="sitemap-list">
                    <li class="sitemap-item"><a href="/surat-keluar"><span class="icon">📋</span> Daftar Surat Keluar</a></li>
                    <li class="sitemap-item"><a href="/surat-keluar/create"><span class="icon">➕</span> Buat Surat Keluar</a></li>
                </ul>
            </div>
            
            <div class="sitemap-section">
                <div class="sitemap-title">📋 Disposisi</div>
                <ul class="sitemap-list">
                    <li class="sitemap-item"><a href="/disposisi"><span class="icon">📋</span> Daftar Disposisi</a></li>
                </ul>
            </div>
            
            <div class="sitemap-section">
                <div class="sitemap-title">📊 Laporan</div>
                <ul class="sitemap-list">
                    <li class="sitemap-item"><a href="/laporan"><span class="icon">📊</span> Laporan</a></li>
                    <li class="sitemap-item"><a href="/laporan/surat-masuk"><span class="icon">📥</span> Laporan Surat Masuk</a></li>
                    <li class="sitemap-item"><a href="/laporan/surat-keluar"><span class="icon">📤</span> Laporan Surat Keluar</a></li>
                </ul>
            </div>
            
            <div class="sitemap-section">
                <div class="sitemap-title">👥 Pengguna</div>
                <ul class="sitemap-list">
                    <li class="sitemap-item"><a href="/pengguna"><span class="icon">👥</span> Manajemen Pengguna</a></li>
                    <li class="sitemap-item"><a href="/profile"><span class="icon">👤</span> Profil Saya</a></li>
                </ul>
            </div>
            
            <div class="sitemap-section">
                <div class="sitemap-title">⚙️ Admin</div>
                <ul class="sitemap-list">
                    <li class="sitemap-item"><a href="/admin/dashboard"><span class="icon">📊</span> Admin Dashboard</a></li>
                    <li class="sitemap-item"><a href="/admin/users"><span class="icon">👥</span> Kelola Pengguna</a></li>
                    <li class="sitemap-item"><a href="/admin/instansi"><span class="icon">🏢</span> Kelola Instansi</a></li>
                    <li class="sitemap-item"><a href="/admin/audit-log"><span class="icon">📋</span> Audit Log</a></li>
                    <li class="sitemap-item"><a href="/admin/backup"><span class="icon">💾</span> Backup</a></li>
                </ul>
            </div>
        </div>
    </div>
</body>
</html>
