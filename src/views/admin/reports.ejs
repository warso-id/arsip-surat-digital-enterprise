<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reports - Admin Panel</title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml;base64,">
    <style>
        :root {
            --primary: #1a56db; --secondary: #64748b; --success: #10b981;
            --warning: #f59e0b; --danger: #ef4444; --dark: #1f2937;
            --darker: #111827; --light: #f9fafb; --lighter: #ffffff; --border: #e5e7eb;
            --font-sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            --shadow: 0 4px 6px rgba(0,0,0,0.1); --radius: 10px; --radius-lg: 16px;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: var(--font-sans); background: var(--light); color: var(--dark); display: flex; min-height: 100vh; }
        
        .sidebar { width: 260px; background: var(--darker); color: white; position: fixed; top: 0; left: 0; bottom: 0; }
        .sidebar-header { padding: 20px; border-bottom: 1px solid #374151; font-weight: 700; }
        .sidebar-nav { padding: 20px 0; }
        .nav-item { display: flex; align-items: center; gap: 12px; padding: 12px 20px; color: #9ca3af; text-decoration: none; font-size: 14px; border-left: 3px solid transparent; }
        .nav-item:hover { background: rgba(255,255,255,0.05); color: white; }
        .nav-item.active { background: rgba(26,86,219,0.2); color: white; border-left-color: var(--primary); }
        
        .main-content { flex: 1; margin-left: 260px; padding: 30px; }
        .page-title { font-size: 24px; font-weight: 800; margin-bottom: 30px; }
        
        .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; margin-bottom: 30px; }
        .stat-card { background: var(--lighter); border-radius: var(--radius); padding: 20px; border: 1px solid var(--border); text-align: center; }
        .stat-value { font-size: 32px; font-weight: 800; }
        .stat-label { font-size: 12px; color: var(--secondary); margin-top: 4px; }
        
        .report-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px; }
        .report-card { background: var(--lighter); border-radius: var(--radius-lg); padding: 25px; border: 1px solid var(--border); cursor: pointer; transition: all 0.3s; }
        .report-card:hover { box-shadow: var(--shadow); transform: translateY(-3px); border-color: var(--primary); }
        .report-icon { font-size: 48px; margin-bottom: 12px; }
        .report-title { font-size: 18px; font-weight: 700; margin-bottom: 6px; }
        .report-desc { font-size: 13px; color: var(--secondary); }
        
        .btn { display: inline-flex; align-items: center; gap: 8px; padding: 10px 20px; border: 2px solid transparent; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; text-decoration: none; transition: all 0.3s; font-family: var(--font-sans); }
        .btn-primary { background: var(--primary); color: white; border-color: var(--primary); }
        .btn-primary:hover { background: #1e40af; transform: translateY(-2px); }
        
        @media (max-width: 768px) { .sidebar { display: none; } .main-content { margin-left: 0; padding: 20px; } }
    </style>
</head>
<body>
    <aside class="sidebar">
        <div class="sidebar-header">⚙️ Admin Panel</div>
        <nav class="sidebar-nav">
            <a href="./dashboard.ejs" class="nav-item">📊 Dashboard</a>
            <a href="./users/index.ejs" class="nav-item">👥 Pengguna</a>
            <a href="./instansi/index.ejs" class="nav-item">🏢 Instansi</a>
            <a href="./reports.ejs" class="nav-item active">📈 Reports</a>
            <a href="./audit-log.ejs" class="nav-item">📋 Audit Log</a>
            <a href="../../login" class="nav-item" style="color: #ef4444; margin-top: 20px;">🚪 Logout</a>
        </nav>
    </aside>
    
    <main class="main-content">
        <h1 class="page-title">📈 Admin Reports</h1>
        
        <div class="stats-grid">
            <div class="stat-card"><div class="stat-value" style="color: var(--primary);">2,458</div><div class="stat-label">Total Surat</div></div>
            <div class="stat-card"><div class="stat-value" style="color: var(--success);">45</div><div class="stat-label">Pengguna Aktif</div></div>
            <div class="stat-card"><div class="stat-value" style="color: var(--warning);">3</div><div class="stat-label">Instansi</div></div>
            <div class="stat-card"><div class="stat-value" style="color: var(--danger);">12</div><div class="stat-label">Error (24h)</div></div>
        </div>
        
        <div class="report-grid">
            <div class="report-card" onclick="window.location.href='../laporan/surat-masuk.ejs'">
                <div class="report-icon">📥</div>
                <div class="report-title">Laporan Surat Masuk</div>
                <div class="report-desc">Rekap semua surat masuk per periode</div>
            </div>
            <div class="report-card" onclick="window.location.href='../laporan/surat-keluar.ejs'">
                <div class="report-icon">📤</div>
                <div class="report-title">Laporan Surat Keluar</div>
                <div class="report-desc">Rekap semua surat keluar per periode</div>
            </div>
            <div class="report-card" onclick="window.location.href='../laporan/disposisi.ejs'">
                <div class="report-icon">📋</div>
                <div class="report-title">Laporan Disposisi</div>
                <div class="report-desc">Rekap status dan tracking disposisi</div>
            </div>
            <div class="report-card" onclick="exportAll()">
                <div class="report-icon">📊</div>
                <div class="report-title">Rekap Semua</div>
                <div class="report-desc">Gabungan semua laporan dalam satu file</div>
            </div>
            <div class="report-card" onclick="window.location.href='./audit-log.ejs'">
                <div class="report-icon">📋</div>
                <div class="report-title">Audit Trail Report</div>
                <div class="report-desc">Log aktivitas semua pengguna</div>
            </div>
            <div class="report-card" onclick="window.location.href='./system-info.ejs'">
                <div class="report-icon">ℹ️</div>
                <div class="report-title">System Report</div>
                <div class="report-desc">Informasi sistem dan performa</div>
            </div>
        </div>
    </main>
    
    <script>
        function exportAll() { alert('Exporting complete report...'); }
        document.addEventListener('DOMContentLoaded', () => {
            if (!localStorage.getItem('auth_token')) window.location.href = '../../login';
        });
    </script>
</body>
</html>
