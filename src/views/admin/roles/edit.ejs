<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Role - Admin Panel</title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml;base64,">
    <style>
        :root {
            --primary: #1a56db; --primary-dark: #1e40af; --secondary: #64748b;
            --dark: #1f2937; --darker: #111827; --light: #f9fafb;
            --lighter: #ffffff; --border: #e5e7eb;
            --font-sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            --shadow: 0 4px 6px rgba(0,0,0,0.1); --transition: all 0.3s ease;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: var(--font-sans); background: var(--light); color: var(--dark); display: flex; min-height: 100vh; }
        
        .sidebar { width: 260px; background: var(--darker); color: white; position: fixed; top: 0; left: 0; bottom: 0; }
        .sidebar-header { padding: 20px; border-bottom: 1px solid #374151; }
        .sidebar-nav { padding: 20px 0; }
        .nav-item { display: flex; align-items: center; gap: 12px; padding: 12px 20px; color: #9ca3af; text-decoration: none; font-size: 14px; border-left: 3px solid transparent; }
        .nav-item:hover { background: rgba(255,255,255,0.05); color: white; }
        .nav-item.active { background: rgba(26,86,219,0.2); color: white; border-left-color: var(--primary); }
        
        .main-content { flex: 1; margin-left: 260px; padding: 30px; max-width: 800px; }
        .page-header { display: flex; align-items: center; gap: 20px; margin-bottom: 25px; }
        .back-btn { text-decoration: none; color: var(--secondary); font-size: 20px; }
        .page-title { font-size: 24px; font-weight: 800; }
        
        .form-card { background: var(--lighter); border-radius: 16px; padding: 30px; border: 1px solid var(--border); box-shadow: var(--shadow); margin-bottom: 20px; }
        .card-title { font-size: 16px; font-weight: 700; margin-bottom: 20px; display: flex; align-items: center; gap: 10px; }
        .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
        .form-group { margin-bottom: 20px; }
        .form-group.full-width { grid-column: 1 / -1; }
        .form-label { display: block; font-size: 14px; font-weight: 600; margin-bottom: 6px; }
        .form-input, .form-select, .form-textarea { width: 100%; padding: 10px 14px; border: 1px solid var(--border); border-radius: 8px; font-size: 14px; font-family: var(--font-sans); background: var(--light); }
        .form-input:focus, .form-select:focus, .form-textarea:focus { outline: none; border-color: var(--primary); box-shadow: 0 0 0 3px rgba(26,86,219,0.1); }
        .form-textarea { min-height: 60px; resize: vertical; }
        .form-input:disabled { background: #f3f4f6; }
        
        .btn { display: inline-flex; align-items: center; gap: 8px; padding: 10px 20px; border: 2px solid transparent; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; text-decoration: none; transition: var(--transition); font-family: var(--font-sans); }
        .btn-primary { background: var(--primary); color: white; border-color: var(--primary); }
        .btn-primary:hover { background: var(--primary-dark); transform: translateY(-2px); }
        .btn-outline { background: transparent; color: var(--secondary); border-color: var(--border); }
        .form-actions { display: flex; gap: 15px; justify-content: flex-end; margin-top: 20px; }
        
        .permission-group { margin-bottom: 20px; }
        .permission-group-title { font-size: 14px; font-weight: 700; margin-bottom: 10px; color: var(--primary); }
        .permission-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 8px; }
        .permission-item { display: flex; align-items: center; gap: 8px; font-size: 13px; padding: 6px 0; }
        .permission-item input[type="checkbox"] { width: 16px; height: 16px; accent-color: var(--primary); }
        
        @media (max-width: 768px) { .sidebar { display: none; } .main-content { margin-left: 0; padding: 20px; } .form-card { padding: 20px; } .form-grid { grid-template-columns: 1fr; } .form-actions { flex-direction: column; } .btn { width: 100%; justify-content: center; } }
    </style>
</head>
<body>
    <aside class="sidebar">
        <div class="sidebar-header">⚙️ Admin Panel</div>
        <nav class="sidebar-nav">
            <a href="../dashboard.ejs" class="nav-item">📊 Dashboard</a>
            <a href="../users/index.ejs" class="nav-item">👥 Pengguna</a>
            <a href="./index.ejs" class="nav-item active">🔑 Role</a>
            <a href="../../../login" class="nav-item" style="color: #ef4444;">🚪 Logout</a>
        </nav>
    </aside>
    
    <main class="main-content">
        <div class="page-header">
            <a href="./index.ejs" class="back-btn">←</a>
            <h1 class="page-title">✏️ Edit Role: Operator</h1>
        </div>
        
        <form class="form-card">
            <h3 class="card-title">📋 Informasi Role</h3>
            <div class="form-grid">
                <div class="form-group"><label class="form-label">Kode Role</label><input type="text" class="form-input" value="operator" disabled></div>
                <div class="form-group"><label class="form-label">Nama Role</label><input type="text" class="form-input" value="Operator"></div>
                <div class="form-group full-width"><label class="form-label">Deskripsi</label><textarea class="form-textarea">Menginput dan memproses surat masuk dan keluar. Dapat membuat dan mengedit surat.</textarea></div>
            </div>
        </form>
        
        <form class="form-card">
            <h3 class="card-title">🔑 Izin Akses</h3>
            
            <div class="permission-group">
                <div class="permission-group-title">📥 Surat Masuk</div>
                <div class="permission-grid">
                    <label class="permission-item"><input type="checkbox" checked> Lihat Surat Masuk</label>
                    <label class="permission-item"><input type="checkbox" checked> Tambah Surat Masuk</label>
                    <label class="permission-item"><input type="checkbox" checked> Edit Surat Masuk</label>
                    <label class="permission-item"><input type="checkbox"> Hapus Surat Masuk</label>
                    <label class="permission-item"><input type="checkbox" checked> Upload Lampiran</label>
                    <label class="permission-item"><input type="checkbox" checked> Download Lampiran</label>
                </div>
            </div>
            
            <div class="permission-group">
                <div class="permission-group-title">📤 Surat Keluar</div>
                <div class="permission-grid">
                    <label class="permission-item"><input type="checkbox" checked> Lihat Surat Keluar</label>
                    <label class="permission-item"><input type="checkbox" checked> Buat Surat Keluar</label>
                    <label class="permission-item"><input type="checkbox" checked> Edit Surat Keluar</label>
                    <label class="permission-item"><input type="checkbox"> Hapus Surat Keluar</label>
                </div>
            </div>
            
            <div class="permission-group">
                <div class="permission-group-title">📋 Disposisi</div>
                <div class="permission-grid">
                    <label class="permission-item"><input type="checkbox" checked> Lihat Disposisi</label>
                    <label class="permission-item"><input type="checkbox" checked> Buat Disposisi</label>
                    <label class="permission-item"><input type="checkbox" checked> Update Status Disposisi</label>
                </div>
            </div>
            
            <div class="permission-group">
                <div class="permission-group-title">📊 Laporan</div>
                <div class="permission-grid">
                    <label class="permission-item"><input type="checkbox" checked> Lihat Laporan</label>
                    <label class="permission-item"><input type="checkbox"> Export PDF</label>
                    <label class="permission-item"><input type="checkbox"> Export Excel</label>
                </div>
            </div>
            
            <div class="permission-group">
                <div class="permission-group-title">⚙️ Lainnya</div>
                <div class="permission-grid">
                    <label class="permission-item"><input type="checkbox" checked> Pencarian</label>
                    <label class="permission-item"><input type="checkbox"> Kelola Pengguna</label>
                    <label class="permission-item"><input type="checkbox"> Kelola Instansi</label>
                    <label class="permission-item"><input type="checkbox"> Pengaturan Sistem</label>
                </div>
            </div>
            
            <div class="form-actions">
                <a href="./index.ejs" class="btn btn-outline">Batal</a>
                <button type="submit" class="btn btn-primary">💾 Simpan Role</button>
            </div>
        </form>
    </main>
    
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            if (!localStorage.getItem('auth_token')) window.location.href = '../../../login';
        });
    </script>
</body>
</html>
