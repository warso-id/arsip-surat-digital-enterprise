<!-- File Preview Component -->
<div class="file-preview">
    <% if (type === 'image') { %>
        <img src="<%= url %>" alt="Preview" class="preview-image" onclick="openFullscreen('<%= url %>')">
    <% } else if (type === 'pdf') { %>
        <iframe src="<%= url %>" class="preview-pdf"></iframe>
    <% } else { %>
        <div class="preview-generic">
            <div class="preview-icon">📄</div>
            <div class="preview-name"><%= name || 'File' %></div>
            <div class="preview-size"><%= size || 'Unknown size' %></div>
            <a href="<%= url %>" class="preview-download" download>⬇️ Download</a>
        </div>
    <% } %>
</div>

<style>
    .file-preview { border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
    .preview-image { width: 100%; max-height: 400px; object-fit: contain; cursor: pointer; }
    .preview-pdf { width: 100%; height: 500px; border: none; }
    .preview-generic { text-align: center; padding: 60px 20px; }
    .preview-icon { font-size: 64px; margin-bottom: 16px; }
    .preview-name { font-size: 16px; font-weight: 600; margin-bottom: 4px; }
    .preview-size { font-size: 13px; color: #64748b; margin-bottom: 16px; }
    .preview-download { display: inline-flex; align-items: center; gap: 6px; padding: 10px 20px; background: #1a56db; color: white; border-radius: 8px; text-decoration: none; font-weight: 600; font-size: 14px; }
    .preview-download:hover { background: #1e40af; }
</style>

<script>
    function openFullscreen(url) {
        const win = window.open(url, '_blank');
        if (win) win.focus();
    }
</script>
