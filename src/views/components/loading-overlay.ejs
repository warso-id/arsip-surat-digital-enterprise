<!-- Loading Overlay Component -->
<div class="loading-overlay" id="<%= id || 'loading' %>" style="display:none">
    <div class="loading-card">
        <div class="loading-spinner-lg"></div>
        <p class="loading-message"><%= message || 'Memproses...' %></p>
        <% if (showProgress) { %>
            <div class="loading-progress"><div class="loading-progress-bar" style="width:<%= progress || 0 %>%"></div></div>
            <span class="loading-percent"><%= progress || 0 %>%</span>
        <% } %>
    </div>
</div>

<style>
    .loading-overlay { position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(255,255,255,0.9);z-index:9999;display:flex;align-items:center;justify-content:center }
    .loading-card { text-align:center;background:white;padding:40px;border-radius:16px;box-shadow:0 10px 40px rgba(0,0,0,0.1) }
    .loading-spinner-lg { width:48px;height:48px;border:4px solid #e5e7eb;border-top-color:#1a56db;border-radius:50%;animation:spin 0.8s linear infinite;margin:0 auto 16px }
    @keyframes spin{to{transform:rotate(360deg)}}
    .loading-message { font-size:15px;color:#374151;font-weight:500 }
    .loading-progress { width:200px;height:6px;background:#e5e7eb;border-radius:3px;overflow:hidden;margin:12px auto 8px }
    .loading-progress-bar { height:100%;background:#1a56db;border-radius:3px;transition:width 0.3s }
    .loading-percent { font-size:12px;color:#64748b }
</style>

<script>
    function showLoading(id) { document.getElementById(id).style.display = 'flex' }
    function hideLoading(id) { document.getElementById(id).style.display = 'none' }
</script>
