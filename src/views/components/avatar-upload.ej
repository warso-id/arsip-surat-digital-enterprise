<!-- Avatar Upload Component -->
<div class="avatar-upload">
    <div class="avatar-preview" id="<%= id || 'avatar' %>Preview" 
         onclick="document.getElementById('<%= id || 'avatar' %>Input').click()">
        <img src="<%= currentAvatar || 'data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHZpZXdCb3g9IjAgMCAxMDAgMTAwIj48cmVjdCB3aWR0aD0iMTAwIiBoZWlnaHQ9IjEwMCIgZmlsbD0iI2U1ZTdlYiIvPjx0ZXh0IHg9IjUwIiB5PSI2NSIgZm9udC1mYW1pbHk9IkFyaWFsIiBmb250LXNpemU9IjQwIiBmaWxsPSIjOWNhM2FmIiB0ZXh0LWFuY2hvcj0ibWlkZGxlIj4/PC90ZXh0Pjwvc3ZnPg==' %>" 
             alt="Avatar" class="avatar-image">
        <div class="avatar-overlay">
            <span>📷</span>
        </div>
    </div>
    <input type="file" id="<%= id || 'avatar' %>Input" accept="image/*" 
           onchange="previewAvatar(this, '<%= id || 'avatar' %>Preview')" style="display: none;">
    <p class="avatar-hint">Klik untuk upload foto</p>
    <p class="avatar-hint">Max 2MB (JPG, PNG)</p>
</div>

<style>
    .avatar-upload { text-align: center; }
    .avatar-preview {
        width: 120px; height: 120px; border-radius: 50%;
        margin: 0 auto 10px; cursor: pointer; position: relative;
        overflow: hidden; border: 3px solid #e5e7eb; transition: all 0.3s;
    }
    .avatar-preview:hover { border-color: #1a56db; }
    .avatar-preview:hover .avatar-overlay { opacity: 1; }
    .avatar-image { width: 100%; height: 100%; object-fit: cover; }
    .avatar-overlay {
        position: absolute; top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(0,0,0,0.5); display: flex; align-items: center;
        justify-content: center; opacity: 0; transition: all 0.3s;
        font-size: 24px; color: white;
    }
    .avatar-hint { font-size: 12px; color: #9ca3af; }
</style>

<script>
    function previewAvatar(input, previewId) {
        const file = input.files[0];
        if (!file) return;
        
        if (file.size > 2 * 1024 * 1024) {
            alert('File terlalu besar. Maksimal 2MB.');
            return;
        }
        
        const reader = new FileReader();
        reader.onload = (e) => {
            document.getElementById(previewId).querySelector('.avatar-image').src = e.target.result;
        };
        reader.readAsDataURL(file);
    }
</script>
