<!-- File Upload Component -->
<!-- Usage: <%- include('../components/file-upload', { id: 'fileUpload', accept: '.pdf,.doc,.docx,.jpg,.png', multiple: true, maxSize: 10 }) %> -->

<div class="file-upload-wrapper" id="<%= id || 'fileUpload' %>">
    <!-- Upload Area -->
    <div class="file-upload-area" id="<%= id %>Area" 
         onclick="document.getElementById('<%= id %>Input').click()">
        <div class="file-upload-icon">📤</div>
        <div class="file-upload-text">
            <strong>Klik untuk upload</strong> atau drag & drop file di sini
        </div>
        <div class="file-upload-hint">
            Format: <%= accept || '.pdf, .doc, .docx, .jpg, .png' %> 
            | Maks: <%= maxSize || 10 %>MB
        </div>
    </div>
    
    <!-- Hidden Input -->
    <input type="file" 
           id="<%= id %>Input" 
           <%= multiple ? 'multiple' : '' %>
           accept="<%= accept || '.pdf,.doc,.docx,.jpg,.jpeg,.png' %>"
           style="display: none;"
           onchange="handleFileSelect_<%= id %>(this.files)">
    
    <!-- File List -->
    <div class="file-list" id="<%= id %>List"></div>
    
    <!-- Progress Bar -->
    <div class="file-progress" id="<%= id %>Progress" style="display: none;">
        <div class="progress-bar">
            <div class="progress-fill" id="<%= id %>ProgressFill"></div>
        </div>
        <div class="progress-text" id="<%= id %>ProgressText">0%</div>
    </div>
</div>

<style>
    .file-upload-wrapper { margin-bottom: 20px; }
    .file-upload-area {
        border: 2px dashed #e5e7eb; border-radius: 12px;
        padding: 40px 20px; text-align: center; cursor: pointer;
        transition: all 0.3s ease; background: #f9fafb;
    }
    .file-upload-area:hover {
        border-color: #1a56db; background: #eff6ff;
    }
    .file-upload-area.dragover {
        border-color: #1a56db; background: #dbeafe;
        transform: scale(1.02);
    }
    .file-upload-icon { font-size: 48px; margin-bottom: 10px; }
    .file-upload-text { font-size: 15px; font-weight: 600; color: #1f2937; margin-bottom: 5px; }
    .file-upload-hint { font-size: 12px; color: #64748b; }
    
    .file-list { margin-top: 15px; display: flex; flex-direction: column; gap: 8px; }
    .file-item {
        display: flex; align-items: center; gap: 12px;
        padding: 12px 15px; background: white; border-radius: 8px;
        border: 1px solid #e5e7eb; transition: all 0.2s;
    }
    .file-item:hover { border-color: #3b82f6; }
    .file-item-icon { font-size: 24px; flex-shrink: 0; }
    .file-item-info { flex: 1; min-width: 0; }
    .file-item-name { font-size: 13px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .file-item-size { font-size: 11px; color: #64748b; }
    .file-item-actions { display: flex; gap: 5px; }
    .file-item-btn {
        background: none; border: none; cursor: pointer;
        font-size: 16px; padding: 4px 8px; border-radius: 4px;
        transition: all 0.2s;
    }
    .file-item-btn:hover { background: #f3f4f6; }
    .file-item-btn.remove { color: #ef4444; }
    .file-item-btn.remove:hover { background: #fee2e2; }
    
    .file-progress { margin-top: 10px; }
    .progress-bar { width: 100%; height: 6px; background: #e5e7eb; border-radius: 3px; overflow: hidden; }
    .progress-fill { height: 100%; background: #1a56db; border-radius: 3px; transition: width 0.3s; width: 0; }
    .progress-text { font-size: 11px; color: #64748b; text-align: center; margin-top: 4px; }
</style>

<script>
    // Store uploaded files
    window['<%= id %>Files'] = window['<%= id %>Files'] || [];
    
    // Drag & drop handlers
    (function() {
        const area = document.getElementById('<%= id %>Area');
        if (!area) return;
        
        area.addEventListener('dragover', (e) => {
            e.preventDefault();
            area.classList.add('dragover');
        });
        
        area.addEventListener('dragleave', () => {
            area.classList.remove('dragover');
        });
        
        area.addEventListener('drop', (e) => {
            e.preventDefault();
            area.classList.remove('dragover');
            handleFileSelect_<%= id %>(e.dataTransfer.files);
        });
    })();
    
    function handleFileSelect_<%= id %>(files) {
        const maxSize = <%= maxSize || 10 %> * 1024 * 1024;
        const allowedTypes = '<%= accept || ".pdf,.doc,.docx,.jpg,.jpeg,.png" %>'.split(',');
        
        for (let i = 0; i < files.length; i++) {
            const file = files[i];
            
            // Validate size
            if (file.size > maxSize) {
                alert(`File "${file.name}" terlalu besar. Maksimal ${maxSize / 1024 / 1024}MB.`);
                continue;
            }
            
            // Validate type
            const ext = '.' + file.name.split('.').pop().toLowerCase();
            if (!allowedTypes.includes(ext) && !allowedTypes.includes(file.type)) {
                alert(`Format file "${file.name}" tidak didukung.`);
                continue;
            }
            
            // Add to files array
            window['<%= id %>Files'].push(file);
            addFileToList_<%= id %>(file);
        }
    }
    
    function addFileToList_<%= id %>(file) {
        const list = document.getElementById('<%= id %>List');
        const item = document.createElement('div');
        item.className = 'file-item';
        
        const icon = file.type.startsWith('image/') ? '🖼️' : '📄';
        const size = formatFileSize(file.size);
        
        item.innerHTML = `
            <span class="file-item-icon">${icon}</span>
            <div class="file-item-info">
                <div class="file-item-name" title="${file.name}">${file.name}</div>
                <div class="file-item-size">${size}</div>
            </div>
            <div class="file-item-actions">
                <button class="file-item-btn remove" onclick="removeFile_<%= id %>(this, '${file.name}')" title="Hapus">✕</button>
            </div>
        `;
        
        list.appendChild(item);
    }
    
    function removeFile_<%= id %>(btn, fileName) {
        btn.closest('.file-item').remove();
        window['<%= id %>Files'] = window['<%= id %>Files'].filter(f => f.name !== fileName);
    }
    
    function formatFileSize(bytes) {
        if (bytes === 0) return '0 Bytes';
        const k = 1024;
        const sizes = ['Bytes', 'KB', 'MB', 'GB'];
        const i = Math.floor(Math.log(bytes) / Math.log(k));
        return parseFloat((bytes / Math.pow(k, i)).toFixed(1)) + ' ' + sizes[i];
    }
    
    function getFiles_<%= id %>() {
        return window['<%= id %>Files'];
    }
    
    function clearFiles_<%= id %>() {
        window['<%= id %>Files'] = [];
        document.getElementById('<%= id %>List').innerHTML = '';
    }
</script>
