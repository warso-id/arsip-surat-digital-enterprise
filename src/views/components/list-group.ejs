<!-- List Group Component -->
<div class="list-group">
    <% items.forEach(function(item, index) { %>
        <div class="list-group-item <%= item.active ? 'active' : '' %> <%= item.class || '' %>"
             <%= item.onclick ? 'onclick="' + item.onclick + '"' : '' %>>
            <% if (item.icon) { %><span class="list-item-icon"><%= item.icon %></span><% } %>
            <div class="list-item-content">
                <div class="list-item-title"><%= item.title %></div>
                <% if (item.description) { %><div class="list-item-desc"><%= item.description %></div><% } %>
            </div>
            <% if (item.badge) { %><span class="list-item-badge"><%= item.badge %></span><% } %>
            <% if (item.action) { %><span class="list-item-action"><%= item.action %></span><% } %>
        </div>
    <% }); %>
</div>

<style>
    .list-group { border: 1px solid #e5e7eb; border-radius: 10px; overflow: hidden; }
    .list-group-item {
        display: flex; align-items: center; gap: 12px;
        padding: 14px 16px; background: white; border-bottom: 1px solid #f3f4f6;
        cursor: pointer; transition: all 0.15s;
    }
    .list-group-item:last-child { border-bottom: none; }
    .list-group-item:hover { background: #f9fafb; }
    .list-group-item.active { background: #eff6ff; border-left: 3px solid #1a56db; }
    .list-item-icon { font-size: 20px; width: 28px; text-align: center; flex-shrink: 0; }
    .list-item-content { flex: 1; min-width: 0; }
    .list-item-title { font-size: 14px; font-weight: 500; }
    .list-item-desc { font-size: 12px; color: #64748b; margin-top: 2px; }
    .list-item-badge {
        padding: 2px 8px; border-radius: 10px; font-size: 11px;
        background: #e5e7eb; color: #374151; font-weight: 500;
    }
    .list-item-action { color: #1a56db; font-size: 13px; font-weight: 500; }
</style>
