<!-- Confirm Dialog Component -->
<!-- Usage: <%- include('../components/confirm-dialog', { id: 'deleteConfirm', title: 'Konfirmasi Hapus', message: 'Apakah Anda yakin?' }) %> -->

<div class="confirm-overlay" id="<%= id %>" style="display: none;">
    <div class="confirm-dialog">
        <div class="confirm-icon">
            <%= icon || '⚠️' %>
        </div>
        <h3 class="confirm-title"><%= title || 'Konfirmasi' %></h3>
        <p class="confirm-message"><%= message || 'Apakah Anda yakin ingin melanjutkan?' %></p>
        <% if (detail) { %>
            <p class="confirm-detail"><%= detail %></p>
        <% } %>
        <div class="confirm-actions">
            <button class="btn btn-cancel" onclick="closeConfirm('<%= id %>')">
                <%= cancelText || 'Batal' %>
            </button>
            <button class="btn btn-confirm btn-<%= confirmType || 'danger' %>" 
                    onclick="confirmAction('<%= id %>')">
                <%= confirmText || 'Ya, Lanjutkan' %>
            </button>
        </div>
    </div>
</div>

<style>
    .confirm-overlay {
        position: fixed; top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(0,0,0,0.5); z-index: 1000;
        display: flex; align-items: center; justify-content: center;
        animation: fadeIn 0.2s ease;
    }
    .confirm-dialog {
        background: white; border-radius: 16px; padding: 32px;
        width: 90%; max-width: 420px; text-align: center;
        box-shadow: 0 20px 60px rgba(0,0,0,0.2);
        animation: scaleIn 0.2s ease;
    }
    .confirm-icon { font-size: 48px; margin-bottom: 16px; }
    .confirm-title { font-size: 18px; font-weight: 700; margin-bottom: 8px; }
    .confirm-message { font-size: 14px; color: #64748b; margin-bottom: 8px; }
    .confirm-detail { font-size: 12px; color: #9ca3af; margin-bottom: 20px; font-style: italic; }
    .confirm-actions { display: flex; gap: 10px; justify-content: center; }
    
    .btn {
        padding: 10px 24px; border-radius: 8px; font-size: 14px; font-weight: 600;
        cursor: pointer; transition: all 0.2s; border: 2px solid transparent;
        font-family: inherit;
    }
    .btn-cancel { background: #f3f4f6; color: #374151; border-color: #e5e7eb; }
    .btn-cancel:hover { background: #e5e7eb; }
    .btn-confirm { color: white; }
    .btn-danger { background: #ef4444; border-color: #ef4444; }
    .btn-danger:hover { background: #dc2626; }
    .btn-primary { background: #1a56db; border-color: #1a56db; }
    .btn-primary:hover { background: #1e40af; }
    .btn-warning { background: #f59e0b; border-color: #f59e0b; color: #1f2937; }
    .btn-warning:hover { background: #d97706; }
    
    @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    @keyframes scaleIn { from { transform: scale(0.9); opacity: 0; } to { transform: scale(1); opacity: 1; } }
</style>

<script>
    function openConfirm(id) {
        document.getElementById(id).style.display = 'flex';
    }
    function closeConfirm(id) {
        document.getElementById(id).style.display = 'none';
    }
    function confirmAction(id) {
        closeConfirm(id);
        if (typeof window['onConfirm_' + id] === 'function') {
            window['onConfirm_' + id]();
        }
    }
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
            document.querySelectorAll('.confirm-overlay[style*="flex"]').forEach(el => {
                el.style.display = 'none';
            });
        }
    });
</script>
