<!-- Enhanced Pagination Component -->
<% if (totalPages > 1) { %>
<div class="pagination-container">
    <div class="pagination-info">
        Menampilkan <strong><%= startItem %></strong>-<strong><%= endItem %></strong> dari <strong><%= totalItems %></strong>
    </div>
    <nav class="pagination">
        <button class="page-btn" <%= currentPage === 1 ? 'disabled' : '' %> onclick="goToPage(1)">««</button>
        <button class="page-btn" <%= currentPage === 1 ? 'disabled' : '' %> onclick="goToPage(<%= currentPage - 1 %>)">«</button>
        <% for (let i = Math.max(1, currentPage - 2); i <= Math.min(totalPages, currentPage + 2); i++) { %>
            <button class="page-btn <%= i === currentPage ? 'active' : '' %>" onclick="goToPage(<%= i %>)"><%= i %></button>
        <% } %>
        <button class="page-btn" <%= currentPage === totalPages ? 'disabled' : '' %> onclick="goToPage(<%= currentPage + 1 %>)">»</button>
        <button class="page-btn" <%= currentPage === totalPages ? 'disabled' : '' %> onclick="goToPage(<%= totalPages %>)">»»</button>
    </nav>
    <select class="page-size" onchange="changePageSize(this.value)">
        <option value="10" <%= pageSize === 10 ? 'selected' : '' %>>10/hal</option>
        <option value="25" <%= pageSize === 25 ? 'selected' : '' %>>25/hal</option>
        <option value="50" <%= pageSize === 50 ? 'selected' : '' %>>50/hal</option>
        <option value="100" <%= pageSize === 100 ? 'selected' : '' %>>100/hal</option>
    </select>
</div>
<% } %>

<style>
    .pagination-container { display: flex; align-items: center; justify-content: space-between; padding: 16px 0; flex-wrap: wrap; gap: 12px; }
    .pagination-info { font-size: 13px; color: #64748b; }
    .pagination { display: flex; gap: 4px; }
    .page-btn { min-width: 34px; height: 34px; padding: 0 8px; border: 1px solid #e5e7eb; border-radius: 6px; background: white; cursor: pointer; font-size: 13px; font-family: inherit; transition: all 0.15s; }
    .page-btn:hover:not(:disabled) { background: #f9fafb; border-color: #1a56db; }
    .page-btn.active { background: #1a56db; color: white; border-color: #1a56db; }
    .page-btn:disabled { opacity: 0.4; cursor: not-allowed; }
    .page-size { padding: 6px 10px; border: 1px solid #e5e7eb; border-radius: 6px; font-size: 13px; font-family: inherit; }
</style>

<script>
    function goToPage(page) { window.location.href = updateQuery('page', page); }
    function changePageSize(size) { window.location.href = updateQuery('size', size) + '&page=1'; }
    function updateQuery(key, value) {
        const url = new URL(window.location.href);
        url.searchParams.set(key, value);
        return url.toString();
    }
</script>
