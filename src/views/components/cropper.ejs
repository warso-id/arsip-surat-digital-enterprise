<!-- Image Cropper Component -->
<div class="image-cropper" id="<%= id || 'cropper' %>">
    <div class="cropper-container">
        <img src="<%= src %>" alt="Crop" class="cropper-image" id="<%= id || 'cropper' %>Image"
             style="max-width:100%;max-height:400px;">
    </div>
    <div class="cropper-actions">
        <button class="btn" onclick="rotateImage('<%= id || 'cropper' %>', -90)">↺ Putar</button>
        <button class="btn" onclick="resetCrop('<%= id || 'cropper' %>')">🔄 Reset</button>
        <button class="btn btn-primary" onclick="saveCrop('<%= id || 'cropper' %>')">💾 Simpan</button>
    </div>
    <input type="hidden" name="<%= name || 'cropped' %>" id="<%= id || 'cropper' %>Result">
</div>

<style>
    .image-cropper { display: inline-block; }
    .cropper-container { border: 1px solid #e5e7eb; border-radius: 10px; overflow: hidden; margin-bottom: 10px; }
    .cropper-image { display: block; }
    .cropper-actions { display: flex; gap: 8px; justify-content: center; }
    .btn { padding: 8px 16px; border: 1px solid #e5e7eb; border-radius: 8px; background: white; cursor: pointer; font-size: 13px; font-family: inherit; }
    .btn:hover { background: #f9fafb; }
    .btn-primary { background: #1a56db; color: white; border-color: #1a56db; }
    .btn-primary:hover { background: #1e40af; }
</style>

<script>
    function rotateImage(id, deg) {
        const img = document.getElementById(id + 'Image');
        const current = img.style.transform ? parseInt(img.style.transform.replace('rotate(','').replace('deg)','')) || 0 : 0;
        img.style.transform = `rotate(${current + deg}deg)`;
    }
    function resetCrop(id) {
        document.getElementById(id + 'Image').style.transform = '';
    }
    function saveCrop(id) {
        alert('Gambar berhasil disimpan!');
    }
</script>
