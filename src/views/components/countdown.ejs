<!-- Countdown Timer Component -->
<div class="countdown" id="<%= id || 'countdown' %>">
    <div class="countdown-item">
        <span class="countdown-value" id="<%= id || 'countdown' %>Days">00</span>
        <span class="countdown-label">Hari</span>
    </div>
    <div class="countdown-item">
        <span class="countdown-value" id="<%= id || 'countdown' %>Hours">00</span>
        <span class="countdown-label">Jam</span>
    </div>
    <div class="countdown-item">
        <span class="countdown-value" id="<%= id || 'countdown' %>Minutes">00</span>
        <span class="countdown-label">Menit</span>
    </div>
    <div class="countdown-item">
        <span class="countdown-value" id="<%= id || 'countdown' %>Seconds">00</span>
        <span class="countdown-label">Detik</span>
    </div>
</div>

<style>
    .countdown { display: flex; gap: 16px; justify-content: center; }
    .countdown-item { text-align: center; }
    .countdown-value {
        display: block; font-size: 32px; font-weight: 800; color: #1a56db;
        background: #eff6ff; padding: 12px 16px; border-radius: 10px;
        min-width: 70px; font-variant-numeric: tabular-nums;
    }
    .countdown-label { font-size: 12px; color: #64748b; margin-top: 4px; display: block; }
</style>

<script>
    const target_<%= id || 'countdown' %> = new Date('<%= target || '2024-12-31T23:59:59' %>').getTime();
    setInterval(() => {
        const now = Date.now();
        const diff = Math.max(0, target_<%= id || 'countdown' %> - now);
        document.getElementById('<%= id || "countdown" %>Days').textContent = String(Math.floor(diff / 86400000)).padStart(2, '0');
        document.getElementById('<%= id || "countdown" %>Hours').textContent = String(Math.floor((diff % 86400000) / 3600000)).padStart(2, '0');
        document.getElementById('<%= id || "countdown" %>Minutes').textContent = String(Math.floor((diff % 3600000) / 60000)).padStart(2, '0');
        document.getElementById('<%= id || "countdown" %>Seconds').textContent = String(Math.floor((diff % 60000) / 1000)).padStart(2, '0');
    }, 1000);
</script>
