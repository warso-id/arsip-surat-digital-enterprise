<!-- Alert Component -->
<!-- Usage: <%- include('../components/alert', { type: 'success', message: 'Data berhasil disimpan!', dismissible: true }) %> -->

<div class="alert alert-<%= type || 'info' %> <%= dismissible !== false ? 'alert-dismissible' : '' %>" role="alert">
    <div style="display: flex; align-items: center; gap: 0.5rem;">
        <% 
        const icons = {
            success: '✅',
            error: '❌',
            warning: '⚠️',
            info: 'ℹ️'
        };
        %>
        <span><%= icons[type] || icons.info %></span>
        <span><%= message %></span>
    </div>
    <% if (dismissible !== false) { %>
    <button type="button" class="alert-close" onclick="this.parentElement.remove()" aria-label="Close">✕</button>
    <% } %>
</div>

<style>
    .alert {
        padding: 0.75rem 1rem;
        border-radius: 0.5rem;
        margin-bottom: 1rem;
        font-size: 0.875rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .alert-success { background: #f0fdf4; color: #065f46; border: 1px solid #bbf7d0; }
    .alert-error { background: #fef2f2; color: #991b1b; border: 1px solid #fecaca; }
    .alert-warning { background: #fffbeb; color: #92400e; border: 1px solid #fde68a; }
    .alert-info { background: #eff6ff; color: #1e40af; border: 1px solid #bfdbfe; }
    .alert-close {
        background: none;
        border: none;
        cursor: pointer;
        font-size: 1.125rem;
        color: inherit;
        opacity: 0.7;
        padding: 0.25rem;
    }
    .alert-close:hover { opacity: 1; }
</style>
