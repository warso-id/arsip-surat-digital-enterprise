<!-- Pulse Animation Component -->
<span class="pulse <%= color || 'blue' %> <%= size || 'md' %>" title="<%= title || 'Online' %>"></span>

<style>
    .pulse { display:inline-block;border-radius:50%;position:relative }
    .pulse::after { content:'';position:absolute;top:0;left:0;right:0;bottom:0;border-radius:50%;animation:pulse-anim 2s infinite }
    .pulse.sm { width:8px;height:8px }
    .pulse.md { width:12px;height:12px }
    .pulse.lg { width:16px;height:16px }
    .pulse.blue { background:#3b82f6 }
    .pulse.blue::after { box-shadow:0 0 0 0 rgba(59,130,246,0.5) }
    .pulse.green { background:#10b981 }
    .pulse.green::after { box-shadow:0 0 0 0 rgba(16,185,129,0.5) }
    .pulse.red { background:#ef4444 }
    .pulse.red::after { box-shadow:0 0 0 0 rgba(239,68,68,0.5) }
    @keyframes pulse-anim { 0%{transform:scale(1);opacity:1} 100%{transform:scale(3);opacity:0} }
</style>
