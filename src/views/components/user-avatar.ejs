<!-- User Avatar Component -->
<div class="user-avatar-comp <%= size || 'md' %>" title="<%= name || 'User' %>">
    <% if (src) { %>
        <img src="<%= src %>" alt="<%= name %>" class="avatar-img">
    <% } else { %>
        <span class="avatar-initials"><%= (name || 'User').charAt(0).toUpperCase() %></span>
    <% } %>
    <% if (status) { %>
        <span class="avatar-status status-<%= status %>"></span>
    <% } %>
</div>

<style>
    .user-avatar-comp {
        position: relative; display: inline-flex; align-items: center;
        justify-content: center; border-radius: 50%; overflow: visible;
    }
    .user-avatar-comp.sm { width: 28px; height: 28px; }
    .user-avatar-comp.md { width: 40px; height: 40px; }
    .user-avatar-comp.lg { width: 56px; height: 56px; }
    .user-avatar-comp.xl { width: 80px; height: 80px; }
    
    .avatar-img { width: 100%; height: 100%; border-radius: 50%; object-fit: cover; }
    .avatar-initials {
        width: 100%; height: 100%; border-radius: 50%;
        background: linear-gradient(135deg, #1a56db, #7c3aed);
        display: flex; align-items: center; justify-content: center;
        color: white; font-weight: 700;
    }
    .sm .avatar-initials { font-size: 12px; }
    .md .avatar-initials { font-size: 16px; }
    .lg .avatar-initials { font-size: 22px; }
    .xl .avatar-initials { font-size: 32px; }
    
    .avatar-status {
        position: absolute; bottom: 0; right: 0;
        width: 10px; height: 10px; border-radius: 50%;
        border: 2px solid white;
    }
    .sm .avatar-status { width: 7px; height: 7px; }
    .xl .avatar-status { width: 14px; height: 14px; }
    .status-online { background: #10b981; }
    .status-offline { background: #9ca3af; }
    .status-busy { background: #ef4444; }
    .status-away { background: #f59e0b; }
</style>
