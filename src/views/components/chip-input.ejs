<!-- Chip Input Component -->
<div class="chip-input" id="<%= id || 'chipInput' %>">
    <div class="chips-container" id="<%= id || 'chipInput' %>Chips">
        <% (value || '').split(',').filter(Boolean).forEach(function(chip) { %>
            <span class="chip"><%= chip.trim() %><button class="chip-remove" onclick="removeChip(this,'<%= id || 'chipInput' %>')">✕</button></span>
        <% }); %>
    </div>
    <input type="text" class="chip-field" placeholder="<%= placeholder || 'Ketik dan tekan Enter...' %>"
           onkeydown="handleChipInput(event, '<%= id || 'chipInput' %>')">
    <input type="hidden" name="<%= name || 'chips' %>" id="<%= id || 'chipInput' %>Value" value="<%= value || '' %>">
</div>

<style>
    .chip-input { display: flex; flex-wrap: wrap; gap: 6px; align-items: center; padding: 8px 12px; border: 1px solid #e5e7eb; border-radius: 8px; min-height: 44px; background: white; }
    .chip-input:focus-within { border-color: #1a56db; box-shadow: 0 0 0 3px rgba(26,86,219,0.1); }
    .chips-container { display: flex; flex-wrap: wrap; gap: 6px; }
    .chip { display: inline-flex; align-items: center; gap: 4px; padding: 4px 10px; background: #dbeafe; color: #1e40af; border-radius: 16px; font-size: 12px; font-weight: 500; }
    .chip-remove { background: none; border: none; cursor: pointer; font-size: 10px; padding: 0 2px; opacity: 0.6; color: #1e40af; }
    .chip-remove:hover { opacity: 1; }
    .chip-field { border: none; outline: none; flex: 1; min-width: 100px; font-size: 14px; font-family: inherit; }
</style>

<script>
    function handleChipInput(event, id) {
        if (event.key === 'Enter' || event.key === ',') {
            event.preventDefault();
            const value = event.target.value.trim().replace(/,/g, '');
            if (value) addChip(id, value);
            event.target.value = '';
        }
    }
    function addChip(id, text) {
        const container = document.getElementById(id + 'Chips');
        const chip = document.createElement('span');
        chip.className = 'chip';
        chip.innerHTML = `${text}<button class="chip-remove" onclick="removeChip(this,'${id}')">✕</button>`;
        container.appendChild(chip);
        updateChipValue(id);
    }
    function removeChip(btn, id) { btn.parentElement.remove(); updateChipValue(id); }
    function updateChipValue(id) {
        const chips = Array.from(document.getElementById(id + 'Chips').querySelectorAll('.chip')).map(c => c.textContent.replace('✕', '').trim());
        document.getElementById(id + 'Value').value = chips.join(',');
    }
</script>
