<!-- Page Header Component -->
<div class="page-header-comp">
    <div class="page-header-left">
        <% if (backUrl) { %>
            <a href="<%= backUrl %>" class="page-header-back" title="Kembali">←</a>
        <% } %>
        <div>
            <h1 class="page-header-title"><%= title || 'Halaman' %></h1>
            <% if (subtitle) { %>
                <p class="page-header-subtitle"><%= subtitle %></p>
            <% } %>
        </div>
    </div>
    <div class="page-header-actions">
        <% if (typeof actions !== 'undefined') { %>
            <%- actions %>
        <% } %>
    </div>
</div>

<style>
    .page-header-comp {
        display: flex; justify-content: space-between; align-items: center;
        margin-bottom: 24px; flex-wrap: wrap; gap: 16px;
    }
    .page-header-left { display: flex; align-items: center; gap: 16px; }
    .page-header-back {
        text-decoration: none; color: #64748b; font-size: 24px;
        padding: 4px 8px; border-radius: 6px; transition: all 0.2s;
    }
    .page-header-back:hover { background: #f3f4f6; color: #1a56db; }
    .page-header-title { font-size: 22px; font-weight: 800; }
    .page-header-subtitle { font-size: 13px; color: #64748b; margin-top: 2px; }
    .page-header-actions { display: flex; gap: 10px; flex-wrap: wrap; }
</style>
