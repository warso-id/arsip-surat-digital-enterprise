<!-- Stepper Component -->
<div class="stepper">
    <% steps.forEach(function(step, index) { %>
        <div class="stepper-step <%= index < current ? 'completed' : '' %> <%= index === current ? 'active' : '' %>">
            <div class="stepper-indicator">
                <% if (index < current) { %>✓<% } else { %><%= index + 1 %><% } %>
            </div>
            <div class="stepper-label"><%= step %></div>
            <% if (index < steps.length - 1) { %>
                <div class="stepper-line <%= index < current ? 'completed' : '' %>"></div>
            <% } %>
        </div>
    <% }); %>
</div>

<style>
    .stepper { display: flex; align-items: center; justify-content: center; padding: 20px 0; }
    .stepper-step { display: flex; align-items: center; position: relative; }
    .stepper-indicator {
        width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center;
        justify-content: center; font-weight: 700; font-size: 14px; z-index: 1;
        background: #e5e7eb; color: #9ca3af; transition: all 0.3s; flex-shrink: 0;
    }
    .stepper-step.active .stepper-indicator { background: #1a56db; color: white; box-shadow: 0 0 0 4px rgba(26,86,219,0.2); }
    .stepper-step.completed .stepper-indicator { background: #10b981; color: white; }
    .stepper-label { font-size: 12px; font-weight: 500; margin: 0 8px; white-space: nowrap; color: #9ca3af; }
    .stepper-step.active .stepper-label { color: #1a56db; font-weight: 600; }
    .stepper-step.completed .stepper-label { color: #10b981; }
    .stepper-line { flex: 1; height: 2px; min-width: 40px; background: #e5e7eb; margin: 0 8px; }
    .stepper-line.completed { background: #10b981; }
</style>
