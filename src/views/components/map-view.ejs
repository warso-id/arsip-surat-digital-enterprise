<!-- Map View Component -->
<div class="map-view" id="<%= id || 'map' %>" style="height:<%= height || '300px' %>;width:100%;border-radius:12px;background:#f3f4f6;display:flex;align-items:center;justify-content:center;">
    <div style="text-align:center;color:#9ca3af;">
        <div style="font-size:48px;">🗺️</div>
        <p style="margin-top:8px;"><%= address || 'Lokasi tidak tersedia' %></p>
        <% if (lat && lng) { %>
            <a href="https://maps.google.com/?q=<%= lat %>,<%= lng %>" target="_blank" style="color:#1a56db;font-size:13px;">Buka di Google Maps</a>
        <% } %>
    </div>
</div>
