<!-- Tree View Component -->
<div class="tree-view">
    <% function renderTree(nodes) { %>
        <ul class="tree-list">
            <% nodes.forEach(function(node) { %>
                <li class="tree-item">
                    <div class="tree-node" onclick="toggleTreeNode(this)">
                        <% if (node.children && node.children.length > 0) { %>
                            <span class="tree-toggle">▶</span>
                        <% } else { %>
                            <span class="tree-toggle" style="visibility:hidden">▶</span>
                        <% } %>
                        <% if (node.icon) { %><span class="tree-icon"><%= node.icon %></span><% } %>
                        <span class="tree-label"><%= node.label %></span>
                        <% if (node.badge) { %><span class="tree-badge"><%= node.badge %></span><% } %>
                    </div>
                    <% if (node.children && node.children.length > 0) { %>
                        <div class="tree-children" style="display:none">
                            <%- renderTree(node.children) %>
                        </div>
                    <% } %>
                </li>
            <% }); %>
        </ul>
    <% } %>
    <%- renderTree(items) %>
</div>

<style>
    .tree-view { font-size:14px }
    .tree-list { list-style:none;padding-left:0 }
    .tree-item { margin:2px 0 }
    .tree-node { display:flex;align-items:center;gap:6px;padding:6px 8px;border-radius:6px;cursor:pointer;transition:all 0.15s }
    .tree-node:hover { background:#f3f4f6 }
    .tree-toggle { font-size:10px;width:16px;text-align:center;transition:transform 0.2s;color:#9ca3af }
    .tree-toggle.open { transform:rotate(90deg) }
    .tree-icon { font-size:16px;width:20px;text-align:center }
    .tree-label { flex:1 }
    .tree-badge { padding:1px 6px;background:#e5e7eb;border-radius:8px;font-size:11px }
    .tree-children { padding-left:20px }
</style>

<script>
    function toggleTreeNode(node) {
        const toggle = node.querySelector('.tree-toggle');
        const children = node.nextElementSibling;
        if (children && children.classList.contains('tree-children')) {
            const isOpen = children.style.display === 'block';
            children.style.display = isOpen ? 'none' : 'block';
            toggle.classList.toggle('open', !isOpen);
        }
    }
</script>
