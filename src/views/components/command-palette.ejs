<!-- Command Palette Component -->
<div class="cmd-overlay" id="cmdOverlay" style="display: none;" onclick="closeCmdPalette()">
    <div class="cmd-palette" onclick="event.stopPropagation()">
        <div class="cmd-header">
            <span>🔍 Perintah</span>
            <kbd>ESC</kbd>
        </div>
        <input type="text" class="cmd-input" id="cmdInput" placeholder="Ketik perintah..." 
               onkeydown="handleCmdKey(event)" autofocus>
        <div class="cmd-results" id="cmdResults">
            <div class="cmd-item" onclick="navigateTo('/dashboard')">
                <span class="cmd-icon">📊</span> Dashboard
                <kbd>Ctrl+D</kbd>
            </div>
            <div class="cmd-item" onclick="navigateTo('/surat-masuk')">
                <span class="cmd-icon">📥</span> Surat Masuk
                <kbd>Ctrl+M</kbd>
            </div>
            <div class="cmd-item" onclick="navigateTo('/surat-masuk/create')">
                <span class="cmd-icon">➕</span> Tambah Surat Masuk
            </div>
            <div class="cmd-item" onclick="navigateTo('/surat-keluar')">
                <span class="cmd-icon">📤</span> Surat Keluar
            </div>
            <div class="cmd-item" onclick="navigateTo('/disposisi')">
                <span class="cmd-icon">📋</span> Disposisi
            </div>
            <div class="cmd-item" onclick="navigateTo('/laporan')">
                <span class="cmd-icon">📊</span> Laporan
            </div>
            <div class="cmd-item" onclick="navigateTo('/pencarian')">
                <span class="cmd-icon">🔍</span> Pencarian
            </div>
            <div class="cmd-item" onclick="navigateTo('/pengaturan')">
                <span class="cmd-icon">⚙️</span> Pengaturan
            </div>
        </div>
    </div>
</div>

<style>
    .cmd-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 9999; display: flex; justify-content: center; padding-top: 100px; }
    .cmd-palette { background: white; border-radius: 16px; box-shadow: 0 20px 60px rgba(0,0,0,0.3); width: 90%; max-width: 550px; overflow: hidden; }
    .cmd-header { display: flex; justify-content: space-between; align-items: center; padding: 14px 20px; border-bottom: 1px solid #e5e7eb; font-weight: 600; font-size: 14px; }
    .cmd-header kbd { background: #f3f4f6; padding: 2px 8px; border-radius: 4px; font-size: 11px; }
    .cmd-input { width: 100%; padding: 14px 20px; border: none; outline: none; font-size: 15px; font-family: inherit; }
    .cmd-results { max-height: 300px; overflow-y: auto; padding: 4px; }
    .cmd-item { display: flex; align-items: center; gap: 10px; padding: 10px 16px; cursor: pointer; border-radius: 8px; font-size: 14px; transition: all 0.1s; }
    .cmd-item:hover { background: #f3f4f6; }
    .cmd-item kbd { margin-left: auto; background: #f3f4f6; padding: 2px 6px; border-radius: 4px; font-size: 10px; color: #6b7280; }
    .cmd-icon { font-size: 18px; width: 24px; text-align: center; }
</style>

<script>
    function openCmdPalette() { document.getElementById('cmdOverlay').style.display = 'flex'; document.getElementById('cmdInput').focus(); }
    function closeCmdPalette() { document.getElementById('cmdOverlay').style.display = 'none'; }
    function handleCmdKey(e) { if (e.key === 'Escape') closeCmdPalette(); }
    function navigateTo(url) { window.location.href = url; closeCmdPalette(); }
    document.addEventListener('keydown', (e) => { if ((e.ctrlKey || e.metaKey) && e.key === 'k') { e.preventDefault(); openCmdPalette(); } });
</script>
