<!-- Image Upload Component -->
<div class="image-upload" id="<%= id || 'imageUpload' %>">
    <div class="image-upload-area" onclick="document.getElementById('<%= id || 'imageUpload' %>Input').click()">
        <% if (preview) { %>
            <img src="<%= preview %>" alt="Preview" class="image-preview">
            <div class="image-upload-overlay">
                <span>📷 Ganti Gambar</span>
            </div>
        <% } else { %>
            <div class="image-upload-placeholder">
                <div class="upload-icon">📷</div>
                <div class="upload-text">Klik untuk upload gambar</div>
                <div class="upload-hint">Max 5MB (JPG, PNG, GIF, WebP)</div>
            </div>
        <% } %>
    </div>
    <input type="file" id="<%= id || 'imageUpload' %>Input" accept="image/*" 
           onchange="previewImage(this, '<%= id || 'imageUpload' %>')" style="display: none;">
    <% if (preview) { %>
        <button class="image-remove-btn" onclick="removeImage('<%= id || 'imageUpload' %>')">🗑️ Hapus</button>
    <% } %>
</div>

<style>
    .image-upload { position: relative; }
    .image-upload-area {
        border: 2px dashed #e5e7eb; border-radius: 12px; overflow: hidden;
        cursor: pointer; transition: all 0.3s; position: relative;
        min-height: 150px; display: flex; align-items: center; justify-content: center;
    }
    .image-upload-area:hover { border-color: #1a56db; background: #f8faff; }
    .image-preview { width: 100%; max-height: 300px; object-fit: contain; display: block; }
    .image-upload-overlay {
        position: absolute; top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(0,0,0,0.5); display: flex; align-items: center;
        justify-content: center; opacity: 0; transition: all 0.3s;
        color: white; font-weight: 600; font-size: 14px;
    }
    .image-upload-area:hover .image-upload-overlay { opacity: 1; }
    .image-upload-placeholder { text-align: center; padding: 40px; }
    .upload-icon { font-size: 48px; margin-bottom: 10px; }
    .upload-text { font-size: 14px; font-weight: 600; color: #374151; }
    .upload-hint { font-size: 12px; color: #9ca3af; margin-top: 4px; }
    .image-remove-btn {
        margin-top: 8px; padding: 6px 12px; border: 1px solid #ef4444;
        color: #ef4444; background: white; border-radius: 6px;
        cursor: pointer; font-size: 12px; font-family: inherit;
    }
    .image-remove-btn:hover { background: #fef2f2; }
</style>

<script>
    function previewImage(input, id) {
        const file = input.files[0];
        if (!file) return;
        if (file.size > 5 * 1024 * 1024) { alert('File terlalu besar. Max 5MB.'); return; }
        
        const reader = new FileReader();
        reader.onload = (e) => {
            const area = document.getElementById(id).querySelector('.image-upload-area');
            area.innerHTML = `
                <img src="${e.target.result}" alt="Preview" class="image-preview">
                <div class="image-upload-overlay"><span>📷 Ganti Gambar</span></div>
            `;
            const removeBtn = document.getElementById(id).querySelector('.image-remove-btn');
            if (!removeBtn) {
                const btn = document.createElement('button');
                btn.className = 'image-remove-btn';
                btn.textContent = '🗑️ Hapus';
                btn.onclick = () => removeImage(id);
                document.getElementById(id).appendChild(btn);
            }
        };
        reader.readAsDataURL(file);
    }
    
    function removeImage(id) {
        document.getElementById(id + 'Input').value = '';
        const area = document.getElementById(id).querySelector('.image-upload-area');
        area.innerHTML = `
            <div class="image-upload-placeholder">
                <div class="upload-icon">📷</div>
                <div class="upload-text">Klik untuk upload gambar</div>
                <div class="upload-hint">Max 5MB (JPG, PNG, GIF, WebP)</div>
            </div>
        `;
        const removeBtn = document.getElementById(id).querySelector('.image-remove-btn');
        if (removeBtn) removeBtn.remove();
    }
</script>
