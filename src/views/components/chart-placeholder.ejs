<!-- Chart Placeholder Component -->
<div class="chart-placeholder">
    <svg viewBox="0 0 600 250" width="100%" height="250" xmlns="http://www.w3.org/2000/svg">
        <rect width="600" height="250" fill="#f9fafb" rx="8"/>
        <!-- Grid -->
        <line x1="60" y1="30" x2="60" y2="220" stroke="#e5e7eb" stroke-width="1"/>
        <line x1="60" y1="220" x2="580" y2="220" stroke="#e5e7eb" stroke-width="1"/>
        <line x1="60" y1="170" x2="580" y2="170" stroke="#f3f4f6" stroke-width="1" stroke-dasharray="4"/>
        <line x1="60" y1="120" x2="580" y2="120" stroke="#f3f4f6" stroke-width="1" stroke-dasharray="4"/>
        <line x1="60" y1="70" x2="580" y2="70" stroke="#f3f4f6" stroke-width="1" stroke-dasharray="4"/>
        
        <!-- Line Chart -->
        <polyline points="80,180 150,150 220,160 290,110 360,140 430,90 500,130 570,80" 
                  fill="none" stroke="#3b82f6" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
        
        <!-- Data Points -->
        <circle cx="80" cy="180" r="5" fill="#3b82f6"/>
        <circle cx="150" cy="150" r="5" fill="#3b82f6"/>
        <circle cx="220" cy="160" r="5" fill="#3b82f6"/>
        <circle cx="290" cy="110" r="5" fill="#3b82f6"/>
        <circle cx="360" cy="140" r="5" fill="#3b82f6"/>
        <circle cx="430" cy="90" r="5" fill="#3b82f6"/>
        <circle cx="500" cy="130" r="5" fill="#3b82f6"/>
        <circle cx="570" cy="80" r="5" fill="#3b82f6"/>
        
        <!-- Area Fill -->
        <polygon points="80,180 150,150 220,160 290,110 360,140 430,90 500,130 570,80 570,220 80,220" 
                 fill="url(#gradient)" opacity="0.3"/>
        
        <defs>
            <linearGradient id="gradient" x1="0%" y1="0%" x2="0%" y2="100%">
                <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:0.5"/>
                <stop offset="100%" style="stop-color:#3b82f6;stop-opacity:0"/>
            </linearGradient>
        </defs>
        
        <!-- Labels -->
        <text x="80" y="240" font-family="Arial" font-size="10" fill="#64748b" text-anchor="middle">Jan</text>
        <text x="150" y="240" font-family="Arial" font-size="10" fill="#64748b" text-anchor="middle">Feb</text>
        <text x="220" y="240" font-family="Arial" font-size="10" fill="#64748b" text-anchor="middle">Mar</text>
        <text x="290" y="240" font-family="Arial" font-size="10" fill="#64748b" text-anchor="middle">Apr</text>
        <text x="360" y="240" font-family="Arial" font-size="10" fill="#64748b" text-anchor="middle">Mei</text>
        <text x="430" y="240" font-family="Arial" font-size="10" fill="#64748b" text-anchor="middle">Jun</text>
        <text x="500" y="240" font-family="Arial" font-size="10" fill="#64748b" text-anchor="middle">Jul</text>
        <text x="570" y="240" font-family="Arial" font-size="10" fill="#64748b" text-anchor="middle">Agu</text>
    </svg>
</div>

<style>
    .chart-placeholder {
        background: white; border-radius: 12px; padding: 16px;
        border: 1px solid #e5e7eb;
    }
</style>
