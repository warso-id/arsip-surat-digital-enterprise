<!-- Calendar View Component -->
<div class="calendar-view">
    <div class="calendar-header">
        <button class="cal-nav" onclick="changeMonth(-1)">‹</button>
        <h3 id="calMonthYear"><%= month %> <%= year %></h3>
        <button class="cal-nav" onclick="changeMonth(1)">›</button>
    </div>
    <div class="calendar-grid">
        <div class="cal-day-header">Min</div><div class="cal-day-header">Sen</div>
        <div class="cal-day-header">Sel</div><div class="cal-day-header">Rab</div>
        <div class="cal-day-header">Kam</div><div class="cal-day-header">Jum</div>
        <div class="cal-day-header">Sab</div>
        <% for (let i = 0; i < 35; i++) { %>
            <div class="cal-day <%= i >= 5 && i < 20 ? '' : 'other-month' %>">
                <span class="cal-day-num"><%= i >= 5 && i < 20 ? i - 4 : '' %></span>
                <% if (i === 10) { %><div class="cal-event blue">Rapat</div><% } %>
                <% if (i === 15) { %><div class="cal-event green">Deadline</div><% } %>
            </div>
        <% } %>
    </div>
</div>

<style>
    .calendar-view { background:white;border:1px solid #e5e7eb;border-radius:12px;overflow:hidden }
    .calendar-header { display:flex;align-items:center;justify-content:space-between;padding:16px 20px;background:#f9fafb;border-bottom:1px solid #e5e7eb }
    .cal-nav { background:none;border:none;font-size:20px;cursor:pointer;padding:4px 8px;border-radius:4px }
    .cal-nav:hover { background:#e5e7eb }
    .calendar-grid { display:grid;grid-template-columns:repeat(7,1fr) }
    .cal-day-header { text-align:center;padding:10px;font-size:12px;font-weight:600;color:#64748b;background:#f9fafb }
    .cal-day { min-height:80px;padding:6px;border-right:1px solid #f3f4f6;border-bottom:1px solid #f3f4f6;font-size:12px }
    .cal-day:nth-child(7n+1) { border-left:1px solid #f3f4f6 }
    .cal-day.other-month { opacity:0.3 }
    .cal-day-num { display:block;margin-bottom:4px;font-weight:500 }
    .cal-event { padding:2px 6px;border-radius:4px;font-size:10px;font-weight:500;margin-bottom:2px;cursor:pointer }
    .cal-event.blue { background:#dbeafe;color:#1e40af }
    .cal-event.green { background:#d1fae5;color:#065f46 }
</style>

<script>
    function changeMonth(dir) { console.log('Change month:', dir) }
</script>
