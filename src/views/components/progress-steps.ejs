<!-- Progress Steps Component -->
<!-- Usage: <%- include('../components/progress-steps', { steps: ['Input Data', 'Verifikasi', 'Disposisi', 'Selesai'], current: 2 }) %> -->

<div class="progress-steps">
    <% steps.forEach(function(step, index) { 
        const stepNum = index + 1;
        const isCompleted = stepNum < current;
        const isActive = stepNum === current;
        const isPending = stepNum > current;
    %>
        <div class="progress-step <%= isCompleted ? 'completed' : '' %> <%= isActive ? 'active' : '' %>">
            <div class="step-indicator">
                <% if (isCompleted) { %>
                    <span class="step-check">✓</span>
                <% } else { %>
                    <span class="step-number"><%= stepNum %></span>
                <% } %>
            </div>
            <div class="step-label"><%= step %></div>
            <% if (index < steps.length - 1) { %>
                <div class="step-connector <%= isCompleted ? 'completed' : '' %>"></div>
            <% } %>
        </div>
    <% }); %>
</div>

<style>
    .progress-steps {
        display: flex; align-items: flex-start; justify-content: center;
        padding: 20px 0; position: relative;
    }
    .progress-step {
        display: flex; flex-direction: column; align-items: center;
        position: relative; flex: 1; max-width: 150px;
    }
    .step-indicator {
        width: 36px; height: 36px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-weight: 700; font-size: 14px; margin-bottom: 8px;
        background: #e5e7eb; color: #9ca3af; z-index: 1;
        transition: all 0.3s;
    }
    .progress-step.active .step-indicator {
        background: #1a56db; color: white;
        box-shadow: 0 0 0 4px rgba(26,86,219,0.2);
    }
    .progress-step.completed .step-indicator {
        background: #10b981; color: white;
    }
    .step-check { font-size: 16px; }
    .step-number { font-size: 14px; }
    .step-label {
        font-size: 12px; font-weight: 500; text-align: center;
        color: #9ca3af; transition: all 0.3s;
    }
    .progress-step.active .step-label { color: #1a56db; font-weight: 600; }
    .progress-step.completed .step-label { color: #10b981; }
    
    .step-connector {
        position: absolute; top: 18px; left: 50%;
        width: 100%; height: 2px; background: #e5e7eb;
        z-index: 0; transition: all 0.3s;
    }
    .step-connector.completed { background: #10b981; }
    
    @media (max-width: 480px) {
        .step-label { font-size: 10px; }
        .step-indicator { width: 28px; height: 28px; font-size: 12px; }
    }
</style>
