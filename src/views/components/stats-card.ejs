<!-- Statistics Card Component -->
<!-- Usage: <%- include('../components/stats-card', { title: 'Total Surat', value: '1,245', icon: '📥', color: 'blue', change: '+12%', changeType: 'up' }) %> -->

<div class="stats-card stats-<%= color || 'blue' %>">
    <div class="stats-card-header">
        <div class="stats-card-icon">
            <%= icon || '📊' %>
        </div>
        <% if (change) { %>
        <span class="stats-card-change <%= changeType === 'up' ? 'change-up' : 'change-down' %>">
            <%= changeType === 'up' ? '↑' : '↓' %> <%= change %>
        </span>
        <% } %>
    </div>
    <div class="stats-card-value"><%= value || '0' %></div>
    <div class="stats-card-title"><%= title || 'Statistik' %></div>
    <% if (subtitle) { %>
    <div class="stats-card-subtitle"><%= subtitle %></div>
    <% } %>
</div>

<style>
    .stats-card {
        background: white; border-radius: 16px; padding: 24px;
        border: 1px solid #e5e7eb; transition: all 0.3s;
    }
    .stats-card:hover { transform: translateY(-3px); box-shadow: 0 10px 40px rgba(0,0,0,0.1); }
    .stats-card-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 16px; }
    .stats-card-icon { width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 24px; }
    .stats-blue .stats-card-icon { background: #dbeafe; }
    .stats-green .stats-card-icon { background: #d1fae5; }
    .stats-yellow .stats-card-icon { background: #fef3c7; }
    .stats-red .stats-card-icon { background: #fee2e2; }
    .stats-purple .stats-card-icon { background: #e0e7ff; }
    .stats-card-change { font-size: 12px; font-weight: 600; }
    .change-up { color: #10b981; }
    .change-down { color: #ef4444; }
    .stats-card-value { font-size: 28px; font-weight: 800; color: #1f2937; margin-bottom: 4px; }
    .stats-card-title { font-size: 13px; color: #64748b; }
    .stats-card-subtitle { font-size: 11px; color: #9ca3af; margin-top: 4px; }
</style>
