<!-- Footer Component -->
<!-- Usage: <%- include('../components/footer') %> -->

<footer class="app-footer">
    <div class="footer-content">
        <div class="footer-left">
            <span>&copy; <%= currentYear || '2024' %> <%= appName || 'Arsip Surat Digital Enterprise' %></span>
            <span class="footer-separator">|</span>
            <span>v<%= appVersion || '2.1.0' %></span>
        </div>
        <div class="footer-right">
            <a href="/help" class="footer-link">Bantuan</a>
            <a href="/terms" class="footer-link">Syarat & Ketentuan</a>
            <a href="/privacy" class="footer-link">Privasi</a>
            <a href="/docs/" class="footer-link">Dokumentasi</a>
        </div>
    </div>
</footer>

<style>
    .app-footer {
        background: white; border-top: 1px solid #e5e7eb;
        padding: 16px 24px; margin-top: auto;
    }
    .footer-content {
        display: flex; justify-content: space-between; align-items: center;
        flex-wrap: wrap; gap: 8px;
    }
    .footer-left { font-size: 12px; color: #64748b; display: flex; align-items: center; gap: 8px; }
    .footer-separator { color: #d1d5db; }
    .footer-right { display: flex; gap: 16px; }
    .footer-link { font-size: 12px; color: #64748b; text-decoration: none; }
    .footer-link:hover { color: #1a56db; }
    
    @media (max-width: 768px) {
        .footer-content { flex-direction: column; text-align: center; }
    }
</style>
