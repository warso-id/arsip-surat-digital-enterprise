<!-- Export Dropdown Component -->
<div class="export-dropdown">
    <button class="btn-export" onclick="toggleExportMenu()" title="Export Data">
        📥 Export <span class="dropdown-arrow">▾</span>
    </button>
    <div class="export-menu" id="exportMenu" style="display: none;">
        <button class="export-option" onclick="exportData('pdf')">
            <span class="export-icon">📄</span>
            <div>
                <strong>Export PDF</strong>
                <small>Format dokumen cetak</small>
            </div>
        </button>
        <button class="export-option" onclick="exportData('excel')">
            <span class="export-icon">📊</span>
            <div>
                <strong>Export Excel</strong>
                <small>Format spreadsheet</small>
            </div>
        </button>
        <button class="export-option" onclick="exportData('csv')">
            <span class="export-icon">📝</span>
            <div>
                <strong>Export CSV</strong>
                <small>Format comma-separated</small>
            </div>
        </button>
        <button class="export-option" onclick="window.print()">
            <span class="export-icon">🖨️</span>
            <div>
                <strong>Cetak</strong>
                <small>Print langsung</small>
            </div>
        </button>
    </div>
</div>

<style>
    .export-dropdown { position: relative; display: inline-block; }
    .btn-export {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 8px 16px; background: white; border: 1px solid #e5e7eb;
        border-radius: 8px; cursor: pointer; font-size: 13px; font-weight: 500;
        font-family: inherit; transition: all 0.2s;
    }
    .btn-export:hover { background: #f9fafb; border-color: #1a56db; }
    .dropdown-arrow { font-size: 10px; }
    
    .export-menu {
        position: absolute; top: 100%; right: 0; margin-top: 4px;
        background: white; border: 1px solid #e5e7eb; border-radius: 10px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.1); min-width: 220px; z-index: 100;
        overflow: hidden; padding: 4px;
    }
    .export-option {
        display: flex; align-items: center; gap: 10px; width: 100%;
        padding: 10px 14px; border: none; background: none; cursor: pointer;
        text-align: left; font-family: inherit; border-radius: 6px; transition: all 0.15s;
    }
    .export-option:hover { background: #f9fafb; }
    .export-option strong { display: block; font-size: 13px; color: #1f2937; }
    .export-option small { font-size: 11px; color: #9ca3af; }
    .export-icon { font-size: 20px; width: 28px; text-align: center; }
</style>

<script>
    function toggleExportMenu() {
        const menu = document.getElementById('exportMenu');
        menu.style.display = menu.style.display === 'none' ? 'block' : 'none';
    }
    
    function exportData(format) {
        document.getElementById('exportMenu').style.display = 'none';
        alert(`Exporting to ${format.toUpperCase()}...`);
    }
    
    document.addEventListener('click', (e) => {
        if (!e.target.closest('.export-dropdown')) {
            document.getElementById('exportMenu').style.display = 'none';
        }
    });
</script>
