<!-- Carousel Component -->
<div class="carousel" id="<%= id || 'carousel' %>">
    <div class="carousel-track" id="<%= id || 'carousel' %>Track">
        <% slides.forEach(function(slide) { %>
            <div class="carousel-slide">
                <% if (slide.image) { %><img src="<%= slide.image %>" alt="<%= slide.title %>"><% } %>
                <% if (slide.title) { %><div class="carousel-caption"><h3><%= slide.title %></h3><% if (slide.desc) { %><p><%= slide.desc %></p><% } %></div><% } %>
            </div>
        <% }); %>
    </div>
    <button class="carousel-btn carousel-prev" onclick="moveCarousel('<%= id || 'carousel' %>', -1)">‹</button>
    <button class="carousel-btn carousel-next" onclick="moveCarousel('<%= id || 'carousel' %>', 1)">›</button>
    <div class="carousel-dots" id="<%= id || 'carousel' %>Dots"></div>
</div>

<style>
    .carousel { position: relative; overflow: hidden; border-radius: 12px; }
    .carousel-track { display: flex; transition: transform 0.5s ease; }
    .carousel-slide { min-width: 100%; position: relative; }
    .carousel-slide img { width: 100%; height: 300px; object-fit: cover; display: block; }
    .carousel-caption { position: absolute; bottom: 0; left: 0; right: 0; padding: 20px; background: linear-gradient(transparent, rgba(0,0,0,0.7)); color: white; }
    .carousel-caption h3 { font-size: 18px; margin-bottom: 4px; }
    .carousel-caption p { font-size: 13px; opacity: 0.9; }
    .carousel-btn { position: absolute; top: 50%; transform: translateY(-50%); background: rgba(255,255,255,0.8); border: none; width: 40px; height: 40px; border-radius: 50%; font-size: 24px; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.2s; }
    .carousel-btn:hover { background: white; }
    .carousel-prev { left: 10px; }
    .carousel-next { right: 10px; }
    .carousel-dots { display: flex; justify-content: center; gap: 6px; padding: 12px; }
    .carousel-dot { width: 8px; height: 8px; border-radius: 50%; background: #d1d5db; cursor: pointer; transition: all 0.2s; border: none; }
    .carousel-dot.active { background: #1a56db; width: 24px; border-radius: 4px; }
</style>

<script>
    let carouselIndex_<%= id || 'carousel' %> = 0;
    const totalSlides_<%= id || 'carousel' %> = <%= slides.length %>;
    
    function initCarousel(id) {
        const dots = document.getElementById(id + 'Dots');
        for (let i = 0; i < totalSlides_<%= id || 'carousel' %>; i++) {
            const dot = document.createElement('button');
            dot.className = 'carousel-dot ' + (i === 0 ? 'active' : '');
            dot.onclick = () => goToSlide(id, i);
            dots.appendChild(dot);
        }
    }
    
    function moveCarousel(id, dir) {
        carouselIndex_<%= id || 'carousel' %> = (carouselIndex_<%= id || 'carousel' %> + dir + totalSlides_<%= id || 'carousel' %>) % totalSlides_<%= id || 'carousel' %>;
        updateCarousel(id);
    }
    
    function goToSlide(id, index) {
        carouselIndex_<%= id || 'carousel' %> = index;
        updateCarousel(id);
    }
    
    function updateCarousel(id) {
        document.getElementById(id + 'Track').style.transform = `translateX(-${carouselIndex_<%= id || 'carousel' %> * 100}%)`;
        document.querySelectorAll('#' + id + 'Dots .carousel-dot').forEach((d, i) => d.classList.toggle('active', i === carouselIndex_<%= id || 'carousel' %>));
    }
    
    initCarousel('<%= id || "carousel" %>');
    setInterval(() => moveCarousel('<%= id || "carousel" %>', 1), 5000);
</script>
