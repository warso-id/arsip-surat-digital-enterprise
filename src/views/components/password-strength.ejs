<!-- Password Strength Meter -->
<div class="pwd-strength">
    <input type="password" class="form-input" id="<%= id || 'password' %>" 
           placeholder="<%= placeholder || 'Masukkan password' %>"
           onkeyup="checkStrength('<%= id || 'password' %>')">
    <div class="strength-meter">
        <div class="strength-bar" id="<%= id || 'password' %>Bar"></div>
    </div>
    <div class="strength-text" id="<%= id || 'password' %>Text">Masukkan password</div>
    <div class="strength-requirements">
        <span class="req" id="<%= id || 'password' %>Len">❌ Minimal 8 karakter</span>
        <span class="req" id="<%= id || 'password' %>Upper">❌ Huruf besar</span>
        <span class="req" id="<%= id || 'password' %>Lower">❌ Huruf kecil</span>
        <span class="req" id="<%= id || 'password' %>Num">❌ Angka</span>
        <span class="req" id="<%= id || 'password' %>Special">❌ Karakter khusus</span>
    </div>
</div>

<style>
    .pwd-strength { margin-bottom: 16px; }
    .form-input { width: 100%; padding: 10px 14px; border: 1px solid #e5e7eb; border-radius: 8px; font-size: 14px; font-family: inherit; }
    .form-input:focus { outline: none; border-color: #1a56db; }
    .strength-meter { height: 6px; background: #e5e7eb; border-radius: 3px; margin-top: 8px; overflow: hidden; }
    .strength-bar { height: 100%; border-radius: 3px; transition: all 0.3s; width: 0; }
    .strength-text { font-size: 12px; margin-top: 4px; }
    .strength-requirements { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 8px; font-size: 12px; }
    .req { padding: 2px 6px; border-radius: 4px; background: #fee2e2; color: #991b1b; }
    .req.valid { background: #d1fae5; color: #065f46; }
</style>

<script>
    function checkStrength(id) {
        const pwd = document.getElementById(id).value;
        const bar = document.getElementById(id + 'Bar');
        const text = document.getElementById(id + 'Text');
        let score = 0;
        const checks = {
            len: pwd.length >= 8, upper: /[A-Z]/.test(pwd),
            lower: /[a-z]/.test(pwd), num: /[0-9]/.test(pwd),
            special: /[^A-Za-z0-9]/.test(pwd)
        };
        Object.entries(checks).forEach(([k,v]) => { if(v) score++; document.getElementById(id + k.charAt(0).toUpperCase() + k.slice(1)).classList.toggle('valid', v); });
        const colors = ['#ef4444','#f59e0b','#f59e0b','#3b82f6','#10b981','#10b981'];
        const labels = ['Sangat Lemah','Lemah','Sedang','Kuat','Sangat Kuat','Sempurna'];
        bar.style.width = (score/5*100) + '%';
        bar.style.background = colors[score];
        text.textContent = labels[score];
        text.style.color = colors[score];
    }
</script>
