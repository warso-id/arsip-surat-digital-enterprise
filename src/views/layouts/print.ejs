<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle || 'Cetak Dokumen' %></title>
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Times New Roman', Times, serif;
            font-size: 12pt;
            line-height: 1.6;
            color: #000;
            padding: 2cm;
        }
        
        .print-header {
            text-align: center;
            margin-bottom: 2cm;
            border-bottom: 3px double #000;
            padding-bottom: 1cm;
        }
        
        .print-header h1 {
            font-size: 18pt;
            font-weight: bold;
            margin-bottom: 5px;
        }
        
        .print-header h2 {
            font-size: 14pt;
            font-weight: normal;
        }
        
        .print-header p {
            font-size: 11pt;
            color: #333;
        }
        
        .print-content {
            margin: 1cm 0;
        }
        
        .print-content table {
            width: 100%;
            border-collapse: collapse;
            margin: 1cm 0;
        }
        
        .print-content table th,
        .print-content table td {
            border: 1px solid #000;
            padding: 8px;
            text-align: left;
            font-size: 11pt;
        }
        
        .print-content table th {
            background: #f0f0f0;
            font-weight: bold;
        }
        
        .print-footer {
            margin-top: 2cm;
            text-align: right;
        }
        
        .print-footer .signature {
            margin-top: 2cm;
        }
        
        .print-footer .signature p {
            margin-bottom: 3cm;
        }
        
        @media print {
            body {
                padding: 0;
            }
            
            .no-print {
                display: none !important;
            }
        }
        
        .print-button {
            position: fixed;
            top: 20px;
            right: 20px;
            padding: 10px 20px;
            background: #1a73e8;
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-size: 14px;
        }
        
        .print-button:hover {
            background: #1557b0;
        }
    </style>
</head>
<body>
    <button class="print-button no-print" onclick="window.print()">🖨️ Cetak</button>
    
    <%- body %>
    
    <script>
        // Auto print after load
        window.onload = function() {
            setTimeout(function() {
                window.print();
            }, 1000);
        };
    </script>
</body>
</html>
