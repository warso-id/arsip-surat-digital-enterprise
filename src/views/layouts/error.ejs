<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | <%= appName %></title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml;base64,">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: linear-gradient(135deg, #eff6ff 0%, #f0f9ff 50%, #ecfdf5 100%);
            min-height: 100vh; display: flex; align-items: center; justify-content: center;
            padding: 20px;
        }
        .error-container {
            background: #fff; border-radius: 20px; padding: 60px 40px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.1); max-width: 500px; width: 100%;
            text-align: center;
        }
        .error-code { font-size: 80px; font-weight: 900; color: #1a56db; line-height: 1; margin-bottom: 10px; }
        .error-title { font-size: 24px; font-weight: 800; color: #1f2937; margin-bottom: 15px; }
        .error-message { font-size: 15px; color: #64748b; margin-bottom: 30px; line-height: 1.6; }
        .btn {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 12px 24px; background: #1a56db; color: white;
            border-radius: 10px; text-decoration: none; font-weight: 600;
            transition: all 0.3s;
        }
        .btn:hover { background: #1e40af; transform: translateY(-2px); }
        @media (max-width: 480px) { .error-container { padding: 40px 20px; } .error-code { font-size: 60px; } }
    </style>
</head>
<body>
    <div class="error-container">
        <%- body %>
        <a href="/" class="btn">🏠 Kembali ke Beranda</a>
    </div>
</body>
</html>
