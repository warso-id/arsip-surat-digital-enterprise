<!DOCTYPE html>
<html lang="id" manifest="manifest.json">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="description" content="<%= pageDescription || 'Arsip Surat Digital Enterprise - Sistem Manajemen Surat Terintegrasi' %>">
    <meta name="theme-color" content="#1a73e8">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    
    <title><%= pageTitle || 'Arsip Surat Digital Enterprise 2026' %></title>
    
    <!-- PWA -->
    <link rel="manifest" href="/manifest.json">
    <link rel="apple-touch-icon" href="/src/public/images/logo.png">
    <link rel="icon" type="image/x-icon" href="/src/public/images/favicon.ico">
    
    <!-- Stylesheets -->
    <link rel="stylesheet" href="/src/public/css/app.css">
    <link rel="stylesheet" href="/src/public/css/dashboard.css">
    <link rel="stylesheet" href="/src/public/css/surat.css">
    <link rel="stylesheet" href="/src/public/css/print.css" media="print">
    
    <!-- Additional Styles -->
    <%- additionalStyles || '' %>
    
    <!-- Security Headers via Meta -->
    <meta http-equiv="Content-Security-Policy" content="default-src 'self' https://script.google.com https://cdnjs.cloudflare.com; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://script.google.com; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com;">
</head>
<body class="enterprise-theme crud-pwa">
    <!-- Loading Spinner -->
    <div id="app-spinner" class="spinner-overlay" style="display: flex;">
        <div class="spinner-container">
            <div class="spinner-enterprise"></div>
            <p class="spinner-text">Memuat Sistem Enterprise 2026...</p>
        </div>
    </div>

    <!-- Offline Indicator -->
    <div id="offline-indicator" class="offline-banner" style="display: none;">
        <div class="offline-content">
            <span class="offline-icon">📡</span>
            <span>Anda sedang offline. Data akan disinkronkan saat koneksi tersedia.</span>
        </div>
    </div>

    <!-- Main App Container -->
    <div id="app-container">
        <%- include('../components/header') %>
        
        <div class="main-layout">
            <%- include('../components/sidebar') %>
            
            <main id="main-content" class="main-content">
                <div class="content-wrapper">
                    <%- body %>
                </div>
            </main>
        </div>
        
        <%- include('../components/footer') %>
    </div>

    <!-- Global Modals -->
    <%- include('../components/modal') %>
    <%- include('../components/alert') %>

    <!-- Toast Container -->
    <div id="toast-container" class="toast-container"></div>

    <!-- Scripts -->
    <script src="/src/public/js/components/SpinnerComponent.js"></script>
    <script src="/src/public/js/app.js"></script>
    <script src="/src/public/js/dashboard.js"></script>
    <script src="/src/public/js/surat.js"></script>
    <script src="/src/public/js/disposisi.js"></script>
    <script src="/src/public/js/laporan.js"></script>
    
    <!-- Additional Scripts -->
    <%- additionalScripts || '' %>
    
    <!-- Initialize Application -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            window.enterpriseApp = new EnterpriseCRUDApp();
            
            // Load current section
            const currentSection = '<%= currentSection || "dashboard" %>';
            if (currentSection) {
                window.enterpriseApp.navigateTo(currentSection);
            }
        });
    </script>
</body>
</html>
