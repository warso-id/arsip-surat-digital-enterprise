<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bantuan - Arsip Surat Digital Enterprise</title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml;base64,">
    <style>
        :root {
            --primary: #1a56db; --secondary: #64748b; --success: #10b981;
            --dark: #1f2937; --light: #f9fafb; --lighter: #ffffff; --border: #e5e7eb;
            --font-sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            --shadow: 0 4px 6px rgba(0,0,0,0.1); --radius-lg: 16px;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: var(--font-sans); background: var(--light); color: var(--dark); }
        
        .help-header {
            background: linear-gradient(135deg, var(--primary), #7c3aed);
            color: white; padding: 60px 20px; text-align: center;
        }
        .help-title { font-size: 36px; font-weight: 800; margin-bottom: 10px; }
        .help-subtitle { font-size: 18px; opacity: 0.9; }
        
        .help-container { max-width: 900px; margin: 40px auto; padding: 0 20px; }
        
        .help-section { background: var(--lighter); border-radius: var(--radius-lg); padding: 30px; border: 1px solid var(--border); margin-bottom: 25px; }
        .section-title { font-size: 20px; font-weight: 700; margin-bottom: 20px; display: flex; align-items: center; gap: 10px; }
        
        .help-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; }
        .help-card {
            background: var(--light); border-radius: 12px; padding: 25px;
            border: 1px solid var(--border); text-decoration: none; color: var(--dark);
            transition: all 0.3s; display: block;
        }
        .help-card:hover { transform: translateY(-3px); box-shadow: var(--shadow); border-color: var(--primary); }
        .help-icon { font-size: 36px; margin-bottom: 10px; }
        .help-card-title { font-size: 16px; font-weight: 700; margin-bottom: 8px; }
        .help-card-desc { font-size: 13px; color: var(--secondary); line-height: 1.5; }
        
        .faq-item { border: 1px solid var(--border); border-radius: 10px; margin-bottom: 10px; overflow: hidden; }
        .faq-question {
            width: 100%; padding: 18px 20px; text-align: left; background: none; border: none;
            font-size: 15px; font-weight: 600; cursor: pointer; display: flex;
            justify-content: space-between; align-items: center; font-family: var(--font-sans);
        }
        .faq-question:hover { background: var(--light); }
        .faq-answer { padding: 0 20px 18px; font-size: 14px; color: var(--secondary); display: none; line-height: 1.6; }
        .faq-item.open .faq-answer { display: block; }
        .faq-item.open .faq-icon { transform: rotate(45deg); }
        .faq-icon { font-size: 20px; transition: transform 0.3s; }
        
        .quick-link { display: inline-flex; align-items: center; gap: 8px; padding: 10px 20px; background: var(--primary); color: white; border-radius: 8px; text-decoration: none; font-weight: 600; margin: 5px; transition: all 0.3s; }
        .quick-link:hover { background: #1e40af; transform: translateY(-2px); }
        
        @media (max-width: 768px) { .help-header { padding: 40px 20px; } .help-title { font-size: 28px; } }
    </style>
</head>
<body>
    <div class="help-header">
        <h1 class="help-title">🆘 Pusat Bantuan</h1>
        <p class="help-subtitle">Temukan jawaban dan panduan penggunaan sistem</p>
    </div>
    
    <div class="help-container">
        <!-- Quick Links -->
        <div class="help-section">
            <h2 class="section-title">⚡ Link Cepat</h2>
            <div style="display: flex; flex-wrap: wrap; gap: 10px;">
                <a href="/docs/USER_GUIDE.md" class="quick-link">📖 Panduan Pengguna</a>
                <a href="/docs/INSTALLATION.md" class="quick-link">🛠️ Panduan Instalasi</a>
                <a href="/docs/API_DOCUMENTATION.md" class="quick-link">🔌 API Documentation</a>
                <a href="/docs/FAQ.md" class="quick-link">❓ FAQ</a>
                <a href="/docs/TROUBLESHOOTING.md" class="quick-link">🔧 Troubleshooting</a>
            </div>
        </div>
        
        <!-- Topic Cards -->
        <div class="help-section">
            <h2 class="section-title">📚 Topik Bantuan</h2>
            <div class="help-grid">
                <a href="/docs/USER_GUIDE.md#surat-masuk" class="help-card">
                    <div class="help-icon">📥</div>
                    <div class="help-card-title">Mengelola Surat Masuk</div>
                    <div class="help-card-desc">Cara mencatat, mengedit, dan memproses surat masuk</div>
                </a>
                <a href="/docs/USER_GUIDE.md#surat-keluar" class="help-card">
                    <div class="help-icon">📤</div>
                    <div class="help-card-title">Membuat Surat Keluar</div>
                    <div class="help-card-desc">Panduan membuat dan mengirim surat keluar</div>
                </a>
                <a href="/docs/USER_GUIDE.md#disposisi" class="help-card">
                    <div class="help-icon">📋</div>
                    <div class="help-card-title">Disposisi Surat</div>
                    <div class="help-card-desc">Cara memberikan dan menindaklanjuti disposisi</div>
                </a>
                <a href="/docs/USER_GUIDE.md#laporan" class="help-card">
                    <div class="help-icon">📊</div>
                    <div class="help-card-title">Membuat Laporan</div>
                    <div class="help-card-desc">Generate dan export laporan surat</div>
                </a>
                <a href="/docs/USER_GUIDE.md#pencarian" class="help-card">
                    <div class="help-icon">🔍</div>
                    <div class="help-card-title">Pencarian Surat</div>
                    <div class="help-card-desc">Tips mencari surat dengan cepat</div>
                </a>
                <a href="/docs/USER_GUIDE.md#pengaturan" class="help-card">
                    <div class="help-icon">⚙️</div>
                    <div class="help-card-title">Pengaturan Akun</div>
                    <div class="help-card-desc">Mengatur profil dan preferensi</div>
                </a>
            </div>
        </div>
        
        <!-- FAQ -->
        <div class="help-section">
            <h2 class="section-title">❓ Pertanyaan Umum</h2>
            <div class="faq-item">
                <button class="faq-question" onclick="toggleFaq(this)">
                    <span>Bagaimana cara login pertama kali?</span>
                    <span class="faq-icon">+</span>
                </button>
                <div class="faq-answer">
                    Gunakan kredensial default: <strong>admin / admin123</strong> untuk Administrator, atau <strong>operator / password123</strong> untuk Operator. Segera ubah password setelah login pertama.
                </div>
            </div>
            <div class="faq-item">
                <button class="faq-question" onclick="toggleFaq(this)">
                    <span>Bagaimana cara menambah surat masuk?</span>
                    <span class="faq-icon">+</span>
                </button>
                <div class="faq-answer">
                    Buka menu <strong>Surat Masuk</strong> > klik <strong>Tambah Surat Masuk</strong>. Isi form dengan data surat (nomor surat, tanggal, pengirim, perihal) lalu klik Simpan.
                </div>
            </div>
            <div class="faq-item">
                <button class="faq-question" onclick="toggleFaq(this)">
                    <span>Bagaimana cara memberikan disposisi?</span>
                    <span class="faq-icon">+</span>
                </button>
                <div class="faq-answer">
                    Buka detail surat masuk > klik <strong>Disposisi</strong> > pilih penerima > tulis instruksi > klik Kirim Disposisi.
                </div>
            </div>
            <div class="faq-item">
                <button class="faq-question" onclick="toggleFaq(this)">
                    <span>Apakah bisa export data ke Excel?</span>
                    <span class="faq-icon">+</span>
                </button>
                <div class="faq-answer">
                    Ya! Buka menu <strong>Laporan</strong> > pilih jenis laporan > tentukan periode > klik <strong>Export Excel</strong>.
                </div>
            </div>
            <div class="faq-item">
                <button class="faq-question" onclick="toggleFaq(this)">
                    <span>Bagaimana jika lupa password?</span>
                    <span class="faq-icon">+</span>
                </button>
                <div class="faq-answer">
                    Klik <strong>Lupa Password</strong> di halaman login, masukkan email terdaftar, dan ikuti instruksi di email. Atau hubungi administrator.
                </div>
            </div>
        </div>
        
        <!-- Contact -->
        <div class="help-section" style="text-align: center;">
            <h2 class="section-title" style="justify-content: center;">📞 Masih Butuh Bantuan?</h2>
            <p style="color: var(--secondary); margin-bottom: 20px;">
                Hubungi tim support kami melalui:
            </p>
            <div style="display: flex; gap: 10px; justify-content: center; flex-wrap: wrap;">
                <a href="mailto:developer@arsipsurat.id" class="quick-link">📧 Email Support</a>
                <a href="https://github.com/warso-id/arsip-surat-digital-enterprise/issues" class="quick-link" style="background: #374151;">🐛 Laporkan Bug</a>
            </div>
        </div>
    </div>
    
    <script>
        function toggleFaq(button) {
            const faqItem = button.parentElement;
            const isOpen = faqItem.classList.contains('open');
            document.querySelectorAll('.faq-item').forEach(item => item.classList.remove('open'));
            if (!isOpen) faqItem.classList.add('open');
        }
    </script>
</body>
</html>
