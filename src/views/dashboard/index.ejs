<section id="dashboard-section" class="content-section active">
    <div class="section-container">
        <div class="section-header">
            <h2>Dashboard</h2>
            <div class="header-actions">
                <span class="date-display" id="current-date"></span>
                <button onclick="refreshDashboard()" class="btn btn-sm btn-secondary">
                    🔄 Refresh
                </button>
            </div>
        </div>
        
        <!-- Stats Grid -->
        <div class="stats-grid" id="dashboard-stats">
            <div class="stat-card stat-card-primary">
                <div class="stat-icon">📥</div>
                <div class="stat-content">
                    <h3 class="stat-value" id="stat-surat-masuk">0</h3>
                    <p class="stat-title">Surat Masuk</p>
                    <small class="stat-subtitle">Bulan ini: <span id="stat-surat-masuk-bulan">0</span></small>
                </div>
            </div>
            
            <div class="stat-card stat-card-success">
                <div class="stat-icon">📤</div>
                <div class="stat-content">
                    <h3 class="stat-value" id="stat-surat-keluar">0</h3>
                    <p class="stat-title">Surat Keluar</p>
                    <small class="stat-subtitle">Bulan ini: <span id="stat-surat-keluar-bulan">0</span></small>
                </div>
            </div>
            
            <div class="stat-card stat-card-warning">
                <div class="stat-icon">📋</div>
                <div class="stat-content">
                    <h3 class="stat-value" id="stat-disposisi-aktif">0</h3>
                    <p class="stat-title">Disposisi Aktif</p>
                    <small class="stat-subtitle">Total: <span id="stat-disposisi-total">0</span></small>
                </div>
            </div>
            
            <div class="stat-card stat-card-info">
                <div class="stat-icon">👥</div>
                <div class="stat-content">
                    <h3 class="stat-value" id="stat-pengguna">0</h3>
                    <p class="stat-title">Pengguna</p>
                    <small class="stat-subtitle">Aktif: <span id="stat-pengguna-aktif">0</span></small>
                </div>
            </div>
        </div>
        
        <!-- Charts Row -->
        <div class="dashboard-grid">
            <div class="chart-container">
                <h3>Tren Surat</h3>
                <canvas id="surat-chart" width="400" height="200"></canvas>
            </div>
            <div class="chart-container">
                <h3>Status Disposisi</h3>
                <canvas id="disposisi-chart" width="400" height="200"></canvas>
            </div>
        </div>
        
        <!-- Recent Activities & Quick Actions -->
        <div class="dashboard-grid">
            <div class="recent-activities">
                <h3>Aktivitas Terbaru</h3>
                <div class="activity-list" id="recent-activities">
                    <p class="empty-text">Memuat aktivitas...</p>
                </div>
            </div>
            <div class="quick-actions">
                <h3>Aksi Cepat</h3>
                <div class="action-buttons">
                    <button onclick="quickCreate('surat-masuk')" class="btn-action">
                        📥 Surat Masuk Baru
                    </button>
                    <button onclick="quickCreate('surat-keluar')" class="btn-action">
                        📤 Surat Keluar Baru
                    </button>
                    <button onclick="quickCreate('disposisi')" class="btn-action">
                        📋 Disposisi Baru
                    </button>
                    <button onclick="navigateTo('laporan')" class="btn-action">
                        📊 Lihat Laporan
                    </button>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    function refreshDashboard() {
        if (window.enterpriseApp) {
            window.enterpriseApp.showSpinner(true);
            window.enterpriseApp.loadDashboardStats().then(() => {
                window.enterpriseApp.showSpinner(false);
            });
        }
    }
    
    function quickCreate(type) {
        if (window.enterpriseApp) {
            window.enterpriseApp.navigateTo(type);
            setTimeout(() => {
                window.enterpriseApp.showCRUDForm(type, 'create');
            }, 300);
        }
    }
</script>
