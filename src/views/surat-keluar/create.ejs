<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Buat Surat Keluar - Arsip Surat Digital Enterprise</title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml;base64,">
    <style>
        :root {
            --primary: #1a56db; --primary-dark: #1e40af; --secondary: #64748b;
            --success: #10b981; --warning: #f59e0b; --danger: #ef4444;
            --dark: #1f2937; --light: #f9fafb; --lighter: #ffffff; --border: #e5e7eb;
            --font-sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            --shadow: 0 4px 6px rgba(0,0,0,0.1); --radius: 10px; --transition: all 0.3s ease;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: var(--font-sans); background: var(--light); color: var(--dark); }
        
        .top-nav {
            background: var(--lighter); border-bottom: 1px solid var(--border);
            padding: 15px 30px; display: flex; align-items: center; gap: 20px;
        }
        .back-btn { text-decoration: none; color: var(--secondary); font-size: 20px; }
        .back-btn:hover { color: var(--primary); }
        .page-title { font-size: 20px; font-weight: 700; }
        
        .form-container { max-width: 900px; margin: 30px auto; padding: 0 20px; }
        .form-card { background: var(--lighter); border-radius: 16px; padding: 40px; border: 1px solid var(--border); box-shadow: var(--shadow); }
        .form-section { margin-bottom: 30px; padding-bottom: 30px; border-bottom: 1px solid var(--border); }
        .form-section:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
        .section-title { font-size: 18px; font-weight: 700; margin-bottom: 20px; display: flex; align-items: center; gap: 10px; }
        .form-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; }
        .form-group { margin-bottom: 20px; }
        .form-group.full-width { grid-column: 1 / -1; }
        .form-label { display: block; font-size: 14px; font-weight: 600; color: var(--dark); margin-bottom: 6px; }
        .form-label .required { color: var(--danger); }
        .form-input, .form-select, .form-textarea {
            width: 100%; padding: 10px 14px; border: 1px solid var(--border);
            border-radius: 8px; font-size: 14px; font-family: var(--font-sans);
            transition: var(--transition); background: var(--light);
        }
        .form-input:focus, .form-select:focus, .form-textarea:focus {
            outline: none; border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(26,86,219,0.1); background: var(--lighter);
        }
        .form-textarea { min-height: 150px; resize: vertical; }
        .form-hint { font-size: 12px; color: var(--secondary); margin-top: 4px; }
        
        .btn {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 12px 24px; border: 2px solid transparent; border-radius: 8px;
            font-size: 14px; font-weight: 600; cursor: pointer; text-decoration: none;
            transition: var(--transition); font-family: var(--font-sans);
        }
        .btn-primary { background: var(--primary); color: white; border-color: var(--primary); }
        .btn-primary:hover { background: var(--primary-dark); transform: translateY(-2px); box-shadow: var(--shadow); }
        .btn-success { background: var(--success); color: white; border-color: var(--success); }
        .btn-success:hover { background: #059669; transform: translateY(-2px); }
        .btn-outline { background: transparent; color: var(--secondary); border-color: var(--border); }
        .btn-outline:hover { background: var(--light); }
        .form-actions { display: flex; gap: 15px; justify-content: flex-end; margin-top: 30px; flex-wrap: wrap; }
        
        /* Template Selector */
        .template-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 15px; margin-bottom: 20px; }
        .template-card {
            background: var(--light); border: 2px solid var(--border); border-radius: 12px;
            padding: 20px; text-align: center; cursor: pointer; transition: var(--transition);
        }
        .template-card:hover { border-color: var(--primary); transform: translateY(-3px); box-shadow: var(--shadow); }
        .template-card.selected { border-color: var(--primary); background: #eff6ff; }
        .template-icon { font-size: 36px; margin-bottom: 10px; }
        .template-name { font-size: 13px; font-weight: 600; }
        
        @media (max-width: 768px) {
            .form-card { padding: 20px; }
            .form-grid { grid-template-columns: 1fr; }
            .form-actions { flex-direction: column; }
            .btn { width: 100%; justify-content: center; }
            .template-grid { grid-template-columns: 1fr 1fr; }
        }
    </style>
</head>
<body>
    <div class="top-nav">
        <a href="./index.ejs" class="back-btn">←</a>
        <h1 class="page-title">📤 Buat Surat Keluar</h1>
    </div>
    
    <div class="form-container">
        <form id="suratKeluarForm" class="form-card">
            <!-- Pilih Template -->
            <div class="form-section">
                <h2 class="section-title">📋 Pilih Template (Opsional)</h2>
                <div class="template-grid">
                    <div class="template-card selected" onclick="selectTemplate(this, 'formal')">
                        <div class="template-icon">📄</div>
                        <div class="template-name">Surat Resmi</div>
                    </div>
                    <div class="template-card" onclick="selectTemplate(this, 'undangan')">
                        <div class="template-icon">💌</div>
                        <div class="template-name">Undangan</div>
                    </div>
                    <div class="template-card" onclick="selectTemplate(this, 'pemberitahuan')">
                        <div class="template-icon">📢</div>
                        <div class="template-name">Pemberitahuan</div>
                    </div>
                    <div class="template-card" onclick="selectTemplate(this, 'custom')">
                        <div class="template-icon">✏️</div>
                        <div class="template-name">Custom</div>
                    </div>
                </div>
            </div>
            
            <!-- Informasi Surat -->
            <div class="form-section">
                <h2 class="section-title">📄 Informasi Surat</h2>
                <div class="form-grid">
                    <div class="form-group">
                        <label class="form-label">Nomor Surat <span class="required">*</span></label>
                        <input type="text" class="form-input" id="nomorSurat" placeholder="Masukkan nomor surat" required>
                        <span class="form-hint">Format: Nomor/Kode-Instansi/Bulan/Tahun</span>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Tanggal Surat <span class="required">*</span></label>
                        <input type="date" class="form-input" id="tanggalSurat" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Tujuan <span class="required">*</span></label>
                        <input type="text" class="form-input" id="tujuan" placeholder="Nama instansi/penerima" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Alamat Tujuan</label>
                        <textarea class="form-input" id="alamatTujuan" rows="3" placeholder="Alamat lengkap tujuan"></textarea>
                    </div>
                    <div class="form-group full-width">
                        <label class="form-label">Perihal <span class="required">*</span></label>
                        <input type="text" class="form-input" id="perihal" placeholder="Perihal surat" required>
                    </div>
                    <div class="form-group full-width">
                        <label class="form-label">Isi Surat</label>
                        <textarea class="form-textarea" id="isiSurat" placeholder="Tulis isi surat di sini..."></textarea>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Kategori</label>
                        <select class="form-select" id="kategori">
                            <option value="biasa" selected>Biasa</option>
                            <option value="penting">Penting</option>
                            <option value="rahasia">Rahasia</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Sifat Surat</label>
                        <select class="form-select" id="sifatSurat">
                            <option value="biasa" selected>Biasa</option>
                            <option value="segera">Segera</option>
                            <option value="sangat-segera">Sangat Segera</option>
                        </select>
                    </div>
                    <div class="form-group full-width">
                        <label class="form-label">Catatan</label>
                        <textarea class="form-textarea" id="catatan" placeholder="Catatan tambahan..." style="min-height: 80px;"></textarea>
                    </div>
                </div>
            </div>
            
            <!-- Form Actions -->
            <div class="form-actions">
                <a href="./index.ejs" class="btn btn-outline">Batal</a>
                <button type="button" class="btn btn-outline" onclick="saveDraft()">💾 Simpan Draft</button>
                <button type="submit" class="btn btn-primary">💾 Simpan Surat</button>
                <button type="button" class="btn btn-success" onclick="simpanDanCetak()">🖨️ Simpan & Cetak</button>
            </div>
        </form>
    </div>
    
    <script>
        let selectedTemplate = 'formal';
        
        function selectTemplate(card, template) {
            document.querySelectorAll('.template-card').forEach(c => c.classList.remove('selected'));
            card.classList.add('selected');
            selectedTemplate = template;
            applyTemplate(template);
        }
        
        function applyTemplate(template) {
            const isiSurat = document.getElementById('isiSurat');
            const templates = {
                formal: 'Yang bertanda tangan di bawah ini:\n\nNama : \nJabatan : \nInstansi : \n\nMenerangkan bahwa...',
                undangan: 'Dengan hormat,\n\nKami mengundang Bapak/Ibu untuk menghadiri acara...\n\nHari/Tanggal : \nWaktu : \nTempat : \n\nDemikian undangan ini kami sampaikan.',
                pemberitahuan: 'Dengan ini kami memberitahukan bahwa...\n\nDemikian pemberitahuan ini disampaikan untuk dapat diketahui.',
                custom: '',
            };
            if (templates[template]) {
                isiSurat.value = templates[template];
            }
        }
        
        function saveDraft() {
            const data = getFormData();
            data.status = 'draft';
            const drafts = JSON.parse(localStorage.getItem('suratKeluarDrafts') || '[]');
            drafts.push({ ...data, id: Date.now() });
            localStorage.setItem('suratKeluarDrafts', JSON.stringify(drafts));
            alert('Draft berhasil disimpan!');
        }
        
        function simpanDanCetak() {
            alert('Surat akan disimpan dan dicetak...');
        }
        
        function getFormData() {
            return {
                nomor_surat: document.getElementById('nomorSurat').value,
                tanggal_surat: document.getElementById('tanggalSurat').value,
                tujuan: document.getElementById('tujuan').value,
                alamat_tujuan: document.getElementById('alamatTujuan').value,
                perihal: document.getElementById('perihal').value,
                isi_surat: document.getElementById('isiSurat').value,
                kategori: document.getElementById('kategori').value,
                sifat_surat: document.getElementById('sifatSurat').value,
                catatan: document.getElementById('catatan').value,
            };
        }
        
        document.getElementById('suratKeluarForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            const data = getFormData();
            console.log('Menyimpan surat keluar:', data);
            
            try {
                const token = localStorage.getItem('auth_token');
                const response = await fetch('/api/surat-keluar', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${token}`,
                    },
                    body: JSON.stringify(data),
                });
                
                if (response.ok) {
                    alert('Surat keluar berhasil dibuat!');
                    window.location.href = './index.ejs';
                } else {
                    alert('Gagal membuat surat keluar.');
                }
            } catch (error) {
                alert('Terjadi kesalahan. Silakan coba lagi.');
            }
        });
        
        document.addEventListener('DOMContentLoaded', () => {
            document.getElementById('tanggalSurat').value = new Date().toISOString().split('T')[0];
            if (!localStorage.getItem('auth_token')) window.location.href = '../../login';
        });
    </script>
</body>
</html>
