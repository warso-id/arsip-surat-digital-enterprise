<form id="surat-masuk-form" class="crud-form" onsubmit="event.preventDefault(); saveCRUD();">
    <div class="form-row">
        <div class="form-group">
            <label>No. Agenda <span class="required">*</span></label>
            <input type="text" name="no_agenda" class="form-control" 
                   placeholder="Otomatis terisi" readonly id="no-agenda-input">
        </div>
        <div class="form-group">
            <label>Tanggal Terima <span class="required">*</span></label>
            <input type="date" name="tanggal_terima" class="form-control" 
                   required value="<%= new Date().toISOString().split('T')[0] %>">
        </div>
    </div>
    
    <div class="form-row">
        <div class="form-group">
            <label>Pengirim <span class="required">*</span></label>
            <input type="text" name="pengirim" class="form-control" 
                   placeholder="Nama pengirim" required>
        </div>
        <div class="form-group">
            <label>Instansi Pengirim</label>
            <select name="instansi_id" class="form-control">
                <option value="">Pilih Instansi</option>
                <% if (typeof instansi !== 'undefined') { %>
                    <% instansi.forEach(function(item) { %>
                        <option value="<%= item.id %>"><%= item.nama_instansi %></option>
                    <% }); %>
                <% } %>
            </select>
        </div>
    </div>
    
    <div class="form-group">
        <label>Perihal <span class="required">*</span></label>
        <textarea name="perihal" class="form-control" rows="3" 
                  placeholder="Perihal surat" required></textarea>
    </div>
    
    <div class="form-row">
        <div class="form-group">
            <label>Kategori <span class="required">*</span></label>
            <select name="kategori_id" class="form-control" required>
                <option value="">Pilih Kategori</option>
                <% if (typeof kategori !== 'undefined') { %>
                    <% kategori.forEach(function(item) { %>
                        <option value="<%= item.id %>"><%= item.nama_kategori %></option>
                    <% }); %>
                <% } %>
            </select>
        </div>
        <div class="form-group">
            <label>Sifat Surat <span class="required">*</span></label>
            <select name="sifat" class="form-control" required>
                <option value="biasa">Biasa</option>
                <option value="penting">Penting</option>
                <option value="rahasia">Rahasia</option>
                <option value="segera">Segera</option>
            </select>
        </div>
    </div>
    
    <div class="form-group">
        <label>Upload File (PDF/DOC) - Opsional</label>
        <%- include('../components/file-upload', { name: 'file_surat', accept: '.pdf,.doc,.docx' }) %>
    </div>
</form>

<script>
    // Generate nomor agenda otomatis
    async function generateNomorAgenda() {
        try {
            const response = await fetch('https://script.google.com/macros/s/AKfycbwblauw29Cv8rmrjQHhfXgdl0csBHlxO3xvZJimyBsSyA4F5f9qH25Ej5QYIu--OGy6Bw/exec', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    data: btoa(encodeURIComponent(JSON.stringify({
                        action: 'generate_nomor_agenda'
                    })))
                })
            });
            
            const result = await response.json();
            const data = JSON.parse(decodeURIComponent(atob(result.data)));
            
            if (data.success) {
                document.getElementById('no-agenda-input').value = data.nomor_agenda;
            }
        } catch (error) {
            console.error('Generate nomor agenda error:', error);
        }
    }
    
    document.addEventListener('DOMContentLoaded', generateNomorAgenda);
</script>
