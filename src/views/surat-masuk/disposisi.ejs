<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Form Disposisi - Arsip Surat Digital Enterprise</title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml;base64,">
    <style>
        :root {
            --primary: #1a56db; --primary-dark: #1e40af; --secondary: #64748b;
            --success: #10b981; --warning: #f59e0b; --danger: #ef4444;
            --dark: #1f2937; --light: #f9fafb; --lighter: #ffffff; --border: #e5e7eb;
            --font-sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            --shadow: 0 4px 6px rgba(0,0,0,0.1); --radius: 10px; --transition: all 0.3s ease;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: var(--font-sans); background: var(--light); color: var(--dark); }
        
        .top-nav {
            background: var(--lighter); border-bottom: 1px solid var(--border);
            padding: 15px 30px; display: flex; align-items: center; gap: 20px;
        }
        .back-btn { text-decoration: none; color: var(--secondary); font-size: 20px; }
        .back-btn:hover { color: var(--primary); }
        .page-title { font-size: 20px; font-weight: 700; }
        
        .form-container { max-width: 800px; margin: 30px auto; padding: 0 20px; }
        
        .surat-info {
            background: var(--lighter); border-radius: 12px; padding: 20px 25px;
            border: 1px solid var(--border); margin-bottom: 25px;
        }
        .surat-info h3 { font-size: 16px; margin-bottom: 10px; }
        .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; font-size: 13px; }
        .info-item { display: flex; gap: 8px; }
        .info-label { color: var(--secondary); min-width: 100px; }
        .info-value { font-weight: 600; }
        
        .form-card {
            background: var(--lighter); border-radius: 16px; padding: 30px;
            border: 1px solid var(--border); box-shadow: var(--shadow);
        }
        .form-section { margin-bottom: 25px; padding-bottom: 25px; border-bottom: 1px solid var(--border); }
        .form-section:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
        .section-title { font-size: 16px; font-weight: 700; margin-bottom: 15px; display: flex; align-items: center; gap: 8px; }
        
        .form-group { margin-bottom: 20px; }
        .form-label { display: block; font-size: 14px; font-weight: 600; margin-bottom: 6px; }
        .form-label .required { color: var(--danger); }
        .form-input, .form-select, .form-textarea {
            width: 100%; padding: 10px 14px; border: 1px solid var(--border);
            border-radius: 8px; font-size: 14px; font-family: var(--font-sans);
            transition: var(--transition); background: var(--light);
        }
        .form-input:focus, .form-select:focus, .form-textarea:focus {
            outline: none; border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(26,86,219,0.1); background: var(--lighter);
        }
        .form-textarea { min-height: 120px; resize: vertical; }
        .form-hint { font-size: 12px; color: var(--secondary); margin-top: 4px; }
        
        .recipient-options { display: flex; gap: 10px; margin-bottom: 15px; }
        .recipient-option {
            padding: 8px 16px; border: 2px solid var(--border); border-radius: 8px;
            cursor: pointer; font-size: 13px; transition: var(--transition);
        }
        .recipient-option:hover, .recipient-option.active {
            border-color: var(--primary); background: #eff6ff; color: var(--primary);
        }
        
        .btn {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 12px 24px; border: 2px solid transparent; border-radius: 10px;
            font-size: 14px; font-weight: 600; cursor: pointer; text-decoration: none;
            transition: var(--transition); font-family: var(--font-sans);
        }
        .btn-primary { background: var(--primary); color: white; border-color: var(--primary); }
        .btn-primary:hover { background: var(--primary-dark); transform: translateY(-2px); box-shadow: var(--shadow); }
        .btn-success { background: var(--success); color: white; border-color: var(--success); }
        .btn-outline { background: transparent; color: var(--secondary); border-color: var(--border); }
        .form-actions { display: flex; gap: 15px; justify-content: flex-end; margin-top: 30px; flex-wrap: wrap; }
        
        .alert { padding: 12px 16px; border-radius: 8px; margin-bottom: 20px; font-size: 13px; display: none; }
        .alert-success { background: #f0fdf4; color: #065f46; border: 1px solid #bbf7d0; }
        .alert-error { background: #fef2f2; color: #991b1b; border: 1px solid #fecaca; }
        .alert.show { display: block; }
        
        @media (max-width: 768px) {
            .form-card { padding: 20px; }
            .info-grid { grid-template-columns: 1fr; }
            .form-actions { flex-direction: column; }
            .btn { width: 100%; justify-content: center; }
        }
    </style>
</head>
<body>
    <div class="top-nav">
        <a href="./show.ejs?id=1" class="back-btn">←</a>
        <h1 class="page-title">📋 Form Disposisi</h1>
    </div>
    
    <div class="form-container">
        <!-- Surat Info -->
        <div class="surat-info">
            <h3>📄 Informasi Surat</h3>
            <div class="info-grid">
                <div class="info-item"><span class="info-label">No. Agenda:</span><span class="info-value">SM-2024-001</span></div>
                <div class="info-item"><span class="info-label">Tanggal:</span><span class="info-value">15 Januari 2024</span></div>
                <div class="info-item"><span class="info-label">Pengirim:</span><span class="info-value">Kementerian A</span></div>
                <div class="info-item"><span class="info-label">Perihal:</span><span class="info-value">Undangan Rapat Koordinasi</span></div>
            </div>
        </div>
        
        <div id="alertContainer"></div>
        
        <form id="disposisiForm" class="form-card">
            <!-- Penerima Disposisi -->
            <div class="form-section">
                <h2 class="section-title">👤 Tujuan Disposisi</h2>
                <div class="recipient-options" id="recipientType">
                    <div class="recipient-option active" onclick="selectRecipientType('user')">👤 User Tertentu</div>
                    <div class="recipient-option" onclick="selectRecipientType('role')">👥 Berdasarkan Role</div>
                </div>
                
                <div class="form-group" id="userSelect">
                    <label class="form-label">Pilih Penerima <span class="required">*</span></label>
                    <select class="form-select" id="kepadaUserId">
                        <option value="">Pilih User</option>
                        <option value="2">Kepala Bagian Umum</option>
                        <option value="3">Staff Administrasi</option>
                        <option value="4">Operator Surat</option>
                    </select>
                </div>
                
                <div class="form-group" id="roleSelect" style="display: none;">
                    <label class="form-label">Pilih Role <span class="required">*</span></label>
                    <select class="form-select" id="kepadaRoleId">
                        <option value="">Pilih Role</option>
                        <option value="3">Operator</option>
                        <option value="4">Pimpinan</option>
                        <option value="5">Viewer</option>
                    </select>
                </div>
            </div>
            
            <!-- Isi Disposisi -->
            <div class="form-section">
                <h2 class="section-title">📝 Isi Disposisi</h2>
                <div class="form-group">
                    <label class="form-label">Isi Disposisi <span class="required">*</span></label>
                    <textarea class="form-textarea" id="isiDisposisi" placeholder="Tulis isi disposisi di sini..." required></textarea>
                    <span class="form-hint">Jelaskan instruksi atau tindak lanjut yang diharapkan</span>
                </div>
                
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                    <div class="form-group">
                        <label class="form-label">Sifat Disposisi</label>
                        <select class="form-select" id="sifatDisposisi">
                            <option value="biasa">Biasa</option>
                            <option value="segera">Segera</option>
                            <option value="sangat-segera">Sangat Segera</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Batas Waktu</label>
                        <input type="date" class="form-input" id="batasWaktu">
                        <span class="form-hint">Kosongkan jika tidak ada batas waktu</span>
                    </div>
                </div>
            </div>
            
            <!-- Form Actions -->
            <div class="form-actions">
                <a href="./show.ejs?id=1" class="btn btn-outline">Batal</a>
                <button type="submit" class="btn btn-primary" id="submitBtn">
                    📋 Kirim Disposisi
                </button>
                <button type="button" class="btn btn-success" onclick="submitAndNew()">
                    ✅ Kirim & Buat Baru
                </button>
            </div>
        </form>
    </div>
    
    <script>
        let recipientType = 'user';
        
        function selectRecipientType(type) {
            recipientType = type;
            document.querySelectorAll('.recipient-option').forEach(el => el.classList.remove('active'));
            event.target.classList.add('active');
            
            document.getElementById('userSelect').style.display = type === 'user' ? 'block' : 'none';
            document.getElementById('roleSelect').style.display = type === 'role' ? 'block' : 'none';
        }
        
        function showAlert(message, type) {
            const container = document.getElementById('alertContainer');
            container.innerHTML = `<div class="alert alert-${type} show">${message}</div>`;
            setTimeout(() => { container.innerHTML = ''; }, 5000);
        }
        
        function submitAndNew() {
            document.getElementById('disposisiForm').dispatchEvent(new Event('submit'));
            setTimeout(() => {
                document.getElementById('isiDisposisi').value = '';
                document.getElementById('batasWaktu').value = '';
            }, 500);
        }
        
        document.getElementById('disposisiForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const isi = document.getElementById('isiDisposisi').value.trim();
            if (!isi) {
                showAlert('Isi disposisi harus diisi!', 'error');
                return;
            }
            
            const data = {
                surat_masuk_id: 1,
                isi_disposisi: isi,
                sifat_disposisi: document.getElementById('sifatDisposisi').value,
                batas_waktu: document.getElementById('batasWaktu').value || null,
            };
            
            if (recipientType === 'user') {
                data.kepada_user_id = document.getElementById('kepadaUserId').value;
            } else {
                data.kepada_role_id = document.getElementById('kepadaRoleId').value;
            }
            
            if (!data.kepada_user_id && !data.kepada_role_id) {
                showAlert('Pilih penerima disposisi!', 'error');
                return;
            }
            
            const submitBtn = document.getElementById('submitBtn');
            submitBtn.disabled = true;
            submitBtn.textContent = '⏳ Mengirim...';
            
            try {
                const token = localStorage.getItem('auth_token');
                const response = await fetch('/api/disposisi', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${token}`,
                    },
                    body: JSON.stringify(data),
                });
                
                const result = await response.json();
                
                if (response.ok && result.success) {
                    showAlert('Disposisi berhasil dikirim!', 'success');
                    setTimeout(() => { window.location.href = './show.ejs?id=1'; }, 1500);
                } else {
                    showAlert(result.message || 'Gagal mengirim disposisi', 'error');
                }
            } catch (error) {
                showAlert('Terjadi kesalahan. Silakan coba lagi.', 'error');
            } finally {
                submitBtn.disabled = false;
                submitBtn.textContent = '📋 Kirim Disposisi';
            }
        });
        
        document.addEventListener('DOMContentLoaded', () => {
            document.getElementById('batasWaktu').value = new Date(Date.now() + 3*24*60*60*1000).toISOString().split('T')[0];
            if (!localStorage.getItem('auth_token')) window.location.href = '../../login';
        });
    </script>
</body>
</html>
