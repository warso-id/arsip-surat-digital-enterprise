<section id="surat-masuk-section" class="content-section">
    <div class="section-container">
        <div class="section-header">
            <h2>Manajemen Surat Masuk</h2>
            <div class="header-actions">
                <button onclick="exportData('surat-masuk')" class="btn btn-sm btn-secondary">📥 Export</button>
                <button onclick="importData('surat-masuk')" class="btn btn-sm btn-secondary">📤 Import</button>
                <button onclick="showCRUDForm('surat-masuk', 'create')" class="btn btn-primary">
                    + Tambah Surat Masuk
                </button>
            </div>
        </div>
        
        <!-- Filter Bar -->
        <%- include('../components/search-bar', { type: 'surat-masuk' }) %>
        
        <!-- Table -->
        <div class="table-container">
            <table id="tabel-surat-masuk" class="data-table">
                <thead>
                    <tr>
                        <th><input type="checkbox" id="select-all-masuk" onchange="toggleSelectAll('masuk')"></th>
                        <th>No. Agenda</th>
                        <th>Tanggal Terima</th>
                        <th>Pengirim</th>
                        <th>Perihal</th>
                        <th>Kategori</th>
                        <th>Status</th>
                        <th>Aksi</th>
                    </tr>
                </thead>
                <tbody id="body-surat-masuk">
                    <tr>
                        <td colspan="8" class="text-center">Memuat data...</td>
                    </tr>
                </tbody>
            </table>
        </div>
        
        <!-- Pagination -->
        <%- include('../components/pagination', { type: 'surat-masuk' }) %>
    </div>
</section>
