<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Detail Disposisi - Arsip Surat Digital Enterprise</title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml;base64,">
    <style>
        :root {
            --primary: #1a56db; --secondary: #64748b; --success: #10b981;
            --warning: #f59e0b; --danger: #ef4444; --dark: #1f2937;
            --light: #f9fafb; --lighter: #ffffff; --border: #e5e7eb;
            --font-sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            --shadow: 0 4px 6px rgba(0,0,0,0.1); --radius: 10px;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: var(--font-sans); background: var(--light); color: var(--dark); }
        
        .top-nav {
            background: var(--lighter); border-bottom: 1px solid var(--border);
            padding: 15px 30px; display: flex; align-items: center; justify-content: space-between;
            position: sticky; top: 0; z-index: 10;
        }
        .nav-left { display: flex; align-items: center; gap: 20px; }
        .back-btn { text-decoration: none; color: var(--secondary); font-size: 20px; }
        .page-title { font-size: 18px; font-weight: 700; }
        
        .btn {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 10px 20px; border: 2px solid transparent; border-radius: 8px;
            font-size: 14px; font-weight: 600; cursor: pointer; text-decoration: none;
            transition: all 0.3s; font-family: var(--font-sans);
        }
        .btn-primary { background: var(--primary); color: white; border-color: var(--primary); }
        .btn-primary:hover { background: #1e40af; transform: translateY(-2px); }
        .btn-success { background: var(--success); color: white; border-color: var(--success); }
        .btn-warning { background: var(--warning); color: white; border-color: var(--warning); }
        .btn-outline { background: transparent; color: var(--primary); border-color: var(--primary); }
        .btn-sm { padding: 6px 12px; font-size: 12px; }
        
        .content-container { max-width: 800px; margin: 30px auto; padding: 0 20px; }
        
        .info-card {
            background: var(--lighter); border-radius: 16px; padding: 25px;
            border: 1px solid var(--border); box-shadow: var(--shadow); margin-bottom: 20px;
        }
        .card-title { font-size: 16px; font-weight: 700; margin-bottom: 20px; padding-bottom: 15px; border-bottom: 2px solid var(--border); display: flex; align-items: center; gap: 10px; }
        
        .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
        .info-row { display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid var(--light); font-size: 14px; }
        .info-label { color: var(--secondary); }
        .info-value { font-weight: 600; text-align: right; }
        
        .status-badge { display: inline-block; padding: 4px 12px; border-radius: 12px; font-size: 12px; font-weight: 600; }
        .status-pending { background: #fef3c7; color: #92400e; }
        .status-proses { background: #dbeafe; color: #1e40af; }
        .status-selesai { background: #d1fae5; color: #065f46; }
        
        .disposisi-content {
            background: #fffbeb; border: 1px solid #fde68a; border-radius: 12px;
            padding: 20px; margin-top: 15px; font-size: 14px; line-height: 1.8;
            border-left: 4px solid var(--warning);
        }
        
        .tindak-lanjut {
            background: var(--light); border-radius: 10px; padding: 20px; margin-top: 15px;
        }
        
        .form-group { margin-bottom: 15px; }
        .form-label { display: block; font-size: 14px; font-weight: 600; margin-bottom: 5px; }
        .form-textarea { width: 100%; padding: 10px 14px; border: 1px solid var(--border); border-radius: 8px; font-size: 14px; font-family: var(--font-sans); min-height: 80px; resize: vertical; }
        .form-textarea:focus { outline: none; border-color: var(--primary); }
        
        @media (max-width: 768px) {
            .info-grid { grid-template-columns: 1fr; }
            .info-value { text-align: left; }
            .content-container { padding: 0 10px; }
        }
    </style>
</head>
<body>
    <div class="top-nav">
        <div class="nav-left">
            <a href="./index.ejs" class="back-btn">←</a>
            <h1 class="page-title">Detail Disposisi #DSP-2024-001</h1>
            <span class="status-badge status-pending">Pending</span>
        </div>
        <div class="action-buttons" style="display: flex; gap: 10px;">
            <button class="btn btn-outline btn-sm" onclick="window.print()">🖨️ Cetak</button>
        </div>
    </div>
    
    <div class="content-container">
        <!-- Info Disposisi -->
        <div class="info-card">
            <div class="card-title">📋 Informasi Disposisi</div>
            <div class="info-grid">
                <div class="info-row"><span class="info-label">Nomor Disposisi</span><span class="info-value">DSP-2024-001</span></div>
                <div class="info-row"><span class="info-label">Tanggal</span><span class="info-value">15 Januari 2024, 09:00</span></div>
                <div class="info-row"><span class="info-label">Dari</span><span class="info-value">Kepala Bagian Umum</span></div>
                <div class="info-row"><span class="info-label">Kepada</span><span class="info-value">Staff Administrasi</span></div>
                <div class="info-row"><span class="info-label">Sifat</span><span class="info-value">Segera</span></div>
                <div class="info-row"><span class="info-label">Batas Waktu</span><span class="info-value" style="color: var(--warning);">20 Januari 2024 (3 hari lagi)</span></div>
                <div class="info-row"><span class="info-label">Status</span><span class="info-value"><span class="status-badge status-pending">Pending</span></span></div>
            </div>
            
            <div class="disposisi-content">
                <strong>📝 Isi Disposisi:</strong><br><br>
                Tolong diproses dan siapkan bahan rapat koordinasi. Koordinasikan dengan bagian terkait untuk persiapan materi. Pastikan semua dokumen pendukung sudah lengkap sebelum tanggal rapat.
            </div>
        </div>
        
        <!-- Surat Terkait -->
        <div class="info-card">
            <div class="card-title">📄 Surat Terkait</div>
            <div class="info-grid">
                <div class="info-row"><span class="info-label">Nomor Agenda</span><span class="info-value">SM-2024-001</span></div>
                <div class="info-row"><span class="info-label">Perihal</span><span class="info-value">Undangan Rapat Koordinasi</span></div>
                <div class="info-row"><span class="info-label">Pengirim</span><span class="info-value">Kementerian A</span></div>
                <div class="info-row"><span class="info-label">Tanggal Terima</span><span class="info-value">15 Januari 2024</span></div>
            </div>
            <a href="../surat-masuk/show.ejs?id=1" class="btn btn-outline btn-sm" style="margin-top: 15px;">👁️ Lihat Surat</a>
        </div>
        
        <!-- Tindak Lanjut -->
        <div class="info-card">
            <div class="card-title">✅ Tindak Lanjut</div>
            <div class="tindak-lanjut">
                <div class="form-group">
                    <label class="form-label">Catatan Tindak Lanjut</label>
                    <textarea class="form-textarea" id="catatanTindakLanjut" placeholder="Tulis catatan tindak lanjut..."></textarea>
                </div>
                <div style="display: flex; gap: 10px;">
                    <button class="btn btn-success btn-sm" onclick="updateStatus('proses')">✅ Mulai Proses</button>
                    <button class="btn btn-primary btn-sm" onclick="updateStatus('selesai')">✅ Tandai Selesai</button>
                    <button class="btn btn-warning btn-sm" onclick="updateStatus('ditolak')">❌ Tolak</button>
                </div>
            </div>
        </div>
    </div>
    
    <script>
        function updateStatus(status) {
            const catatan = document.getElementById('catatanTindakLanjut').value;
            if (confirm(`Ubah status disposisi menjadi "${status}"?`)) {
                console.log('Updating status to:', status, 'Catatan:', catatan);
                alert('Status disposisi berhasil diperbarui!');
                location.reload();
            }
        }
        
        document.addEventListener('DOMContentLoaded', () => {
            if (!localStorage.getItem('auth_token')) window.location.href = '../../login';
        });
    </script>
</body>
</html>
