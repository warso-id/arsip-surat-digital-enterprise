<div id="forgot-password-form">
    <form onsubmit="event.preventDefault(); handleForgotPassword()">
        <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" class="form-control" 
                   placeholder="Masukkan email terdaftar" required>
            <small style="color: #666; margin-top: 5px; display: block;">
                Kami akan mengirimkan link reset password ke email Anda.
            </small>
        </div>
        
        <button type="submit" class="btn-auth">Kirim Link Reset</button>
    </form>
    
    <div class="auth-links">
        <p><a href="/login">Kembali ke Login</a></p>
    </div>
</div>

<script>
    async function handleForgotPassword() {
        const email = document.getElementById('email').value;
        
        const btn = document.querySelector('.btn-auth');
        btn.textContent = 'Mengirim...';
        btn.disabled = true;
        
        try {
            const authService = new AuthService();
            const result = await authService.forgotPassword(email);
            
            if (result.success) {
                alert('Link reset password telah dikirim ke email Anda');
                window.location.href = '/login';
            } else {
                alert(result.message || 'Gagal mengirim reset password');
            }
        } catch (error) {
            alert('Gagal terhubung ke server');
        } finally {
            btn.textContent = 'Kirim Link Reset';
            btn.disabled = false;
        }
    }
</script>
