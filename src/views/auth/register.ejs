<div id="register-form">
    <form onsubmit="event.preventDefault(); handleRegister()">
        <div class="form-group">
            <label for="nama">Nama Lengkap</label>
            <input type="text" id="nama" name="nama" class="form-control" 
                   placeholder="Masukkan nama lengkap" required>
        </div>
        
        <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" class="form-control" 
                   placeholder="Masukkan email" required>
        </div>
        
        <div class="form-group">
            <label for="password">Password</label>
            <input type="password" id="password" name="password" class="form-control" 
                   placeholder="Minimal 8 karakter" required minlength="8">
        </div>
        
        <div class="form-group">
            <label for="password_confirmation">Konfirmasi Password</label>
            <input type="password" id="password_confirmation" name="password_confirmation" 
                   class="form-control" placeholder="Ulangi password" required minlength="8">
        </div>
        
        <div class="form-group">
            <label for="instansi">Instansi</label>
            <select id="instansi" name="instansi_id" class="form-control">
                <option value="">Pilih Instansi</option>
                <!-- Loaded dynamically -->
            </select>
        </div>
        
        <button type="submit" class="btn-auth">Daftar</button>
    </form>
    
    <div class="auth-links">
        <p>Sudah punya akun? <a href="/login">Masuk</a></p>
    </div>
</div>

<script>
    async function handleRegister() {
        const nama = document.getElementById('nama').value;
        const email = document.getElementById('email').value;
        const password = document.getElementById('password').value;
        const passwordConfirmation = document.getElementById('password_confirmation').value;
        const instansiId = document.getElementById('instansi').value;
        
        if (password !== passwordConfirmation) {
            alert('Password tidak cocok');
            return;
        }
        
        const btn = document.querySelector('.btn-auth');
        btn.textContent = 'Memproses...';
        btn.disabled = true;
        
        try {
            const authService = new AuthService();
            const result = await authService.register({
                nama: nama,
                email: email,
                password: password,
                instansi_id: instansiId
            });
            
            if (result.success) {
                alert('Registrasi berhasil! Silakan login.');
                window.location.href = '/login';
            } else {
                alert(result.message || 'Registrasi gagal');
            }
        } catch (error) {
            alert('Gagal terhubung ke server');
        } finally {
            btn.textContent = 'Daftar';
            btn.disabled = false;
        }
    }
    
    // Load instansi options
    async function loadInstansi() {
        try {
            const response = await fetch('https://script.google.com/macros/s/AKfycbwblauw29Cv8rmrjQHhfXgdl0csBHlxO3xvZJimyBsSyA4F5f9qH25Ej5QYIu--OGy6Bw/exec', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    data: btoa(encodeURIComponent(JSON.stringify({
                        action: 'instansi_index'
                    })))
                })
            });
            
            const result = await response.json();
            const data = JSON.parse(decodeURIComponent(atob(result.data)));
            
            if (data.success && data.data) {
                const select = document.getElementById('instansi');
                data.data.forEach(instansi => {
                    const option = document.createElement('option');
                    option.value = instansi.id;
                    option.textContent = instansi.nama_instansi;
                    select.appendChild(option);
                });
            }
        } catch (error) {
            console.error('Load instansi error:', error);
        }
    }
    
    document.addEventListener('DOMContentLoaded', loadInstansi);
</script>
