<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verifikasi Email - Arsip Surat Digital Enterprise</title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml;base64,">
    <style>
        :root {
            --primary: #1a56db; --secondary: #64748b; --success: #10b981;
            --danger: #ef4444; --dark: #1f2937; --light: #f9fafb;
            --lighter: #ffffff; --border: #e5e7eb;
            --font-sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            --shadow-lg: 0 10px 40px rgba(0,0,0,0.15); --radius-lg: 16px;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: var(--font-sans);
            background: linear-gradient(135deg, #eff6ff 0%, #f0f9ff 50%, #ecfdf5 100%);
            min-height: 100vh; display: flex; align-items: center; justify-content: center;
            padding: 20px;
        }
        .verify-container { width: 100%; max-width: 450px; }
        .verify-card {
            background: var(--lighter); border-radius: var(--radius-lg);
            padding: 50px 40px; box-shadow: var(--shadow-lg); border: 1px solid var(--border);
            text-align: center;
        }
        .verify-icon { font-size: 80px; margin-bottom: 20px; }
        .verify-title { font-size: 24px; font-weight: 800; color: var(--dark); margin-bottom: 10px; }
        .verify-message { font-size: 15px; color: var(--secondary); margin-bottom: 30px; line-height: 1.6; }
        
        .btn {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 14px 28px; background: var(--primary); color: white;
            border-radius: 10px; text-decoration: none; font-weight: 600;
            transition: all 0.3s; border: none; cursor: pointer; font-family: inherit; font-size: 16px;
        }
        .btn:hover { background: #1e40af; transform: translateY(-2px); }
        .btn-outline { background: transparent; color: var(--primary); border: 2px solid var(--primary); }
        .btn-outline:hover { background: var(--primary); color: white; }
        
        .alert { padding: 12px 16px; border-radius: 8px; margin-bottom: 20px; font-size: 13px; display: none; }
        .alert-success { background: #f0fdf4; color: #065f46; border: 1px solid #bbf7d0; }
        .alert-error { background: #fef2f2; color: #991b1b; border: 1px solid #fecaca; }
        .alert.show { display: block; }
        
        @media (max-width: 480px) { .verify-card { padding: 30px 20px; } }
    </style>
</head>
<body>
    <div class="verify-container">
        <div class="verify-card">
            <div class="verify-icon">📧</div>
            <h1 class="verify-title">Verifikasi Email</h1>
            <p class="verify-message">
                Kami telah mengirimkan link verifikasi ke email Anda. 
                Silakan cek inbox atau folder spam untuk melanjutkan.
            </p>
            
            <div id="alertContainer"></div>
            
            <button class="btn" onclick="resendVerification()">📤 Kirim Ulang Email</button>
            <br><br>
            <a href="/login" class="btn btn-outline">🔐 Kembali ke Login</a>
        </div>
    </div>
    
    <script>
        async function resendVerification() {
            const btn = event.target;
            btn.disabled = true;
            btn.textContent = '⏳ Mengirim...';
            
            try {
                const token = localStorage.getItem('auth_token');
                const response = await fetch('/auth/resend-verification', {
                    method: 'POST',
                    headers: { 
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${token}` 
                    },
                });
                
                const result = await response.json();
                
                if (response.ok) {
                    showAlert('Email verifikasi telah dikirim ulang!', 'success');
                } else {
                    showAlert(result.message || 'Gagal mengirim email', 'error');
                }
            } catch (error) {
                showAlert('Terjadi kesalahan', 'error');
            } finally {
                btn.disabled = false;
                btn.textContent = '📤 Kirim Ulang Email';
            }
        }
        
        function showAlert(message, type) {
            const container = document.getElementById('alertContainer');
            container.innerHTML = `<div class="alert alert-${type} show">${message}</div>`;
            setTimeout(() => { container.innerHTML = ''; }, 5000);
        }
    </script>
</body>
</html>
