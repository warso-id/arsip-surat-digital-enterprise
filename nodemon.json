{
    "watch": [
        "src/",
        ".env"
    ],
    "ext": "js,json,ejs,css,html",
    "ignore": [
        "src/storage/",
        "src/public/uploads/",
        "node_modules/",
        "tests/",
        "*.test.js",
        "*.spec.js"
    ],
    "delay": "1000",
    "verbose": true,
    "env": {
        "NODE_ENV": "development"
    },
    "exec": "node src/app.js",
    "events": {
        "restart": "echo '🔄 Server restarting...'",
        "crash": "echo '❌ Server crashed!'"
    }
}
