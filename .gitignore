# ============================================================
# ARSIP SURAT DIGITAL ENTERPRISE v3.0.0
# Git Ignore Rules
# ============================================================

# Dependencies
node_modules/
package-lock.json
yarn.lock

# Build output
dist/
build/
*.min.js
*.min.css

# Environment files
.env
.env.local
.env.production
.env.development

# IDE files
.vscode/
.idea/
*.sublime-*
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Testing
coverage/
.nyc_output/
cypress/videos/
cypress/screenshots/

# Temp files
tmp/
temp/
*.tmp
*.temp

# Cache
.cache/
*.cache

# SSL Certificates
ssl/
*.pem
*.crt
*.key

# Backup files
*.bak
*.backup
backup/

# Config files (with sensitive data)
config/local.json
config/production.json

# Docker
docker-compose.override.yml

# Database
*.sqlite
*.db

# Secrets
secrets/
*.secret
