# ============================================
# STORAGE - Keep folder structure, ignore files
# ============================================

# Ignore all files in storage subfolders
storage/app/surat/masuk/*
storage/app/surat/keluar/*
storage/app/lampiran/*
storage/app/temp/*
storage/logs/*
storage/backup/*
public/uploads/*

# BUT keep .gitkeep files
!storage/app/surat/masuk/.gitkeep
!storage/app/surat/keluar/.gitkeep
!storage/app/lampiran/.gitkeep
!storage/app/template/.gitkeep
!storage/app/temp/.gitkeep
!storage/logs/.gitkeep
!storage/backup/.gitkeep
!public/uploads/.gitkeep
!src/public/images/.gitkeep

# Keep template files
!storage/app/template/*.docx
!storage/app/template/*.dotx
