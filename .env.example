# ============================================
# ENVIRONMENT CONFIGURATION - EXAMPLE FILE
# ARSIP SURAT DIGITAL ENTERPRISE v3.2.2
# ============================================
# SAFE TO COMMIT TO GITHUB
# Copy this file to .env and fill in your real values
# ============================================

# App
APP_NAME=Arsip Surat Digital Enterprise
APP_VERSION=3.2.2
APP_ENV=development
APP_URL=http://localhost:8080

# Google Apps Script (REQUIRED - Fill with your own)
GAS_API_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
GAS_SCRIPT_ID=YOUR_SCRIPT_ID

# Google Sheets (REQUIRED - Fill with your own)
SPREADSHEET_ID=YOUR_SPREADSHEET_ID
SPREADSHEET_ID_ENCODED=YOUR_ENCODED_ID
MASTER_FOLDER_ID=YOUR_FOLDER_ID

# Security (REQUIRED - Generate your own secrets)
JWT_SECRET=your-generated-jwt-secret-here
CSRF_SECRET=your-generated-csrf-secret-here
ENCRYPTION_SECRET=your-generated-encryption-secret-here
API_KEY=your-generated-api-key-here

# Features
FEATURE_BIOMETRIC=true
FEATURE_TWO_FACTOR=true
FEATURE_AI=true
FEATURE_OCR=true
FEATURE_BLOCKCHAIN=true

# Development
DEV_SERVER_PORT=8080
DEV_MOCK_API=true

# Build
BUILD_OUTPUT_DIR=./build
BUILD_MINIFY=true

# Deploy
DEPLOY_TARGET=github
DEPLOY_BRANCH=gh-pages
