# ==================== ENVIRONMENT CONFIGURATION ====================
# Arsip Surat Digital Enterprise v2.1.0
# Copy this file to .env and adjust the values
# NEVER commit .env file to repository!

# ==================== APPLICATION ====================
APP_NAME=Arsip Surat Digital Enterprise
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:3000
APP_PORT=3000
APP_TIMEZONE=Asia/Jakarta
APP_LOCALE=id
APP_KEY=base64:change-this-to-a-random-64-char-string

# ==================== DATABASE ====================
DB_CONNECTION=sqlite
DB_SQLITE_PATH=database.sqlite

# MySQL (optional)
# DB_CONNECTION=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_DATABASE=arsip_surat
# DB_USERNAME=root
# DB_PASSWORD=

# PostgreSQL (optional)
# DB_CONNECTION=pgsql
# DB_HOST=localhost
# DB_PORT=5432
# DB_DATABASE=arsip_surat
# DB_USERNAME=postgres
# DB_PASSWORD=

# ==================== AUTHENTICATION ====================
JWT_SECRET=change-this-to-a-very-long-random-secret-key
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

SESSION_DRIVER=jwt
SESSION_LIFETIME=120

PASSWORD_MIN_LENGTH=8
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_TIME=30

# ==================== STORAGE ====================
STORAGE_DISK=local
MAX_FILE_SIZE=10485760
IMAGE_MAX_WIDTH=2000
IMAGE_MAX_HEIGHT=2000
IMAGE_QUALITY=80

# ==================== MAIL ====================
MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM_ADDRESS=noreply@arsipsurat.id
MAIL_FROM_NAME=Arsip Surat Digital

# ==================== CACHE ====================
CACHE_DRIVER=file
CACHE_TTL=3600

# Redis (optional)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# ==================== QUEUE ====================
QUEUE_CONNECTION=sync
QUEUE_NAME=notifications
QUEUE_RETRY_AFTER=60

# ==================== SECURITY ====================
CORS_ENABLED=true
CORS_ORIGINS=*
CORS_MAX_AGE=86400

RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

ENCRYPTION_KEY=change-this-encryption-key

# ==================== LOGGING ====================
LOG_CHANNEL=daily
LOG_LEVEL=debug
LOG_DAYS=30

# ==================== BACKUP ====================
BACKUP_ENABLED=false
BACKUP_SCHEDULE=0 2 * * *
BACKUP_KEEP=7

# ==================== PWA ====================
PWA_ENABLED=true

# ==================== API ====================
API_PER_PAGE=15
API_MAX_PER_PAGE=100
API_THROTTLE_ENABLED=true
API_THROTTLE_MAX=60
API_THROTTLE_DECAY=1

# ==================== EXTERNAL SERVICES ====================
# GitHub (for update checking)
GITHUB_TOKEN=
GITHUB_REPO=warso-id/arsip-surat-digital-enterprise

# Sentry (error tracking)
# SENTRY_DSN=

# Google Analytics
# GA_TRACKING_ID=
