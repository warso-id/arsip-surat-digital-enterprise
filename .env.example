# ============================================================
# ARSIP SURAT DIGITAL ENTERPRISE v3.0.0
# Environment Variables Configuration
# ============================================================
# Copy this file to .env and fill in your values
# ============================================================

# ==================== APPLICATION ====================
APP_NAME=Arsip Surat Digital Enterprise
APP_VERSION=3.0.0
APP_ENV=production
APP_DEBUG=false
APP_URL=https://arsip-surat.example.com
APP_TIMEZONE=Asia/Jakarta
APP_LOCALE=id

# ==================== GOOGLE APPS SCRIPT ====================
GAS_API_URL=https://script.google.com/macros/s/AKfycbwblauw29Cv8rmrjQHhfXgdl0csBHlxO3xvZJimyBsSyA4F5f9qH25Ej5QYIu--OGy6Bw/exec
GAS_API_TIMEOUT=30000
GAS_API_RETRIES=3
GAS_USE_BASE64=true

# ==================== DATABASE ====================
DB_TYPE=indexeddb
DB_NAME=ArsipSuratEnterprise
DB_VERSION=3

# ==================== AUTHENTICATION ====================
AUTH_TOKEN_EXPIRY=86400
AUTH_REFRESH_EXPIRY=604800
AUTH_MAX_LOGIN_ATTEMPTS=5
AUTH_LOCKOUT_DURATION=900
AUTH_SESSION_TIMEOUT=3600

# ==================== SECURITY ====================
SECURITY_ENCRYPTION_KEY=your-encryption-key-here
SECURITY_CSRF_ENABLED=true
SECURITY_CORS_ENABLED=true
SECURITY_HSTS_ENABLED=true

# ==================== FEATURES ====================
FEATURE_MULTI_INSTANSI=true
FEATURE_RBAC=true
FEATURE_AUDIT_TRAIL=true
FEATURE_NOTIFICATIONS=true
FEATURE_PWA=true
FEATURE_OFFLINE_MODE=true
FEATURE_EXPORT_PDF=true
FEATURE_EXPORT_EXCEL=true
FEATURE_QR_CODE=true
FEATURE_BACKUP=true

# ==================== NOTIFICATIONS ====================
NOTIFICATION_EMAIL_ENABLED=false
NOTIFICATION_EMAIL_HOST=smtp.gmail.com
NOTIFICATION_EMAIL_PORT=587
NOTIFICATION_EMAIL_USER=
NOTIFICATION_EMAIL_PASS=
NOTIFICATION_PUSH_ENABLED=true
NOTIFICATION_VAPID_PUBLIC_KEY=

# ==================== MONITORING ====================
MONITORING_ENABLED=true
MONITORING_LOG_LEVEL=info
MONITORING_REMOTE_LOGGING=true
MONITORING_PERFORMANCE=true
MONITORING_ERROR_TRACKING=true

# ==================== BACKUP ====================
BACKUP_AUTO_ENABLED=true
BACKUP_INTERVAL=3600000
BACKUP_MAX_COUNT=5
BACKUP_INCLUDE_FILES=false
BACKUP_ENCRYPT=true

# ==================== DEPLOYMENT ====================
DEPLOY_SERVER=your-server.com
DEPLOY_USER=deploy
DEPLOY_PATH=/var/www/html
DEPLOY_SSH_KEY=~/.ssh/id_rsa

# ==================== DOCKER ====================
DOCKER_REGISTRY=docker.io
DOCKER_IMAGE=arsip-surat-enterprise
DOCKER_TAG=latest
