# Application
APP_NAME="Arsip Surat Digital Enterprise"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:3000
APP_PORT=3000
APP_KEY=

# Database
DB_CONNECTION=sqlite
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=database.sqlite
DB_USERNAME=root
DB_PASSWORD=

# Mail
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@arsipsurat.id
MAIL_FROM_NAME="Arsip Surat Digital"

# Storage
STORAGE_DRIVER=local
STORAGE_PATH=storage/app
MAX_UPLOAD_SIZE=10MB
ALLOWED_FILE_TYPES=pdf,doc,docx,jpg,jpeg,png

# Security
JWT_SECRET=
JWT_EXPIRY=24h
BCRYPT_ROUNDS=10
SESSION_LIFETIME=120
RATE_LIMIT_MAX=100
CORS_ORIGIN=*

# Backup
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 0 * * *"
BACKUP_RETENTION_DAYS=30

# Notification
NOTIFICATION_EMAIL_ENABLED=false
NOTIFICATION_TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Logging
LOG_LEVEL=debug
LOG_CHANNEL=daily
LOG_RETENTION_DAYS=14

# Feature Flags
FEATURE_DIGITAL_SIGNATURE=false
FEATURE_QR_CODE=true
FEATURE_OCR=false
FEATURE_EXPORT_EXCEL=true
FEATURE_EXPORT_PDF=true

# External Services
OCR_API_KEY=
MAPS_API_KEY=
SMS_API_KEY=
