# ============================================
# ENVIRONMENT CONFIGURATION - EXAMPLE FILE
# ARSIP SURAT DIGITAL ENTERPRISE v3.2.2
# ============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env with real secrets
# ============================================

# App
APP_NAME=Arsip Surat Digital Enterprise
APP_VERSION=3.2.2
APP_ENV=development
APP_URL=http://localhost:8080
APP_PRODUCTION_URL=https://warso-id.github.io/arsip-surat-digital-enterprise

# Google Apps Script (REQUIRED)
GAS_API_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
GAS_SCRIPT_ID=YOUR_SCRIPT_ID

# Google Sheets (REQUIRED)
SPREADSHEET_ID=YOUR_SPREADSHEET_ID
SPREADSHEET_ID_ENCODED=YOUR_ENCODED_SPREADSHEET_ID
MASTER_FOLDER_ID=YOUR_FOLDER_ID

# Security (CHANGE THESE)
JWT_SECRET=generate-a-random-secret-here
CSRF_SECRET=generate-a-random-secret-here
ENCRYPTION_SECRET=generate-a-random-secret-here
API_KEY=generate-a-random-api-key-here

# Features
FEATURE_BIOMETRIC=true
FEATURE_TWO_FACTOR=true
FEATURE_AI=true
FEATURE_OCR=true
FEATURE_BLOCKCHAIN=true

# Push Notifications (Optional)
PUSH_VAPID_PUBLIC_KEY=your-vapid-public-key
PUSH_VAPID_PRIVATE_KEY=your-vapid-private-key

# Development
DEV_SERVER_PORT=8080
DEV_MOCK_API=true

# Build
BUILD_OUTPUT_DIR=./build
BUILD_MINIFY=true

# Deploy
DEPLOY_TARGET=github
DEPLOY_BRANCH=gh-pages
