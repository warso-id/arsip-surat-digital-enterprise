# Enterprise Application Environment Configuration
APP_NAME=Arsip Surat Digital Enterprise
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-domain.com
APP_VERSION=2026.1

# Google Apps Script Integration
GAS_SCRIPT_URL=https://script.google.com/macros/s/AKfycbwblauw29Cv8rmrjQHhfXgdl0csBHlxO3xvZJimyBsSyA4F5f9qH25Ej5QYIu--OGy6Bw/exec
GAS_API_KEY=your-api-key-here

# Database Configuration
DB_CONNECTION=gas
DB_HOST=script.google.com
DB_DATABASE=arsip_surat_enterprise

# Security
JWT_SECRET=your-jwt-secret-key-here
ENCRYPTION_KEY=your-32-character-encryption-key
CORS_ALLOWED_ORIGINS=*

# Session
SESSION_DRIVER=database
SESSION_LIFETIME=120

# Cache
CACHE_DRIVER=redis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail
MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
