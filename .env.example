# ==================== ARSIP SURAT DIGITAL ENTERPRISE ====================
# Environment Configuration Template
# Copy to .env and fill with your values
# NEVER commit .env to repository!

# ==================== APPLICATION ====================
APP_NAME="Arsip Surat Digital Enterprise"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:3000
APP_PORT=3000
APP_TIMEZONE=Asia/Jakarta
APP_LOCALE=id

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APP_KEY=

# ==================== DATABASE ====================
DB_CONNECTION=sqlite
DB_SQLITE_PATH=database.sqlite

# MySQL (Optional)
# DB_CONNECTION=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_DATABASE=arsip_surat
# DB_USERNAME=root
# DB_PASSWORD=

# ==================== AUTHENTICATION ====================
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

SESSION_DRIVER=jwt
SESSION_LIFETIME=120
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_TIME=30
PASSWORD_MIN_LENGTH=8

# ==================== STORAGE ====================
STORAGE_DISK=local
MAX_FILE_SIZE=10485760
IMAGE_MAX_WIDTH=2000
IMAGE_MAX_HEIGHT=2000
IMAGE_QUALITY=80

# ==================== MAIL ====================
MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@arsipsurat.id
MAIL_FROM_NAME="Arsip Surat Digital"

# ==================== SECURITY ====================
CORS_ENABLED=true
CORS_ORIGINS=*
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ==================== PWA ====================
PWA_ENABLED=true

# ==================== LOGGING ====================
LOG_CHANNEL=daily
LOG_LEVEL=debug
LOG_DAYS=30

# ==================== BACKUP ====================
BACKUP_ENABLED=false
BACKUP_SCHEDULE="0 2 * * *"
BACKUP_KEEP=7

# ==================== GOOGLE APPS SCRIPT ====================
# Base64 encoded GAS configuration
# Encode with: echo -n '{"url":"https://script.google.com/macros/s/.../exec","key":"your-key"}' | base64
GAS_CONFIG_BASE64=

# ==================== API ====================
API_PER_PAGE=15
API_MAX_PER_PAGE=100
API_THROTTLE_ENABLED=true
API_THROTTLE_MAX=60
