# API Configuration
API_URL=https://script.google.com/macros/s/AKfycbw.../exec
SPREADSHEET_ID=your-spreadsheet-id-here
MASTER_FOLDER_ID=your-master-folder-id-here

# Security
JWT_SECRET=arsip-surat-digital-enterprise-secret-key-v3
SESSION_TIMEOUT=3600000

# Push Notifications
PUSH_VAPID_KEY=your-vapid-public-key

# Feature Flags
FEATURE_BIOMETRIC=true
FEATURE_2FA=true
FEATURE_AI=true
FEATURE_OCR=true
FEATURE_BLOCKCHAIN=true

# App
APP_NAME=Arsip Surat Digital Enterprise
APP_VERSION=3.2.2
APP_URL=https://your-domain.com
